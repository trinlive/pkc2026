<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Sarabun', sans-serif; }
        
        @keyframes shine {
            0% {
                left: -100%;
                opacity: 0;
            }
            50% {
                opacity: 1;
            }
            100% {
                left: 100%;
                opacity: 0;
            }
        }
        
        .logo-shine {
            position: absolute;
            top: 0;
            left: -100%;
            width: 50%;
            height: 100%;
            background: linear-gradient(90deg, 
                transparent, 
                rgba(255, 255, 255, 0.6), 
                transparent);
            transform: skewX(-20deg);
            animation: shine 1.5s ease-in-out;
            pointer-events: none;
            z-index: 1;
        }

        /* Modal Styles */
        .modal-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.9);
            z-index: 9999;
            animation: fadeIn 0.2s ease-out;
        }
        .modal-overlay.active {
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .modal-content {
            position: relative;
            max-width: 90vw;
            max-height: 90vh;
            animation: zoomIn 0.3s ease-out;
        }
        .modal-content img {
            max-width: 100%;
            max-height: 90vh;
            object-fit: contain;
            border-radius: 8px;
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.5);
        }
        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }
        @keyframes zoomIn {
            from { transform: scale(0.8); opacity: 0; }
            to { transform: scale(1); opacity: 1; }
        }
    </style>
</head>
<body class="bg-gray-50 text-gray-900">
    <% const safeSearchQuery = (typeof searchQuery !== 'undefined' && searchQuery) ? searchQuery : ''; %>
    <%- include('./partials/mourning_ribbon') %>
    <%- include('./partials/header') %>

    <!-- Header Section -->
    <header class="bg-gradient-to-r from-blue-700 to-blue-800 text-white py-12 px-6 shadow-lg">
        <div class="max-w-7xl mx-auto">
            <div class="flex items-center justify-between mb-4">
                <h1 class="text-3xl lg:text-4xl font-bold flex items-center">
                    <svg class="w-8 h-8 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10l4 4v10a2 2 0 01-2 2z"></path>
                    </svg>
                    ข่าวประชาสัมพันธ์ทั้งหมด
                </h1>
                <a href="/" class="text-sm bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded-lg transition flex items-center">
                    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                    </svg>
                    กลับหน้าแรก
                </a>
            </div>
            
            <!-- Search Box -->
            <div class="mb-4 flex flex-col md:flex-row gap-3">
                <div class="flex-1 relative">
                    <input 
                        type="text" 
                        id="searchInput" 
                        placeholder="ค้นหาข่าว..." 
                        value="<%= safeSearchQuery %>"
                        class="w-full px-4 py-3 rounded-lg text-gray-800 focus:outline-none focus:ring-4 focus:ring-yellow-400 transition shadow-md"
                    >
                    <svg class="absolute right-3 top-3.5 w-5 h-5 text-gray-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                    </svg>
                </div>
                <button onclick="clearSearch()" class="px-6 py-3 bg-yellow-500 hover:bg-yellow-600 text-blue-900 font-bold rounded-lg transition shadow-md whitespace-nowrap">
                    ล้างค้นหา
                </button>
            </div>
            
            <% if (safeSearchQuery) { %>
                <p class="text-blue-100">ผลการค้นหา "<%= safeSearchQuery %>" - พบ <%= totalNews %> รายการ</p>
            <% } else { %>
                <p class="text-blue-100">รวม <%= totalNews %> รายการข่าว</p>
            <% } %>
        </div>
    </header>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-4 py-12">
        <!-- News Grid -->
        <% if (newsList && newsList.length > 0) { %>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <% newsList.forEach((news) => { %>
                    <% 
                        const date = news.date_posted ? new Date(news.date_posted) : new Date();
                        const thaiDate = date.toLocaleDateString('th-TH', { day: 'numeric', month: 'long', year: 'numeric' });
                        const badgeText = news.is_featured ? 'ด่วนที่สุด' : (news.news_category || 'ข่าวประชาสัมพันธ์');
                        const badgeClass = news.is_featured ? 'bg-red-600' : 'bg-blue-600';
                        const sourceImageUrl = news.image_preview_url || news.image_url;
                        const detailUrl = news.attachment_url || '#';
                        let imageUrl = 'https://images.unsplash.com/photo-1554224155-8d04cb21cd6c?q=80&w=600&auto=format&fit=crop';
                        if (sourceImageUrl) {
                            try {
                                const cleanImagePath = decodeURIComponent(String(sourceImageUrl).split('#')[0].trim());
                                if (cleanImagePath) {
                                    if (/^https?:\/\//i.test(cleanImagePath) || cleanImagePath.startsWith('/')) {
                                        imageUrl = cleanImagePath;
                                    } else {
                                        imageUrl = `/${cleanImagePath}`;
                                    }
                                }
                            } catch (e) {
                                const fallbackPath = String(sourceImageUrl).split('#')[0].trim();
                                if (fallbackPath) {
                                    imageUrl = fallbackPath.startsWith('/') ? fallbackPath : `/${fallbackPath}`;
                                }
                            }
                        }
                        
                        // Strip HTML tags and Joomla shortcodes from description for preview
                        const stripHtml = (html) => {
                            if (!html) return '';
                            return String(html)
                                .replace(/<[^>]*>/g, ' ')           // Remove HTML tags
                                .replace(/\{[^}]*\}/g, ' ')         // Remove Joomla shortcodes
                                .replace(/\s+/g, ' ')               // Normalize whitespace
                                .trim();
                        };
                        const plainDescription = stripHtml(news.description);
                    %>
                    <div 
                        class="bg-white rounded-2xl shadow-sm border border-gray-100 hover:shadow-lg hover:border-blue-200 transition-all duration-300 flex flex-col overflow-hidden group"
                        data-news-card
                        data-title="<%= news.title %>"
                        data-description="<%= plainDescription %>"
                        data-category="<%= news.news_category || '' %>"
                    >
                        <!-- Image Section -->
                        <div class="relative overflow-hidden h-48 shrink-0">
                            <img src="<%= imageUrl %>" alt="<%= news.title %>" class="w-full h-full object-cover transform group-hover:scale-110 transition duration-500">
                            <div class="absolute top-3 left-3 <%= badgeClass %> text-white text-[10px] font-bold px-2.5 py-1 rounded-md shadow-md uppercase tracking-wide">
                                <%= badgeText %>
                            </div>
                        </div>
                        
                        <!-- Content Section -->
                        <div class="p-4 flex flex-col justify-between flex-1">
                            <!-- Date -->
                            <div class="text-xs text-gray-400 mb-2 flex items-center font-medium tracking-wide">
                                <svg class="w-4 h-4 mr-1 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                                <%= thaiDate %>
                            </div>
                            
                            <!-- Title -->
                            <h3 class="text-base font-bold text-gray-800 mb-2 group-hover:text-blue-700 transition line-clamp-2 leading-snug">
                                <%= news.title %>
                            </h3>
                            
                            <!-- Description -->
                            <p class="text-sm text-gray-600 mb-4 leading-relaxed line-clamp-2">
                                <%= plainDescription || 'ไม่มีรายละเอียดข่าว' %>
                            </p>
                            
                            <!-- Read More Link -->
                            <div class="mt-auto">
                                <button onclick="handleAttachmentClick('<%= detailUrl %>', '<%= news.title %>')" class="inline-flex items-center text-blue-600 font-semibold text-sm hover:text-blue-800 transition cursor-pointer">
                                    อ่านรายละเอียด <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                                </button>
                            </div>
                        </div>
                    </div>
                <% }); %>
            </div>

            <!-- Pagination -->
            <% if (totalPages > 1) { %>
                <nav class="mt-12 flex justify-center items-center gap-2">
                    <!-- Previous Button -->
                    <% if (currentPage > 1) { %>
                        <a href="/news<%= safeSearchQuery ? '?q=' + encodeURIComponent(safeSearchQuery) + '&page=' : '?page=' %><%= currentPage - 1 %>" class="px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-blue-50 hover:border-blue-400 transition">
                            ← ก่อนหน้า
                        </a>
                    <% } else { %>
                        <span class="px-4 py-2 border border-gray-200 rounded-lg text-gray-400 bg-gray-50 cursor-not-allowed">
                            ← ก่อนหน้า
                        </span>
                    <% } %>

                    <!-- Page Numbers -->
                    <div class="flex gap-1">
                        <% 
                            const startPage = Math.max(1, currentPage - 2);
                            const endPage = Math.min(totalPages, currentPage + 2);
                        %>
                        <% if (startPage > 1) { %>
                            <a href="/news<%= safeSearchQuery ? '?q=' + encodeURIComponent(safeSearchQuery) + '&page=1' : '?page=1' %>" class="px-3 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-blue-50 transition">1</a>
                            <% if (startPage > 2) { %>
                                <span class="px-3 py-2 text-gray-400">...</span>
                            <% } %>
                        <% } %>

                        <% for (let i = startPage; i <= endPage; i++) { %>
                            <% if (i === currentPage) { %>
                                <span class="px-3 py-2 bg-blue-600 text-white rounded-lg font-bold">
                                    <%= i %>
                                </span>
                            <% } else { %>
                                <a href="/news<%= safeSearchQuery ? '?q=' + encodeURIComponent(safeSearchQuery) + '&page=' + i : '?page=' + i %>" class="px-3 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-blue-50 hover:border-blue-400 transition">
                                    <%= i %>
                                </a>
                            <% } %>
                        <% } %>

                        <% if (endPage < totalPages) { %>
                            <% if (endPage < totalPages - 1) { %>
                                <span class="px-3 py-2 text-gray-400">...</span>
                            <% } %>
                            <a href="/news<%= safeSearchQuery ? '?q=' + encodeURIComponent(safeSearchQuery) + '&page=' + totalPages : '?page=' + totalPages %>" class="px-3 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-blue-50 transition">
                                <%= totalPages %>
                            </a>
                        <% } %>
                    </div>

                    <!-- Next Button -->
                    <% if (currentPage < totalPages) { %>
                        <a href="/news<%= safeSearchQuery ? '?q=' + encodeURIComponent(safeSearchQuery) + '&page=' : '?page=' %><%= currentPage + 1 %>" class="px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-blue-50 hover:border-blue-400 transition">
                            ถัดไป →
                        </a>
                    <% } else { %>
                        <span class="px-4 py-2 border border-gray-200 rounded-lg text-gray-400 bg-gray-50 cursor-not-allowed">
                            ถัดไป →
                        </span>
                    <% } %>
                </nav>

                <!-- Pagination Info -->
                <div class="text-center mt-6 text-gray-500 text-sm">
                    หน้า <%= currentPage %> จาก <%= totalPages %> (รวม <%= totalNews %> รายการ)
                </div>
            <% } %>

        <% } else { %>
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-12 text-center">
                <svg class="w-16 h-16 mx-auto text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10l4 4v10a2 2 0 01-2 2z"></path>
                </svg>
                <p class="text-gray-500 text-lg">ยังไม่มีข่าวประชาสัมพันธ์ในระบบ</p>
            </div>
        <% } %>
    </main>

    <!-- Footer -->
    <footer class="bg-blue-900 text-blue-100 py-8 px-4 border-t-4 border-yellow-500 mt-12 relative z-10">
        <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-6">
            
            <div class="flex flex-col items-center md:items-start text-center md:text-left">
                    <div class="logo-container bg-white/5 p-2 rounded-full shadow-inner flex items-center justify-center w-16 h-16 mb-3">
                    <img src="/images/logo.png" alt="PKC Logo" class="w-12 h-12 relative z-10">
                </div>
                <h3 class="text-lg font-bold text-white mb-2">สำนักงานเทศบาลนครปากเกร็ด</h3>
                <p class="text-sm leading-relaxed text-blue-200">
                    เลขที่ 1 หมู่ 5 ถ.แจ้งวัฒนะ<br>
                    ต.ปากเกร็ด อ.ปากเกร็ด<br>
                    จ.นนทบุรี 11120
                </p>
            </div>

            <div class="flex flex-col items-center md:items-start text-center md:text-left">
                <h4 class="text-base font-bold text-white mb-3 border-b-2 border-yellow-500 pb-1 inline-block">ติดต่อสอบถาม</h4>
                <ul class="space-y-2 text-sm text-blue-200">
                    <li class="flex items-center justify-center md:justify-start">
                        <span class="mr-2 text-yellow-400">📞</span> 
                        <strong>โทรศัพท์:</strong>&nbsp; 0-2960-9704-14
                    </li>
                    <li class="flex items-center justify-center md:justify-start">
                        <span class="mr-2 text-yellow-400">📠</span> 
                        <strong>โทรสาร:</strong>&nbsp; 0-2960-9703
                    </li>
                    <li class="flex items-center justify-center md:justify-start">
                        <span class="mr-2 text-yellow-400">📧</span> 
                        <strong>อีเมล:</strong>&nbsp; <a href="mailto:webmaster@pakkretcity.go.th" class="hover:text-yellow-400 transition ml-1 underline underline-offset-2">webmaster@pakkretcity.go.th</a>
                    </li>
                </ul>
            </div>

            <div class="flex flex-col items-center md:items-start text-center md:text-left">
                <h4 class="text-base font-bold text-white mb-3 border-b-2 border-yellow-500 pb-1 inline-block">ติดตามเรา</h4>
                <div class="flex space-x-3">
                    <a href="https://www.facebook.com/PakkretMunicipality" target="_blank" class="w-9 h-9 rounded-full bg-blue-800 flex items-center justify-center hover:bg-yellow-500 hover:text-blue-900 transition shadow border border-blue-700 hover:border-transparent">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.469h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.469h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                    </a>
                    <a href="#" class="w-9 h-9 rounded-full bg-blue-800 flex items-center justify-center hover:bg-yellow-500 hover:text-blue-900 transition shadow border border-blue-700 hover:border-transparent">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm4.441 16.892c-2.102.144-6.784.144-8.883 0C5.282 16.736 5.017 15.622 5 12c.017-3.629.285-4.736 2.558-4.892 2.099-.144 6.782-.144 8.883 0C18.718 7.264 18.982 8.378 19 12c-.018 3.629-.285 4.736-2.559 4.892zM10 9.658l4.917 2.338L10 14.342V9.658z"/></svg>
                    </a>
                    <a href="#" class="w-9 h-9 rounded-full bg-blue-800 flex items-center justify-center hover:bg-yellow-500 hover:text-blue-900 transition shadow border border-blue-700 hover:border-transparent font-bold text-xs">
                        LINE
                    </a>
                </div>
            </div>

        </div>

        <div class="max-w-7xl mx-auto border-t border-blue-800 mt-8 pt-5 text-center text-xs text-blue-400">
            <p>© 2026 Pakkret City Municipality. All rights reserved.</p>
        </div>
    </footer>
    <%- include('./partials/sticky_news') %>

    <!-- Image Modal -->
    <div id="imageModal" class="modal-overlay" onclick="closeModal(event)">
        <div class="modal-content" onclick="event.stopPropagation()">
            <img id="modalImage" src="" alt="Preview">
            <!-- Close Button -->
            <button onclick="closeModal()" class="absolute top-4 right-4 bg-white/10 hover:bg-white/20 text-white rounded-full w-12 h-12 flex items-center justify-center transition backdrop-blur-sm border border-white/30">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </button>
            <!-- Download Button -->
            <a id="modalDownload" href="" download class="absolute bottom-4 right-4 bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg flex items-center gap-2 transition shadow-lg">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
                </svg>
                ดาวน์โหลด
            </a>
            <!-- Image Title -->
            <div class="absolute top-4 left-4 bg-black/60 text-white px-4 py-2 rounded-lg backdrop-blur-sm max-w-2xl">
                <p id="modalTitle" class="font-semibold text-sm"></p>
            </div>
        </div>
    </div>

    <script src="/js/mobile-menu.js"></script>
    <script src="/js/logo-shine.js"></script>
    
    <script>
        // Search functionality
        const searchInput = document.getElementById('searchInput');
        
        // ค้นหาเมื่อ Enter key ถูกกด
        if (searchInput) {
            searchInput.addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    performSearch();
                }
            });
        }
        
        function performSearch() {
            const searchTerm = (searchInput.value || '').trim();
            if (searchTerm) {
                window.location.href = `/news?q=${encodeURIComponent(searchTerm)}`;
            } else {
                window.location.href = '/news';
            }
        }
        
        function clearSearch() {
            window.location.href = '/news';
        }
        
        // Handle attachment click (PDF or Image)
        function handleAttachmentClick(url, title) {
            if (!url || url === '#') {
                alert('ไม่มีไฟล์แนบสำหรับข่าวนี้');
                return;
            }
            
            // Check file extension
            const fileExt = url.toLowerCase().split('.').pop().split('?')[0];
            const imageExtensions = ['jpg', 'jpeg', 'png', 'gif', 'webp'];
            const pdfExtensions = ['pdf'];
            
            if (imageExtensions.includes(fileExt)) {
                // Show image in modal
                openImageModal(url, title);
            } else if (pdfExtensions.includes(fileExt)) {
                // Open PDF in new tab
                window.open(url, '_blank', 'noopener,noreferrer');
            } else {
                // Unknown type - open in new tab
                window.open(url, '_blank', 'noopener,noreferrer');
            }
        }
        
        // Open image modal
        function openImageModal(imageUrl, title) {
            const modal = document.getElementById('imageModal');
            const modalImage = document.getElementById('modalImage');
            const modalTitle = document.getElementById('modalTitle');
            const modalDownload = document.getElementById('modalDownload');
            
            modalImage.src = imageUrl;
            modalTitle.textContent = title || 'ภาพประกอบข่าว';
            modalDownload.href = imageUrl;
            modal.classList.add('active');
            document.body.style.overflow = 'hidden';
        }
        
        // Close modal
        function closeModal(event) {
            if (!event || event.target.id === 'imageModal') {
                const modal = document.getElementById('imageModal');
                modal.classList.remove('active');
                document.body.style.overflow = 'auto';
            }
        }
        
        // Close modal with ESC key
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                closeModal();
            }
        });
    </script>
    
    <style>
        .highlight-search {
            animation: highlight 0.3s ease-out;
        }
        @keyframes highlight {
            from {
                box-shadow: 0 0 20px rgba(59, 130, 246, 0.6);
            }
            to {
                box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.1);
            }
        }
    </style>
</body>
</html>
