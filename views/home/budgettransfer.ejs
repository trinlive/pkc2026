<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Sarabun', sans-serif; }
    </style>
</head>
<body class="bg-gray-50 text-gray-900">
    <% const safeSearchQuery = (typeof searchQuery !== 'undefined' && searchQuery) ? searchQuery : ''; %>
    <%- include('./partials/mourning_ribbon') %>
    <%- include('./partials/header') %>

    <!-- Header Section -->
    <header class="bg-gradient-to-r from-blue-700 to-blue-800 text-white py-12 px-6 shadow-lg">
        <div class="max-w-7xl mx-auto">
            <div class="flex items-center justify-between mb-4">
                <h1 class="text-3xl lg:text-4xl font-bold flex items-center">
                    <svg class="w-8 h-8 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"></path>
                    </svg>
                    การโอนงบประมาณรายจ่ายประจำปี
                </h1>
                <a href="/" class="text-sm bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded-lg transition flex items-center">
                    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                    </svg>
                    กลับหน้าแรก
                </a>
            </div>
            
            <!-- Search Box -->
            <div class="mb-4 flex flex-col md:flex-row gap-3">
                <div class="flex-1 relative">
                    <input 
                        type="text" 
                        id="searchInput" 
                        placeholder="ค้นหาหัวข้อ หรือเลขอ้างอิง..." 
                        value="<%= safeSearchQuery %>"
                        class="w-full px-4 py-3 rounded-lg text-gray-800 focus:outline-none focus:ring-4 focus:ring-yellow-400 transition shadow-md"
                    >
                    <svg class="absolute right-3 top-3.5 w-5 h-5 text-gray-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                    </svg>
                </div>
                <button onclick="clearSearch()" class="px-6 py-3 bg-yellow-500 hover:bg-yellow-600 text-blue-900 font-bold rounded-lg transition shadow-md whitespace-nowrap">
                    ล้างค้นหา
                </button>
            </div>
            
            <% if (safeSearchQuery) { %>
                <p class="text-blue-100">ผลการค้นหา "<%= safeSearchQuery %>" - พบ <%= totalBudgetTransfers %> รายการ</p>
            <% } else { %>
                <p class="text-blue-100">รวม <%= totalBudgetTransfers %> รายการการโอนงบประมาณ</p>
            <% } %>
        </div>
    </header>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-4 py-12">

            <!-- Table Section -->
            <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead class="bg-blue-900 text-white">
                            <tr>
                                <th class="px-6 py-4 text-sm font-bold uppercase tracking-wider w-24 text-center">วันที่</th>
                                <th class="px-6 py-4 text-sm font-bold uppercase tracking-wider">หัวข้อ</th>
                                <th class="px-6 py-4 text-sm font-bold uppercase tracking-wider hidden md:table-cell">ประเภท</th>
                                <th class="px-6 py-4 text-sm font-bold uppercase tracking-wider text-center">ดาวน์โหลด</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            <% if (budgetTransferList && budgetTransferList.length > 0) { %>
                                <% budgetTransferList.forEach((transfer) => { %>
                                    <% 
                                        const date = transfer.date_posted ? new Date(transfer.date_posted) : new Date();
                                        const thaiDate = date.toLocaleDateString('th-TH', { day: 'numeric', month: 'short', year: 'numeric' });
                                        const categoryDisplay = transfer.category || 'งบประมาณ';
                                        const categoryColor = transfer.is_featured ? 'bg-red-100 text-red-800' : 'bg-gray-100 text-gray-800';
                                    %>
                                    <tr class="hover:bg-blue-50/50 transition-colors">
                                        <td class="px-6 py-4 text-sm text-gray-500 text-center font-medium whitespace-nowrap">
                                            <%= thaiDate %>
                                        </td>
                                        <td class="px-6 py-4">
                                            <button 
                                                class="block w-full text-left text-sm md:text-base text-gray-700 font-semibold hover:text-blue-700 transition line-clamp-2 md:line-clamp-1 cursor-pointer hover:underline detail-btn"
                                                data-id="<%= transfer.id %>"
                                                data-title="<%= transfer.title %>"
                                                data-description="<%= transfer.description || '' %>"
                                                data-category="<%= categoryDisplay %>"
                                                data-reference="<%= transfer.reference_number || '' %>"
                                            >
                                                <%= transfer.title %>
                                            </button>
                                            <div class="md:hidden mt-1">
                                                <span class="inline-block text-[10px] px-2 py-0.5 rounded <%= categoryColor %> uppercase font-bold">
                                                    <%= categoryDisplay %>
                                                </span>
                                                <% if (transfer.attachment_url) { %>
                                                    <span class="inline-block ml-1 text-[10px] px-2 py-0.5 rounded bg-green-100 text-green-800 uppercase font-bold">
                                                        มีไฟล์แนบ
                                                    </span>
                                                <% } %>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4 hidden md:table-cell">
                                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold <%= categoryColor %> uppercase">
                                                <%= categoryDisplay %>
                                            </span>
                                        </td>
                                        <td class="px-6 py-4 text-center">
                                            <% if (transfer.attachment_url) { %>
                                                <a href="<%= transfer.attachment_url %>" target="_blank" class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-blue-50 text-blue-600 hover:bg-blue-600 hover:text-white transition shadow-sm border border-blue-100">
                                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                                                </a>
                                            <% } else { %>
                                                <button disabled class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-gray-100 text-gray-400 cursor-not-allowed border border-gray-200">
                                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
                                                </button>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="4" class="px-6 py-12 text-center text-gray-500">
                                        <% if (searchQuery) { %>
                                            ไม่พบข้อมูลการโอนงบประมาณที่ตรงกับคำค้นหา
                                        <% } else { %>
                                            ยังไม่มีข้อมูลการโอนงบประมาณเผยแพร่
                                        <% } %>
                                    </td>
                                </tr>
                            <% } %>                        </tbody>
                    </table>
                </div>
                
                <!-- Pagination Footer -->
                <div class="bg-gray-50 px-6 py-4 flex flex-col md:flex-row items-center justify-between border-t border-gray-100 gap-4">
                    <p class="text-xs text-gray-500 font-medium italic">* ข้อมูลการโอนงบประมาณของเทศบาลนครปากเกร็ด</p>
                    <% if (totalPages > 1) { %>
                        <div class="flex flex-wrap items-center justify-center gap-2">
                            <% if (currentPage > 1) { %>
                                <a href="?page=1<%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>" class="px-3 py-1 bg-white border border-gray-300 rounded text-xs text-gray-600 hover:bg-blue-600 hover:text-white hover:border-blue-600 transition font-medium">
                                    ที่ 1
                                </a>
                                <a href="?page=<%= currentPage - 1 %><%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>" class="px-3 py-1 bg-white border border-gray-300 rounded text-xs text-gray-600 hover:bg-blue-600 hover:text-white hover:border-blue-600 transition font-medium">
                                    ก่อนหน้า
                                </a>
                            <% } %>
                            
                            <% for (let i = Math.max(1, currentPage - 2); i <= Math.min(totalPages, currentPage + 2); i++) { %>
                                <% if (i === currentPage) { %>
                                    <span class="px-3 py-1 bg-blue-600 border border-blue-600 rounded text-xs text-white font-bold">
                                        <%= i %>
                                    </span>
                                <% } else { %>
                                    <a href="?page=<%= i %><%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>" class="px-3 py-1 bg-white border border-gray-300 rounded text-xs text-gray-600 hover:bg-blue-600 hover:text-white hover:border-blue-600 transition font-medium">
                                        <%= i %>
                                    </a>
                                <% } %>
                            <% } %>
                            
                            <% if (currentPage < totalPages) { %>
                                <a href="?page=<%= currentPage + 1 %><%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>" class="px-3 py-1 bg-white border border-gray-300 rounded text-xs text-gray-600 hover:bg-blue-600 hover:text-white hover:border-blue-600 transition font-medium">
                                    ถัดไป
                                </a>
                                <a href="?page=<%= totalPages %><%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>" class="px-3 py-1 bg-white border border-gray-300 rounded text-xs text-gray-600 hover:bg-blue-600 hover:text-white hover:border-blue-600 transition font-medium">
                                    ที่ <%= totalPages %>
                                </a>
                            <% } %>
                        </div>
                    <% } else { %>
                        <div class="flex space-x-2">
                            <button class="px-3 py-1 bg-white border border-gray-300 rounded text-xs text-gray-600 disabled:opacity-50" disabled>ก่อนหน้า</button>
                            <button class="px-3 py-1 bg-white border border-gray-300 rounded text-xs text-gray-600 disabled:opacity-50" disabled>ถัดไป</button>
                        </div>
                    <% } %>
                </div>
            </div>

        </div>
    </main>

    <%- include('./partials/widgets') %>

    <!-- Details Modal -->
    <div id="detailsModal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-[9999] flex items-center justify-center p-4">
        <div class="bg-white rounded-lg max-w-2xl w-full max-h-[90vh] overflow-y-auto">
            <div class="sticky top-0 bg-blue-900 text-white p-6 flex justify-between items-start">
                <div>
                    <h2 id="modalTitle" class="text-2xl font-bold mb-2"></h2>
                    <p id="modalRef" class="text-blue-200 text-xs mb-1"></p>
                    <p id="modalCategory" class="text-blue-200 text-sm"></p>
                </div>
                <button onclick="closeDetailsModal()" class="text-white hover:bg-blue-700 rounded-full p-2 transition flex-shrink-0">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            <div class="p-6">
                <p id="modalDescription" class="text-gray-700 leading-relaxed whitespace-pre-wrap text-sm"></p>
            </div>
        </div>
    </div>

    <script>
        // Search function - trigger on Enter key
        document.getElementById('searchInput')?.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                const query = this.value.trim();
                if (query) {
                    window.location.href = `/budgettransfer?q=${encodeURIComponent(query)}`;
                } else {
                    window.location.href = '/budgettransfer';
                }
            }
        });

        function clearSearch() {
            window.location.href = '/budgettransfer';
        }

        function openDetails(id, title, description, category, reference) {
            document.getElementById('modalTitle').textContent = title;
            document.getElementById('modalCategory').textContent = 'ประเภท: ' + category;
            document.getElementById('modalRef').textContent = reference ? 'เลขอ้างอิง: ' + reference : '';
            
            const stripHtml = (html) => {
                if (!html) return '';
                return String(html)
                    .replace(/<[^>]*>/g, ' ')
                    .replace(/\{[^}]*\}/g, ' ')
                    .replace(/\s+/g, ' ')
                    .trim();
            };
            
            document.getElementById('modalDescription').textContent = stripHtml(description) || 'ไม่มีรายละเอียด';
            document.getElementById('detailsModal').classList.remove('hidden');
        }

        function closeDetailsModal() {
            document.getElementById('detailsModal').classList.add('hidden');
        }

        // Detail button click handler
        document.querySelectorAll('.detail-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                const id = this.dataset.id;
                const title = this.dataset.title;
                const description = this.dataset.description;
                const category = this.dataset.category;
                const reference = this.dataset.reference;
                openDetails(id, title, description, category, reference);
            });
        });

        // Close modal on Escape key
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                closeDetailsModal();
            }
        });

        // Close modal when clicking outside
        document.getElementById('detailsModal')?.addEventListener('click', (e) => {
            if (e.target.id === 'detailsModal') {
                closeDetailsModal();
            }
        });
    </script>
</body>
</html>
