<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Sarabun', sans-serif; }
        .modal-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.9);
            z-index: 9999;
            animation: fadeIn 0.2s ease-out;
        }
        .modal-overlay.active {
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .modal-content {
            position: relative;
            max-width: 90vw;
            max-height: 90vh;
            animation: zoomIn 0.3s ease-out;
        }
        .modal-content img,
        .modal-content iframe {
            max-width: 100%;
            max-height: 90vh;
            border-radius: 8px;
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.5);
            background: #fff;
        }
        .modal-content iframe {
            width: 90vw;
            height: 90vh;
            border: 0;
        }
        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }
        @keyframes zoomIn {
            from { transform: scale(0.8); opacity: 0; }
            to { transform: scale(1); opacity: 1; }
        }
    </style>
</head>
<body class="bg-gray-50 text-gray-900">
    <%- include('./partials/mourning_ribbon') %>
    <%- include('./partials/header') %>

    <header class="bg-gradient-to-r from-blue-700 to-blue-800 text-white py-12 px-6 shadow-lg">
        <div class="max-w-7xl mx-auto">
            <div class="flex items-center justify-between mb-3">
                <h1 class="text-3xl lg:text-4xl font-bold flex items-center">
                    <span class="bg-yellow-400 w-2 h-8 mr-3 rounded-full"></span>
                    ข่าวกิจกรรมทั้งหมด
                </h1>
                <a href="/" class="text-sm bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded-lg transition flex items-center">
                    กลับหน้าแรก
                </a>
            </div>
            <% if (searchQuery) { %>
                <p class="text-blue-100">ผลการค้นหา "<%= searchQuery %>" - พบ <%= totalActivities %> รายการ</p>
            <% } else { %>
                <p class="text-blue-100">รวม <%= totalActivities %> รายการกิจกรรม</p>
            <% } %>

            <div class="mt-4 flex flex-col md:flex-row gap-3">
                <div class="flex-1 relative">
                    <input
                        type="text"
                        id="searchInput"
                        placeholder="ค้นหาข่าวกิจกรรม..."
                        value="<%= searchQuery %>"
                        class="w-full px-4 py-3 rounded-lg text-gray-800 focus:outline-none focus:ring-4 focus:ring-yellow-400 transition shadow-md"
                    >
                    <svg class="absolute right-3 top-3.5 w-5 h-5 text-gray-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                    </svg>
                </div>
                <button onclick="clearSearch()" class="px-6 py-3 bg-yellow-500 hover:bg-yellow-600 text-blue-900 font-bold rounded-lg transition shadow-md whitespace-nowrap">
                    ล้างค้นหา
                </button>
            </div>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 py-12">
        <% if (activitiesList && activitiesList.length > 0) { %>
            <div id="activitiesGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                <% activitiesList.forEach((activity) => { %>
                    <% 
                        const date = activity.date_posted ? new Date(activity.date_posted) : new Date();
                        const displayDate = date.toLocaleDateString('th-TH', { day: 'numeric', month: 'long', year: 'numeric' });
                        const sourceImageUrl = activity.image_preview_url || activity.image_url;
                        const detailUrl = activity.attachment_url || '#';
                        let imageUrl = 'https://images.unsplash.com/photo-1554224155-8d04cb21cd6c?q=80&w=800&auto=format&fit=crop';

                        if (sourceImageUrl) {
                            try {
                                const cleanImagePath = decodeURIComponent(String(sourceImageUrl).split('#')[0].trim());
                                if (cleanImagePath) {
                                    if (/^https?:\/\//i.test(cleanImagePath) || cleanImagePath.startsWith('/')) {
                                        imageUrl = cleanImagePath;
                                    } else {
                                        imageUrl = `/${cleanImagePath}`;
                                    }
                                }
                            } catch (e) {
                                const fallbackPath = String(sourceImageUrl).split('#')[0].trim();
                                if (fallbackPath) {
                                    imageUrl = fallbackPath.startsWith('/') ? fallbackPath : `/${fallbackPath}`;
                                }
                            }
                        }
                    %>
                    <article class=\"bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-shadow duration-300 group flex flex-col border border-gray-100\" data-activity-card data-title=\"<%= activity.title %>\">
                        <div class="relative overflow-hidden h-52">
                            <img src="<%= imageUrl %>" alt="<%= activity.title %>" class="w-full h-full object-cover transform group-hover:scale-110 transition duration-500">
                            <div class="absolute top-4 left-4 bg-yellow-500 text-gray-900 text-xs font-bold px-3 py-1.5 rounded-full shadow">
                                ข่าวกิจกรรม
                            </div>
                        </div>
                        <div class="p-6 flex-1 flex flex-col">
                            <h3 class="text-lg font-bold text-gray-800 mb-3 line-clamp-2 group-hover:text-blue-600 transition">
                                <%= activity.title %>
                            </h3>
                            <div class="mt-auto flex items-center justify-between text-sm text-gray-500 border-t border-gray-100 pt-4 gap-3">
                                <span class="truncate"><%= displayDate %></span>
                                <button type="button" data-url="<%= detailUrl || '#' %>" data-title="<%= activity.title || '' %>" onclick="handleActivityAttachmentClickFromButton(this)" class="text-blue-600 hover:text-blue-800 font-semibold whitespace-nowrap">
                                    อ่านรายละเอียด
                                </button>
                            </div>
                        </div>
                    </article>
                <% }); %>
            </div>

            <div id="noSearchResult" class="hidden mt-8 bg-white rounded-2xl shadow-sm border border-gray-100 p-8 text-center text-gray-500">
                ไม่พบข่าวกิจกรรมที่ค้นหา
            </div>

            <% if (totalPages > 1) { %>
                <nav id="paginationNav" class="mt-12 flex justify-center items-center gap-2">
                    <!-- Previous Button -->
                    <% if (currentPage > 1) { %>
                        <a href="/activities<%= searchQuery ? '?q=' + encodeURIComponent(searchQuery) + '&page=' : '?page=' %><%= currentPage - 1 %>" class="px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-blue-50 hover:border-blue-400 transition">
                            ← ก่อนหน้า
                        </a>
                    <% } else { %>
                        <span class="px-4 py-2 border border-gray-200 rounded-lg text-gray-400 bg-gray-50 cursor-not-allowed">
                            ← ก่อนหน้า
                        </span>
                    <% } %>

                    <!-- Page Numbers -->
                    <div class="flex gap-1">
                        <% 
                            const startPage = Math.max(1, currentPage - 2);
                            const endPage = Math.min(totalPages, currentPage + 2);
                        %>
                        <% if (startPage > 1) { %>
                            <a href="/activities<%= searchQuery ? '?q=' + encodeURIComponent(searchQuery) + '&page=1' : '?page=1' %>" class="px-3 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-blue-50 transition">1</a>
                            <% if (startPage > 2) { %>
                                <span class="px-3 py-2 text-gray-400">...</span>
                            <% } %>
                        <% } %>

                        <% for (let i = startPage; i <= endPage; i++) { %>
                            <% if (i === currentPage) { %>
                                <span class="px-3 py-2 bg-blue-600 text-white rounded-lg font-bold">
                                    <%= i %>
                                </span>
                            <% } else { %>
                                <a href="/activities<%= searchQuery ? '?q=' + encodeURIComponent(searchQuery) + '&page=' + i : '?page=' + i %>" class="px-3 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-blue-50 hover:border-blue-400 transition">
                                    <%= i %>
                                </a>
                            <% } %>
                        <% } %>

                        <% if (endPage < totalPages) { %>
                            <% if (endPage < totalPages - 1) { %>
                                <span class="px-3 py-2 text-gray-400">...</span>
                            <% } %>
                            <a href="/activities<%= searchQuery ? '?q=' + encodeURIComponent(searchQuery) + '&page=' + totalPages : '?page=' + totalPages %>" class="px-3 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-blue-50 transition">
                                <%= totalPages %>
                            </a>
                        <% } %>
                    </div>

                    <!-- Next Button -->
                    <% if (currentPage < totalPages) { %>
                        <a href="/activities<%= searchQuery ? '?q=' + encodeURIComponent(searchQuery) + '&page=' : '?page=' %><%= currentPage + 1 %>" class="px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-blue-50 hover:border-blue-400 transition">
                            ถัดไป →
                        </a>
                    <% } else { %>
                        <span class="px-4 py-2 border border-gray-200 rounded-lg text-gray-400 bg-gray-50 cursor-not-allowed">
                            ถัดไป →
                        </span>
                    <% } %>
                </nav>

                <!-- Pagination Info -->
                <div class="text-center mt-6 text-gray-500 text-sm">
                    หน้า <%= currentPage %> จาก <%= totalPages %> (รวม <%= totalActivities %> รายการ)
                </div>
            <% } %>
        <% } else { %>
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8 text-center text-gray-500">
                ยังไม่มีข่าวกิจกรรมในระบบ
            </div>
        <% } %>
    </main>

    <div id="activityAttachmentModal" class="modal-overlay" onclick="closeActivityAttachmentModal(event)">
        <div class="modal-content" onclick="event.stopPropagation()">
            <div id="activityModalBody" class="relative"></div>
            <button type="button" onclick="closeActivityAttachmentModal()" class="absolute top-4 right-4 bg-white/10 hover:bg-white/20 text-white rounded-full w-12 h-12 flex items-center justify-center transition backdrop-blur-sm border border-white/30">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </button>
            <a id="activityModalDownload" href="#" download class="absolute bottom-4 right-4 bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg flex items-center gap-2 transition shadow-lg">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
                </svg>
                ดาวน์โหลด
            </a>
            <div class="absolute top-4 left-4 bg-black/60 text-white px-4 py-2 rounded-lg backdrop-blur-sm max-w-2xl">
                <p id="activityModalTitle" class="font-semibold text-sm"></p>
            </div>
        </div>
    </div>

    <script>
        const searchInput = document.getElementById('searchInput');
        
        // ค้นหาเมื่อ Enter key ถูกกด
        if (searchInput) {
            searchInput.addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    performSearch();
                }
            });
        }
        
        function performSearch() {
            const searchTerm = (searchInput.value || '').trim();
            if (searchTerm) {
                window.location.href = `/activities?q=${encodeURIComponent(searchTerm)}`;
            } else {
                window.location.href = '/activities';
            }
        }
        
        function clearSearch() {
            window.location.href = '/activities';
        }

        function handleActivityAttachmentClickFromButton(buttonEl) {
            const url = buttonEl?.dataset?.url || '#';
            const title = buttonEl?.dataset?.title || '';
            handleActivityAttachmentClick(url, title);
        }

        function handleActivityAttachmentClick(url, title) {
            if (!url || url === '#') {
                alert('ไม่มีไฟล์แนบสำหรับกิจกรรมนี้');
                return;
            }

            const modal = document.getElementById('activityAttachmentModal');
            const modalTitle = document.getElementById('activityModalTitle');
            const modalBody = document.getElementById('activityModalBody');
            const modalDownload = document.getElementById('activityModalDownload');
            const ext = url.toLowerCase().split('.').pop().split('?')[0];

            modalTitle.textContent = title || 'รายละเอียดกิจกรรม';
            modalDownload.href = url;
            modalDownload.setAttribute('download', '');

            if (['jpg', 'jpeg', 'png', 'gif', 'webp'].includes(ext)) {
                modalBody.innerHTML = `<img src="${url}" alt="${title || 'attachment'}">`;
            } else if (ext === 'pdf') {
                modalBody.innerHTML = `<iframe src="${url}" title="${title || 'PDF'}"></iframe>`;
            } else {
                window.open(url, '_blank', 'noopener,noreferrer');
                return;
            }

            modal.classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        function closeActivityAttachmentModal(event) {
            if (!event || event.target.id === 'activityAttachmentModal') {
                const modal = document.getElementById('activityAttachmentModal');
                const modalBody = document.getElementById('activityModalBody');
                const modalDownload = document.getElementById('activityModalDownload');
                modal.classList.remove('active');
                modalBody.innerHTML = '';
                if (modalDownload) {
                    modalDownload.href = '#';
                }
                document.body.style.overflow = 'auto';
            }
        }

        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                closeActivityAttachmentModal();
            }
        });
    </script>
</body>
</html>
