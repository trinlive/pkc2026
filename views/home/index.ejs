<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Sarabun', sans-serif; }
        
        @keyframes shine {
            0% {
                left: -100%;
                opacity: 0;
            }
            50% {
                opacity: 1;
            }
            100% {
                left: 100%;
                opacity: 0;
            }
        }
        
        .logo-shine {
            position: absolute;
            top: 0;
            left: -100%;
            width: 50%;
            height: 100%;
            background: linear-gradient(90deg, 
                transparent, 
                rgba(255, 255, 255, 0.6), 
                transparent);
            transform: skewX(-20deg);
            animation: shine 1.5s ease-in-out;
            pointer-events: none;
            z-index: 1;
        }
    </style>
</head>
<body class="bg-gray-50 text-gray-900">
    <%- include('./partials/mourning_ribbon') %>
    <%- include('./partials/header') %>

    <%- include('./partials/slider') %>

    <header class="bg-blue-700 text-white py-8 px-6 shadow-inner">
        <div class="max-w-7xl mx-auto flex flex-col items-center justify-center">
       <div class="flex items-center gap-4">
                <div class="logo-container bg-white/5 p-3 rounded-full shadow-lg">
                    <img src="/images/logo.png" alt="PKC Logo" class="w-16 h-16 relative z-10">
                </div>
                <h1 class="text-2xl md:text-4xl font-bold">ยินดีต้อนรับ เทศบาลนครปากเกร็ด จังหวัดนนทบุรี</h1>
            </div>
        </div>
    </header>
  <%- include('./partials/fiscal_status') %>
    <main class="max-w-7xl mx-auto px-4 py-12">
        <div class="flex flex-col md:flex-row gap-8">
            
            <div class="md:w-2/3">
                <%- include('./partials/news') %>
            </div>

            <div class="md:w-1/3 space-y-6">
                <%- include('./partials/banner') %>
            </div>
            
        </div>
    </main>
    <%- include('./partials/activities') %>
    <%- include('./partials/ebook_v2') %>
    <%- include('./partials/egp_v2') %>
    <%- include('./partials/procurement') %>
    <%- include('./partials/information_reports') %>
    <%- include('./partials/external_banners') %>
    <%- include('./partials/widgets') %>

  <footer class="bg-blue-900 text-blue-100 py-8 px-4 border-t-4 border-yellow-500 mt-8 relative z-10">
