<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;700&display=swap" rel="stylesheet">
    
    <style>
        body { font-family: 'Sarabun', sans-serif; }
        .content-html { line-height: 1.8; }
        .content-html img { max-width: 100%; height: auto; margin: 1rem 0; border-radius: 0.5rem; }
        .status-badge { display: inline-block; padding: 0.25rem 0.75rem; border-radius: 9999px; font-size: 0.875rem; }
        .status-published { background-color: #d1fae5; color: #065f46; }
        .status-draft { background-color: #fef3c7; color: #78350f; }
    </style>
</head>
<body class="bg-gray-100">
    <div class="flex min-h-screen">
        <!-- Sidebar -->
            <%- include('./partials/sidebar', { currentPage }) %>

        <!-- Main Content -->
        <main class="flex-1 p-8">
            <div class="max-w-4xl mx-auto">
                <!-- Back Button -->
                <a href="/admin/activities" class="inline-block mb-6 text-blue-600 hover:text-blue-800 font-semibold transition">
                    ← กลับไปรายการ
                </a>

                <!-- Header -->
                <div class="bg-white rounded-lg shadow-md p-6 mb-6">
                    <div class="flex justify-between items-start">
                        <div class="flex-1">
                            <h1 class="text-3xl font-bold text-gray-800 mb-2"><%= activity.title %></h1>
                            <div class="flex flex-wrap gap-4 text-sm text-gray-600">
                                <div>
                                    <span class="font-semibold">ID:</span> <%= activity.id %>
                                </div>
                                <div>
                                    <span class="font-semibold">หมวดหมู่:</span> <%= activity.category_name %>
                                </div>
                                <div>
                                    <span class="font-semibold">สถานะ:</span>
                                    <span class="status-badge <%= activity.state === 1 ? 'status-published' : 'status-draft' %>">
                                        <%= activity.state === 1 ? '✅ เผยแพร่' : '⏸️ ร่าง' %>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Content -->
                <div class="grid grid-cols-3 gap-6 mb-6">
                    <!-- Main Content -->
                    <div class="col-span-2">
                        <!-- Featured Image -->
                        <% if (activity.display_image) { %>
                            <div class="bg-white rounded-lg shadow-md p-6 mb-6">
                                <img src="<%= activity.display_image %>" alt="<%= activity.title %>" class="w-full h-auto rounded-lg" onerror="this.src='/images/placeholder.png'">
                            </div>
                        <% } %>

                        <!-- Article Content -->
                        <div class="bg-white rounded-lg shadow-md p-6 mb-6">
                            <h2 class="text-2xl font-bold text-gray-800 mb-4">บทความหลัก</h2>
                            
                            <!-- Intro Text -->
                            <% if (activity.introtext) { %>
                                <div class="mb-6">
                                    <h3 class="text-lg font-semibold text-gray-700 mb-2">บทนำ</h3>
                                    <div class="content-html text-gray-700 bg-blue-50 p-4 rounded-lg">
                                        <%- activity.introtext %>
                                    </div>
                                </div>
                            <% } %>

                            <!-- Full Text -->
                            <% if (activity.fulltext) { %>
                                <div class="mb-6">
                                    <h3 class="text-lg font-semibold text-gray-700 mb-2">รายละเอียดเต็ม</h3>
                                    <div class="content-html text-gray-700 bg-gray-50 p-4 rounded-lg">
                                        <%- activity.fulltext %>
                                    </div>
                                </div>
                            <% } %>
                        </div>
                    </div>

                    <!-- Sidebar Info -->
                    <div class="col-span-1">
                        <!-- Meta Information -->
                        <div class="bg-white rounded-lg shadow-md p-6 mb-6">
                            <h3 class="text-lg font-bold text-gray-800 mb-4">📋 ข้อมูล</h3>
                            
                            <div class="space-y-4 text-sm">
                                <div>
                                    <div class="font-semibold text-gray-700">ผู้เขียน</div>
                                    <div class="text-gray-600"><%= activity.author_name || 'ไม่ระบุ' %></div>
                                </div>

                                <div>
                                    <div class="font-semibold text-gray-700">วันที่เผยแพร่</div>
                                    <div class="text-gray-600">
                                        <% 
                                            const publishDate = new Date(activity.publish_up);
                                            const formatted = publishDate.toLocaleDateString('th-TH', { 
                                                year: 'numeric', 
                                                month: 'long', 
                                                day: 'numeric',
                                                hour: '2-digit',
                                                minute: '2-digit'
                                            });
                                        %>
                                        <%= formatted %>
                                    </div>
                                </div>

                                <div>
                                    <div class="font-semibold text-gray-700">วันที่สร้าง</div>
                                    <div class="text-gray-600">
                                        <% 
                                            const createdDate = new Date(activity.created);
                                            const formattedCreated = createdDate.toLocaleDateString('th-TH', { 
                                                year: 'numeric', 
                                                month: 'long', 
                                                day: 'numeric'
                                            });
                                        %>
                                        <%= formattedCreated %>
                                    </div>
                                </div>

                                <% if (activity.publish_down && activity.publish_down !== '0000-00-00 00:00:00') { %>
                                    <div>
                                        <div class="font-semibold text-gray-700">วันที่สิ้นสุด</div>
                                        <div class="text-gray-600">
                                            <% 
                                                const endDate = new Date(activity.publish_down);
                                                const formattedEnd = endDate.toLocaleDateString('th-TH', { 
                                                    year: 'numeric', 
                                                    month: 'long', 
                                                    day: 'numeric'
                                                });
                                            %>
                                            <%= formattedEnd %>
                                        </div>
                                    </div>
                                <% } %>

                                <div>
                                    <div class="font-semibold text-gray-700">ระดับการเข้าถึง</div>
                                    <div class="text-gray-600">
                                        <% 
                                            const accessLevelMap = { 
                                                1: 'Public',
                                                2: 'Registered', 
                                                3: 'Special',
                                                4: 'Super Users',
                                                5: 'Custom'
                                            };
                                        %>
                                        <%= accessLevelMap[activity.access] || activity.access %>
                                    </div>
                                </div>

                                <div>
                                    <div class="font-semibold text-gray-700">Alias</div>
                                    <div class="text-gray-600 text-xs break-words"><%= activity.alias %></div>
                                </div>
                            </div>
                        </div>

                        <!-- Source Info -->
                        <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
                            <div class="text-sm text-blue-800">
                                <strong>📌 แหล่งที่มา:</strong><br>
                                ข้อมูลจากระบบ Joomla เก่า<br>
                                Category: ข่าวกิจกรรม | Activity
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</body>
</html>
