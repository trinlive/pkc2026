<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Sarabun', sans-serif; }
    </style>
</head>
<body class="bg-gray-100">
    <div class="flex min-h-screen">
        <!-- Sidebar -->
        <%- include('admin-panel', { currentPage }) %>

        <!-- Main Content -->
        <main class="flex-1 p-8">
            <div class="max-w-6xl mx-auto">
                <div class="bg-white rounded-lg shadow-md p-6 mb-6">
                    <h2 class="text-3xl font-bold text-gray-800">จัดการ Models</h2>
                    <p class="text-gray-600 mt-2">แก้ไขไฟล์ Models สำหรับจัดการฐานข้อมูล</p>
                </div>

                <div class="bg-white rounded-lg shadow-md p-6">
                    <h3 class="text-xl font-bold text-gray-800 mb-4">รายการไฟล์ Models</h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <% models.forEach(file => { %>
                        <a href="/admin/models/<%= file %>" class="block p-6 border-2 border-gray-200 rounded-lg hover:border-green-500 hover:shadow-lg transition">
                            <div class="flex items-center justify-between">
                                <div>
                                    <div class="text-3xl mb-2">📦</div>
                                    <div class="font-semibold text-gray-800 text-lg"><%= file %></div>
                                    <div class="text-xs text-gray-500 mt-1">JavaScript Model</div>
                                </div>
                                <div class="text-green-600">
                                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                                    </svg>
                                </div>
                            </div>
                        </a>
                        <% }) %>
                    </div>
                </div>

                <div class="mt-6">
                    <a href="/admin/dashboard" class="inline-block bg-gray-600 text-white px-6 py-3 rounded-lg hover:bg-gray-700">
                        ← กลับหน้า Dashboard
                    </a>
                </div>
            </div>
        </main>
    </div>
</body>
</html>