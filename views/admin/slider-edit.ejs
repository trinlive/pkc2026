<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Sarabun', sans-serif; }
        .file-input-label {
            display: inline-block;
            cursor: pointer;
            padding: 0.75rem 1.5rem;
            background-color: #f3f4f6;
            border: 2px dashed #d1d5db;
            border-radius: 0.5rem;
            text-align: center;
            transition: all 0.3s ease;
            width: 100%;
        }
        .file-input-label:hover {
            border-color: #3b82f6;
            background-color: #dbeafe;
        }
        .file-input {
            display: none;
        }
        .image-preview {
            position: relative;
            width: 100%;
            max-width: 600px;
        }
        .image-preview img {
            width: 100%;
            height: auto;
            border-radius: 0.5rem;
            border: 2px solid #e5e7eb;
        }
        .remove-image {
            position: absolute;
            top: 10px;
            right: 10px;
            background-color: #ef4444;
            color: white;
            border: none;
            border-radius: 50%;
            width: 36px;
            height: 36px;
            cursor: pointer;
            font-size: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .remove-image:hover {
            background-color: #dc2626;
        }
    </style>
</head>
<body class="bg-gray-100">
    <div class="flex min-h-screen">
        <!-- Sidebar -->
        <%- include('admin-panel', { currentPage }) %>

        <!-- Main Content -->
        <main class="flex-1 p-8">
            <div class="max-w-4xl mx-auto">
                <div class="bg-white rounded-lg shadow-md p-6 mb-6">
                    <h2 class="text-3xl font-bold text-gray-800">แก้ไข Slider</h2>
                    <p class="text-gray-600 mt-2">แก้ไขข้อมูล Slider #<%= slider.id %></p>
                </div>

                <form action="/admin/sliders/edit/<%= slider.id %>" method="POST" enctype="multipart/form-data" class="bg-white rounded-lg shadow-md p-6">
                    <div class="space-y-6">
                        <% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
                        <div class="bg-red-50 border-l-4 border-red-500 p-4 rounded">
                            <p class="text-red-700 font-semibold"><%= errorMessage %></p>
                        </div>
                        <% } %>

                        <!-- ภาพตัวอย่างปัจจุบัน -->
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">🖼️ รูปภาพ Slider</label>
                            
                            <% if (slider.image_url) { %>
                                <div class="mb-4">
                                    <p class="text-sm text-gray-600 mb-2">รูปภาพปัจจุบัน:</p>
                                    <div class="image-preview">
                                        <img src="<%= slider.image_url %>" alt="<%= slider.title %>">
                                        <button type="button" class="remove-image" onclick="removeCurrentImage()">×</button>
                                    </div>
                                </div>
                            <% } %>

                            <label class="file-input-label">
                                <input type="file" name="image_file" class="file-input" id="imageInput" accept=".jpg,.jpeg,.png,.webp,.gif,image/*">
                                <div class="text-sm text-gray-600">
                                    <div class="mb-1">📤 คลิกเพื่อเลือกไฟล์ หรือ ลากไฟล์มาวางที่นี่</div>
                                    <div class="text-xs text-gray-500">📐 ขนาดแนะนำ: 1920x1080 px | สูงสุด 10MB</div>
                                    <div class="text-xs text-blue-600 mt-1">✨ ระบบจะปรับขนาดให้เป็น 1920x1080 อัตโนมัติ</div>
                                </div>
                            </label>
                            <div id="imagePreview" class="mt-4"></div>
                        </div>

                        <!-- หัวข้อหลัก -->
                        <div>
                            <label class="block text-sm font-bold text-gray-700 mb-2">หัวข้อหลัก *</label>
                            <input type="text" name="title" required value="<%= slider.title %>"
                                   class="w-full p-3 border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:outline-none">
                        </div>

                        <!-- หัวข้อรอง -->
                        <div>
                            <label class="block text-sm font-bold text-gray-700 mb-2">หัวข้อรอง</label>
                            <input type="text" name="subtitle" value="<%= slider.subtitle || '' %>"
                                   class="w-full p-3 border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:outline-none">
                        </div>

                        <!-- URL รูปภาพ -->
                        <div>
                            <label class="block text-sm font-bold text-gray-700 mb-2">URL รูปภาพ</label>
                            <input type="url" name="image_url" value="<%= slider.image_url %>"
                                   class="w-full p-3 border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:outline-none">
                            <p class="text-xs text-blue-600 mt-1">💡 เคล็ดลับ: เมื่อคุณเลือกไฟล์ใหม่ ระบบจะล้างและปิดช่อง URL นี้อัตโนมัติ</p>
                        </div>

                        <!-- URL ลิงก์ -->
                        <div>
                            <label class="block text-sm font-bold text-gray-700 mb-2">URL ลิงก์</label>
                            <input type="url" name="link_url" value="<%= slider.link_url || '' %>"
                                   class="w-full p-3 border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:outline-none">
                            <p class="text-xs text-gray-500 mt-1">URL ที่จะเปิดเมื่อคลิก Slider (ถ้ามี)</p>
                        </div>

                        <!-- Badge -->
                        <div>
                            <label class="block text-sm font-bold text-gray-700 mb-2">ข้อความ Badge</label>
                            <input type="text" name="badge_text" value="<%= slider.badge_text || '' %>"
                                   class="w-full p-3 border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:outline-none">
                            <p class="text-xs text-gray-500 mt-1">แสดงเป็นป้ายด้านบนหัวข้อ</p>
                        </div>

                        <!-- ลำดับการแสดง -->
                        <div>
                            <label class="block text-sm font-bold text-gray-700 mb-2">ลำดับการแสดง *</label>
                            <input type="number" name="display_order" required value="<%= slider.display_order %>" min="0"
                                   class="w-full p-3 border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:outline-none">
                            <p class="text-xs text-gray-500 mt-1">เรียงจากน้อยไปมาก (0, 1, 2, ...)</p>
                        </div>

                        <!-- สถานะ -->
                        <div class="bg-gray-50 rounded-lg p-4">
                            <label class="block text-sm font-bold text-gray-700 mb-2">สถานะ:</label>
                            <span class="<%= slider.is_active ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-800' %> px-4 py-2 rounded-full text-sm font-bold">
                                <%= slider.is_active ? '✓ กำลังแสดงบนหน้าเว็บ' : '✕ ซ่อนอยู่' %>
                            </span>
                        </div>

                        <!-- ปุ่ม -->
                        <div class="pt-4 flex gap-4">
                            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-8 rounded-lg transition shadow-md">
                                💾 บันทึกการแก้ไข
                            </button>
                            <a href="/admin/sliders" class="bg-gray-600 hover:bg-gray-700 text-white font-bold py-3 px-8 rounded-lg transition inline-block">
                                ← ยกเลิก
                            </a>
                        </div>
                    </div>
                </form>

                <!-- ส่วนลบ -->
                <div class="bg-red-50 border-l-4 border-red-500 p-6 mt-6 rounded-lg">
                    <h3 class="font-bold text-red-800 mb-2">⚠️ ลบ Slider นี้</h3>
                    <p class="text-sm text-red-700 mb-4">การลบจะไม่สามารถกู้คืนได้</p>
                    <form action="/admin/sliders/delete/<%= slider.id %>" method="POST" onsubmit="return confirm('ยืนยันการลบ Slider นี้?')">
                        <button type="submit" class="bg-red-600 hover:bg-red-700 text-white font-bold py-2 px-6 rounded-lg transition">
                            🗑️ ลบ Slider นี้
                        </button>
                    </form>
                </div>
            </div>
        </main>
    </div>
    
    <script>
        // Image Preview
        const imageInput = document.getElementById('imageInput');
        const imagePreview = document.getElementById('imagePreview');
        const imageUrlInput = document.querySelector('input[name="image_url"]');

        imageInput.addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (file) {
                // แสดง preview
                const reader = new FileReader();
                reader.onload = function(event) {
                    imagePreview.innerHTML = `
                        <div class="image-preview">
                            <img src="${event.target.result}" alt="Preview">
                            <button type="button" class="remove-image" onclick="clearImage()">×</button>
                        </div>
                    `;
                };
                reader.readAsDataURL(file);
                
                // ล้างและ disable URL field อัตโนมัติ
                imageUrlInput.value = '';
                imageUrlInput.disabled = true;
                imageUrlInput.style.backgroundColor = '#f3f4f6';
                imageUrlInput.style.color = '#9ca3af';
            }
        });

        // Drag and Drop
        const fileInputLabel = document.querySelector('.file-input-label');
        
        fileInputLabel.addEventListener('dragover', (e) => {
            e.preventDefault();
            fileInputLabel.style.borderColor = '#3b82f6';
            fileInputLabel.style.backgroundColor = '#dbeafe';
        });

        fileInputLabel.addEventListener('dragleave', () => {
            fileInputLabel.style.borderColor = '#d1d5db';
            fileInputLabel.style.backgroundColor = '#f3f4f6';
        });

        fileInputLabel.addEventListener('drop', (e) => {
            e.preventDefault();
            fileInputLabel.style.borderColor = '#d1d5db';
            fileInputLabel.style.backgroundColor = '#f3f4f6';
            
            const files = e.dataTransfer.files;
            if (files.length > 0) {
                imageInput.files = files;
                const event = new Event('change', { bubbles: true });
                imageInput.dispatchEvent(event);
            }
        });

        function clearImage() {
            imageInput.value = '';
            imagePreview.innerHTML = '';
            // เปิด URL field กลับมาใช้งานได้
            imageUrlInput.disabled = false;
            imageUrlInput.style.backgroundColor = '';
            imageUrlInput.style.color = '';
        }

        function removeCurrentImage() {
            // This just provides visual feedback; the actual image stays in database
            if (confirm('ต้องการซ่อนรูปภาพปัจจุบัน? (ถ้าไม่อัปโหลดรูปใหม่ รูปเดิมจะยังคงอยู่)')) {
                document.querySelector('.image-preview').style.opacity = '0.3';
            }
        }
    </script>
</body>
</html>
