<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Sarabun', sans-serif; }
        .pulse {
            animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
        }
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: .5; }
        }
    </style>
</head>
<body class="bg-gray-100">
    <div class="flex min-h-screen">
        <!-- Sidebar -->
        <%- include('partials/sidebar', { currentPage: 'migration' }) %>

        <!-- Main Content -->
        <main class="flex-1 p-8">
            <div class="max-w-7xl mx-auto">
                <!-- Header -->
                <div class="bg-gradient-to-r from-blue-600 to-purple-600 rounded-lg shadow-md p-6 mb- text-white">
                    <h2 class="text-3xl font-bold">🔄 Data Migration Center</h2>
                    <p class="mt-2">ย้ายข้อมูลจาก Joomla Database มาที่ระบบใหม่</p>
                </div>

                <!-- Database Status -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                    <!-- Joomla DB Stats -->
                    <div class="bg-white rounded-lg shadow-md p-6">
                        <h3 class="text-xl font-bold text-gray-800 mb-4">
                            📊 Joomla Database (เก่า)
                        </h3>
                        <div class="space-y-3">
                            <div class="flex justify-between items-center p-3 bg-blue-50 rounded">
                                <span class="text-gray-700">Connection:</span>
                                <span class="font-bold text-green-600">
                                    <%= joomlaStats.status === 'connected' ? '✓ Connected' : '✗ Disconnected' %>
                                </span>
                            </div>
                            <div class="flex justify-between items-center p-3 bg-gray-50 rounded">
                                <span class="text-gray-700">Database:</span>
                                <span class="font-bold text-gray-800"><%= joomlaStats.database %></span>
                            </div>
                            <div class="flex justify-between items-center p-3 bg-yellow-50 rounded">
                                <span class="text-gray-700">บทความ:</span>
                                <span class="font-bold text-yellow-700"><%= joomlaStats.articles.toLocaleString() %> รายการ</span>
                            </div>
                            <div class="flex justify-between items-center p-3 bg-purple-50 rounded">
                                <span class="text-gray-700">หมวดหมู่:</span>
                                <span class="font-bold text-purple-700"><%= joomlaStats.categories %> หมวด</span>
                            </div>
                            <div class="flex justify-between items-center p-3 bg-green-50 rounded">
                                <span class="text-gray-700">ผู้ใช้:</span>
                                <span class="font-bold text-green-700"><%= joomlaStats.users %> คน</span>
                            </div>
                        </div>
                    </div>

                    <!-- Current System Stats -->
                    <div class="bg-white rounded-lg shadow-md p-6">
                        <h3 class="text-xl font-bold text-gray-800 mb-4">
                            🎯 ระบบใหม่ (N-Pakkret)
                        </h3>
                        <div class="space-y-3">
                            <div class="flex justify-between items-center p-3 bg-blue-50 rounded">
                                <span class="text-gray-700">Database:</span>
                                <span class="font-bold text-gray-800">pkc_nodeweb_db</span>
                            </div>
                            <div class="flex justify-between items-center p-3 bg-orange-50 rounded">
                                <span class="text-gray-700">ข่าวปัจจุบัน:</span>
                                <span class="font-bold text-orange-700" id="currentNewsCount"><%= currentNewsCount %> รายการ</span>
                            </div>
                            <div class="flex justify-between items-center p-3 bg-green-50 rounded">
                                <span class="text-gray-700">สถานะระบบ:</span>
                                <span class="font-bold text-green-600">✓ Online</span>
                            </div>
                        </div>
                    </div>

                    <!-- Instructions -->
                    <div class="bg-blue-50 border-2 border-blue-200 rounded-lg shadow-md p-6">
                        <h3 class="text-lg font-bold text-blue-800 mb-4">📖 วิธีการใช้งาน Migration</h3>
                        <div class="space-y-3 text-sm text-gray-700">
                            <p><strong>1️⃣ ขั้นตอนแรก:</strong> เลือกจำนวนรายการที่ต้องการ Migrate</p>
                            <ul class="ml-4 space-y-1 text-gray-600">
                                <li>• <strong>ครั้งแรก:</strong> ลอง 50 หรือ 100 รายการก่อน</li>
                                <li>• <strong>ครั้งต่อไป:</strong> ถ้า Migrate สำเร็จแล้ว ให้เลือกจำนวนที่มากขึ้น เช่น 200, 300 ฯลฯ</li>
                                <li>• 💡 ระบบจะ <strong>ข้ามรายการที่มีอยู่แล้ว</strong> โดยอัตโนมัติ</li>
                            </ul>
                            <p class="mt-3"><strong>2️⃣ ขั้นตอนที่สอง:</strong> กด "Preview รายการ" เพื่อตรวจสอบก่อน</p>
                            <ul class="ml-4 space-y-1 text-gray-600">
                                <li>• ระบบจะแสดง <span class="text-green-600 font-bold">จะเพิ่ม</span> (รายการใหม่) และ <span class="text-orange-600 font-bold">จะข้าม</span> (มีอยู่แล้ว)</li>
                                <li>• ตรวจสอบให้ชัดเจนก่อน migrate</li>
                            </ul>
                            <p class="mt-3"><strong>3️⃣ ขั้นตอนที่สาม:</strong> กด "เริ่ม Migration" เพื่อ migrate จริง</p>
                            <ul class="ml-4 space-y-1 text-gray-600">
                                <li>• ระบบจะคัดลอกข้อมูล: <strong>ข่าว</strong>, <strong>รูปภาพ</strong>, <strong>ไฟล์แนบ (PDF/JPG)</strong></li>
                                <li>• 📎 ไฟล์แนบจะถูกใส่ในช่อง "อ่านรายละเอียด" โดยอัตโนมัติ</li>
                                <li>• ⏳ รอให้ migration สำเร็จ (ไม่ปิดเบราว์เซอร์)</li>
                            </ul>
                        </div>
                    </div>
                </div>

                <!-- Migration Tools -->
                <div class="bg-white rounded-lg shadow-md p-6">
                    <h3 class="text-xl font-bold text-gray-800 mb-4">🔧 เครื่องมือ Migration</h3>
                    
                    <!-- Universal Migration Form -->
                    <div class="border-2 border-blue-200 rounded-lg p-6 mb-4">
                        <h4 class="text-lg font-bold text-blue-800 mb-4">📰 Migrate ข่าวประชาสัมพันธ์ / 🎯 จัดการข่าวกิจกรรม</h4>
                        
                        <form id="migrationForm" class="space-y-4">
                            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-2">
                                        หมวดหมู่จาก Joomla:
                                    </label>
                                    <select name="categoryName" class="w-full p-3 border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:outline-none">
                                        <option value="">-- ทั้งหมด --</option>
                                        <option value="ข่าวประชาสัมพันธ์ | News" selected>ข่าวประชาสัมพันธ์ | News</option>
                                        <% if (categories.length > 0) { %>
                                            <% categories.forEach(cat => { %>
                                                <% if (cat.title !== 'ข่าวประชาสัมพันธ์ | News') { %>
                                                    <option value="<%= cat.title %>"><%= cat.title %></option>
                                                <% } %>
                                            <% }) %>
                                        <% } %>
                                    </select>
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-2">
                                        ปลายทาง (Menu จัดการ):
                                    </label>
                                    <select name="destinationMenu" class="w-full p-3 border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:outline-none">
                                        <option value="news">📰 จัดการข่าวสาร → ข่าวประชาสัมพันธ์</option>
                                        <option value="activities">🎯 จัดการข่าวกิจกรรม</option>
                                    </select>
                                </div>
                                <div class="grid grid-cols-2 gap-4">
                                    <div>
                                        <label class="block text-sm font-medium text-gray-700 mb-2">
                                            จำนวนที่ต้องการ Migrate:
                                        </label>
                                        <input type="number" name="limit" value="10" min="1"
                                               class="w-full p-3 border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:outline-none"
                                               placeholder="เช่น 50, 100, 200 ฯลฯ">
                                        <p class="text-xs text-gray-500 mt-1">
                                            💡 จำนวนรายการที่ดึงมาตรวจสอบ
                                        </p>
                                    </div>
                                    <div>
                                        <label class="block text-sm font-medium text-gray-700 mb-2">
                                            ข้ามจากรายการที่ (Offset):
                                        </label>
                                        <input type="number" name="offset" value="0" min="0"
                                               class="w-full p-3 border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:outline-none"
                                               placeholder="0 = เริ่มจากต้น">
                                        <p class="text-xs text-gray-500 mt-1">
                                            💡 ตั้ง 50 เพื่อเริ่มจากรายการที่ 51
                                        </p>
                                    </div>
                                </div>
                            </div>

                            <div class="flex gap-4">
                                <button type="button" id="previewBtn"
                                        class="bg-amber-600 hover:bg-amber-700 text-white font-bold py-3 px-8 rounded-lg transition shadow-md">
                                    👁️ Preview รายการ
                                </button>
                                <button type="submit" id="migrateBtn"
                                        class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-8 rounded-lg transition shadow-md">
                                    🚀 เริ่ม Migration
                                </button>
                                <button type="button" id="retryMigrateBtn"
                                        class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3 px-8 rounded-lg transition shadow-md">
                                    🔁 Re-Migrate Existing
                                </button>
                                <button type="button" id="cancelMigrateBtn"
                                        class="bg-red-600 hover:bg-red-700 text-white font-bold py-3 px-8 rounded-lg transition shadow-md opacity-50 cursor-not-allowed"
                                        disabled>
                                    ⛔ หยุดงาน
                                </button>
                                <button type="button" id="viewItemsBtn"
                                        class="bg-green-600 hover:bg-green-700 text-white font-bold py-3 px-8 rounded-lg transition shadow-md">
                                    📋 ดูรายการข่าว
                                </button>
                            </div>
                        </form>

                        <!-- Progress Display -->
                        <div id="progressContainer" class="hidden mt-6">
                            <div class="bg-blue-50 border-l-4 border-blue-500 p-4 rounded">
                                <p class="text-blue-800 font-semibold flex items-center">
                                    <svg class="animate-spin h-5 w-5 mr-3" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                                    </svg>
                                    กำลัง Migrate ข้อมูล...
                                </p>
                                <p id="progressText" class="text-sm text-gray-600 mt-2"></p>
                                <div class="mt-3 bg-white/80 rounded-full h-3 overflow-hidden border border-blue-200">
                                    <div id="progressBar" class="h-full bg-blue-600 transition-all duration-300" style="width: 0%"></div>
                                </div>
                                <div class="flex justify-between items-center mt-2 text-xs text-blue-700">
                                    <span id="progressBatchText">Batch 0/0</span>
                                    <span id="progressPercent">0%</span>
                                </div>
                            </div>
                        </div>

                        <!-- Result Display -->
                        <div id="previewContainer" class="hidden mt-6"></div>
                        <div id="resultContainer" class="hidden mt-6"></div>
                    </div>
                </div>

                <!-- Help Section -->
                <div class="bg-yellow-50 border-l-4 border-yellow-500 p-6 rounded-lg mt-6">
                    <h4 class="font-bold text-yellow-800 mb-2">💡 วิธีใช้งาน:</h4>
                    <ol class="list-decimal list-inside space-y-2 text-yellow-700">
                        <li>เลือกหมวดหมู่ที่ต้องการ migrate (แนะนำ: ข่าวประชาสัมพันธ์ | News)</li>
                        <li>ระบุจำนวนข่าวที่ต้องการ migrate (1-100 รายการ)</li>
                        <li>กดปุ่ม "เริ่ม Migration" เพื่อเริ่มต้น</li>
                        <li>รอระบบประมวลผล (ใช้เวลาประมาณ 1-2 วินาที/รายการ)</li>
                        <li>เมื่อเสร็จแล้วสามารถกด "ดูรายการข่าว" เพื่อตรวจสอบผลลัพธ์</li>
                    </ol>
                </div>
            </div>
        </main>
    </div>

    <script>
        const migrationForm = document.getElementById('migrationForm');
        const progressContainer = document.getElementById('progressContainer');
        const previewContainer = document.getElementById('previewContainer');
        const resultContainer = document.getElementById('resultContainer');
        const previewBtn = document.getElementById('previewBtn');
        const migrateBtn = document.getElementById('migrateBtn');
        const retryMigrateBtn = document.getElementById('retryMigrateBtn');
        const cancelMigrateBtn = document.getElementById('cancelMigrateBtn');
        const currentNewsCountEl = document.getElementById('currentNewsCount');
        const progressTextEl = document.getElementById('progressText');
        const progressBarEl = document.getElementById('progressBar');
        const progressBatchTextEl = document.getElementById('progressBatchText');
        const progressPercentEl = document.getElementById('progressPercent');
        let shouldRetryExisting = false;
        let cancelRequested = false;
        let isMigrationRunning = false;
        const BATCH_SIZE = 10;

        /**
         * สร้างส่วนแสดงรายละเอียดไฟล์ที่ผิดพลาด
         * @param {Object} aggregate - ข้อมูลรวมจาก migration
         * @returns {string} HTML string
         */
        const generateFileErrorsSection = (aggregate) => {
            const hasImageErrors = aggregate.imageErrorDetails && aggregate.imageErrorDetails.length > 0;
            const hasAttachmentErrors = aggregate.attachmentErrorDetails && aggregate.attachmentErrorDetails.length > 0;
            
            if (!hasImageErrors && !hasAttachmentErrors) {
                return ''; // ไม่มีข้อผิดพลาด ไม่ต้องแสดงอะไร
            }

            // รวมรายการ Article IDs ที่มีปัญหา (สำหรับปุ่ม Retry)
            const failedArticleIds = new Set();
            if (hasImageErrors) {
                aggregate.imageErrorDetails.forEach(item => failedArticleIds.add(item.articleId));
            }
            if (hasAttachmentErrors) {
                aggregate.attachmentErrorDetails.forEach(item => failedArticleIds.add(item.articleId));
            }

            // สร้างรายการรูปภาพที่ผิดพลาด
            const imageErrorRows = hasImageErrors ? aggregate.imageErrorDetails.flatMap(item => 
                item.errors.map(err => `
                    <tr class="hover:bg-blue-50">
                        <td class="py-2 px-3 border-b text-sm">${item.articleId}</td>
                        <td class="py-2 px-3 border-b text-sm">${item.articleTitle}</td>
                        <td class="py-2 px-3 border-b text-xs text-gray-600 font-mono">${err.path}</td>
                        <td class="py-2 px-3 border-b text-xs text-red-600">${err.error}</td>
                    </tr>
                `)
            ).join('') : '';

            // สร้างรายการไฟล์แนบที่ผิดพลาด
            const attachmentErrorRows = hasAttachmentErrors ? aggregate.attachmentErrorDetails.flatMap(item => 
                item.errors.map(err => `
                    <tr class="hover:bg-purple-50">
                        <td class="py-2 px-3 border-b text-sm">${item.articleId}</td>
                        <td class="py-2 px-3 border-b text-sm">${item.articleTitle}</td>
                        <td class="py-2 px-3 border-b text-xs text-gray-600 font-mono">${err.path}</td>
                        <td class="py-2 px-3 border-b text-xs text-red-600">${err.error}</td>
                    </tr>
                `)
            ).join('') : '';

            return `
                <div class="bg-red-50 border-l-4 border-red-500 p-6 rounded mt-6">
                    <h5 class="font-bold text-red-800 text-lg mb-3">⚠️ รายละเอียดไฟล์ที่ผิดพลาด</h5>
                    
                    <!-- ปุ่มควบคุม -->
                    <div class="flex gap-3 mb-4">
                        <button onclick="downloadErrorsAsCsv()" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded text-sm font-semibold flex items-center gap-2">
                            📥 ดาวน์โหลดรายการเป็น CSV
                        </button>
                        <button onclick="retryFailedArticles([${Array.from(failedArticleIds).join(',')}])" class="bg-orange-600 hover:bg-orange-700 text-white px-4 py-2 rounded text-sm font-semibold flex items-center gap-2">
                            🔄 Retry เฉพาะบทความที่มีปัญหา (${failedArticleIds.size} รายการ)
                        </button>
                    </div>

                    ${hasImageErrors ? `
                        <div class="mb-6">
                            <h6 class="font-bold text-blue-800 mb-2">🖼️ รูปภาพที่ผิดพลาด (${aggregate.imageErrors} ไฟล์)</h6>
                            <div class="bg-white rounded-lg overflow-hidden border border-blue-200 max-h-96 overflow-y-auto">
                                <table class="w-full text-left">
                                    <thead class="bg-blue-100 sticky top-0">
                                        <tr>
                                            <th class="py-2 px-3 font-semibold text-blue-900 text-sm">Article ID</th>
                                            <th class="py-2 px-3 font-semibold text-blue-900 text-sm">ชื่อบทความ</th>
                                            <th class="py-2 px-3 font-semibold text-blue-900 text-sm">Path ไฟล์</th>
                                            <th class="py-2 px-3 font-semibold text-blue-900 text-sm">สาเหตุ</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        ${imageErrorRows}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    ` : ''}

                    ${hasAttachmentErrors ? `
                        <div>
                            <h6 class="font-bold text-purple-800 mb-2">📎 ไฟล์แนบที่ผิดพลาด (${aggregate.attachmentErrors} ไฟล์)</h6>
                            <div class="bg-white rounded-lg overflow-hidden border border-purple-200 max-h-96 overflow-y-auto">
                                <table class="w-full text-left">
                                    <thead class="bg-purple-100 sticky top-0">
                                        <tr>
                                            <th class="py-2 px-3 font-semibold text-purple-900 text-sm">Article ID</th>
                                            <th class="py-2 px-3 font-semibold text-purple-900 text-sm">ชื่อบทความ</th>
                                            <th class="py-2 px-3 font-semibold text-purple-900 text-sm">Path ไฟล์</th>
                                            <th class="py-2 px-3 font-semibold text-purple-900 text-sm">สาเหตุ</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        ${attachmentErrorRows}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    ` : ''}

                    <div class="mt-4 p-3 bg-yellow-50 border border-yellow-200 rounded">
                        <p class="text-sm text-yellow-800">
                            <strong>💡 แนะนำ:</strong> ตรวจสอบว่าไฟล์เหล่านี้มีอยู่ในเซิร์ฟเวอร์ Joomla เดิมหรือไม่ หากไม่มีอาจต้องหาไฟล์สำรองหรือติดต่อผู้ดูแลระบบเดิม
                        </p>
                    </div>

                    <div id="csvDownloadData" data-image-errors='${JSON.stringify(aggregate.imageErrorDetails || [])}' data-attachment-errors='${JSON.stringify(aggregate.attachmentErrorDetails || [])}' class="hidden"></div>
                </div>
            `;
        };

        /**
         * ดาวน์โหลดรายการไฟล์ที่ผิดพลาดเป็น CSV
         */
        const downloadErrorsAsCsv = () => {
            const dataEl = document.getElementById('csvDownloadData');
            if (!dataEl) return;

            const imageErrors = JSON.parse(dataEl.getAttribute('data-image-errors') || '[]');
            const attachmentErrors = JSON.parse(dataEl.getAttribute('data-attachment-errors') || '[]');

            // สร้าง CSV content
            const csvRows = [];
            csvRows.push('Type,Article ID,Article Title,File Path,Error,Details');

            // เพิ่มข้อมูลรูปภาพ
            imageErrors.forEach(item => {
                item.errors.forEach(err => {
                    csvRows.push(`"Image","${item.articleId}","${item.articleTitle.replace(/"/g, '""')}","${err.path}","${err.error}","${err.details || ''}"`);
                });
            });

            // เพิ่มข้อมูลไฟล์แนบ
            attachmentErrors.forEach(item => {
                item.errors.forEach(err => {
                    csvRows.push(`"Attachment","${item.articleId}","${item.articleTitle.replace(/"/g, '""')}","${err.path}","${err.error}","${err.details || ''}"`);
                });
            });

            // สร้าง Blob และดาวน์โหลด
            const csvContent = csvRows.join('\\n');
            const blob = new Blob(['\uFEFF' + csvContent], { type: 'text/csv;charset=utf-8;' });
            const link = document.createElement('a');
            const url = URL.createObjectURL(blob);
            const timestamp = new Date().toISOString().replace(/[:.]/g, '-').substring(0, 19);
            
            link.setAttribute('href', url);
            link.setAttribute('download', `migration_errors_${timestamp}.csv`);
            link.style.visibility = 'hidden';
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        };

        /**
         * Retry เฉพาะบทความที่มีไฟล์ผิดพลาด
         * @param {Array<number>} articleIds - รายการ Article IDs
         */
        const retryFailedArticles = async (articleIds) => {
            if (!articleIds || articleIds.length === 0) {
                alert('ไม่มี Article IDs ที่ต้อง retry');
                return;
            }

            if (!confirm(`ต้องการ Retry ${articleIds.length} รายการที่มีไฟล์ผิดพลาดหรือไม่?`)) {
                return;
            }

            const categoryName = document.getElementById('categoryName').value;
            const destinationMenu = document.getElementById('destinationMenu').value;

            progressContainer.classList.remove('hidden');
            previewContainer.classList.add('hidden');
            resultContainer.classList.add('hidden');
            setButtonsDisabled(true);
            updateProgressUi(0, articleIds.length, 1, 1, 'กำลัง Retry บทความที่มีไฟล์ผิดพลาด...');

            try {
                const response = await fetch('/admin/migration/news', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        categoryName,
                        destinationMenu,
                        retryExisting: true,
                        articleIds: articleIds,
                        limit: articleIds.length,
                        offset: 0
                    })
                });

                const result = await response.json();
                progressContainer.classList.add('hidden');
                resultContainer.classList.remove('hidden');

                if (!result.success) {
                    resultContainer.innerHTML = `
                        <div class="bg-red-50 border-l-4 border-red-500 p-6 rounded">
                            <h5 class="font-bold text-red-800 text-lg mb-2">❌ Retry ล้มเหลว</h5>
                            <p class="text-red-700">${result.message || 'ไม่สามารถ retry ได้'}</p>
                        </div>
                    `;
                    return;
                }

                const stats = result.statistics || {};
                const hasNewImageErrors = result.imageDetails && result.imageDetails.imageErrors && result.imageDetails.imageErrors.length > 0;
                const hasNewAttachmentErrors = result.attachmentDetails && result.attachmentDetails.attachmentErrors && result.attachmentDetails.attachmentErrors.length > 0;

                resultContainer.innerHTML = `
                    <div class="bg-green-50 border-l-4 border-green-500 p-6 rounded">
                        <h5 class="font-bold text-green-800 text-lg mb-3">✅ Retry สำเร็จ!</h5>
                        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-4">
                            <div class="bg-white p-4 rounded shadow">
                                <p class="text-sm text-gray-600">ประมวลผล:</p>
                                <p class="text-2xl font-bold text-blue-600">${stats.totalProcessed || 0}</p>
                            </div>
                            <div class="bg-white p-4 rounded shadow">
                                <p class="text-sm text-gray-600">อัปเดต:</p>
                                <p class="text-2xl font-bold text-indigo-600">${stats.updatedCount || 0}</p>
                            </div>
                            <div class="bg-white p-4 rounded shadow">
                                <p class="text-sm text-gray-600">รูปภาพ:</p>
                                <p class="text-lg font-bold ${stats.imageErrors > 0 ? 'text-red-600' : 'text-green-600'}">
                                    ${stats.imagesCopied || 0} ✓ / ${stats.imageErrors || 0} ✗
                                </p>
                            </div>
                            <div class="bg-white p-4 rounded shadow">
                                <p class="text-sm text-gray-600">ไฟล์แนบ:</p>
                                <p class="text-lg font-bold ${stats.attachmentErrors > 0 ? 'text-red-600' : 'text-green-600'}">
                                    ${stats.attachmentsCopied || 0} ✓ / ${stats.attachmentErrors || 0} ✗
                                </p>
                            </div>
                        </div>
                        <p class="text-sm text-green-700">
                            ${stats.imageErrors > 0 || stats.attachmentErrors > 0 ? 
                                'ยังคงมีไฟล์ที่คัดลอกไม่สำเร็จ อาจเป็นเพราะไฟล์ไม่มีอยู่จริงในระบบ Joomla เดิม' : 
                                'คัดลอกไฟล์ทั้งหมดสำเร็จ!'}
                        </p>
                    </div>

                    ${hasNewImageErrors || hasNewAttachmentErrors ? generateFileErrorsSection({
                        imageErrors: stats.imageErrors || 0,
                        imageErrorDetails: result.imageDetails.imageErrors || [],
                        attachmentErrors: stats.attachmentErrors || 0,
                        attachmentErrorDetails: result.attachmentDetails.attachmentErrors || []
                    }) : ''}
                `;

            } catch (error) {
                progressContainer.classList.add('hidden');
                resultContainer.classList.remove('hidden');
                resultContainer.innerHTML = `
                    <div class="bg-red-50 border-l-4 border-red-500 p-6 rounded">
                        <h5 class="font-bold text-red-800 text-lg mb-2">❌ เกิดข้อผิดพลาด</h5>
                        <p class="text-red-700">ไม่สามารถเชื่อมต่อกับเซิร์ฟเวอร์ได้</p>
                        <p class="text-sm text-red-600 mt-2">${error.message}</p>
                    </div>
                `;
            } finally {
                setButtonsDisabled(false);
            }
        };

        const setButtonsDisabled = (disabled) => {
            previewBtn.disabled = disabled;
            migrateBtn.disabled = disabled;
            retryMigrateBtn.disabled = disabled;

            const method = disabled ? 'add' : 'remove';
            previewBtn.classList[method]('opacity-50', 'cursor-not-allowed');
            migrateBtn.classList[method]('opacity-50', 'cursor-not-allowed');
            retryMigrateBtn.classList[method]('opacity-50', 'cursor-not-allowed');
        };

        const updateProgressUi = (processedItems, totalItems, batchIndex, totalBatches, message = '') => {
            const safeTotal = Math.max(totalItems, 1);
            const percent = Math.min(100, Math.round((processedItems / safeTotal) * 100));
            progressBarEl.style.width = `${percent}%`;
            progressPercentEl.textContent = `${percent}%`;
            progressBatchTextEl.textContent = `Batch ${batchIndex}/${totalBatches}`;
            progressTextEl.textContent = message || `กำลังประมวลผล ${processedItems}/${totalItems} รายการ`;
        };

        const setCancelButtonState = (enabled) => {
            cancelMigrateBtn.disabled = !enabled;
            if (enabled) {
                cancelMigrateBtn.classList.remove('opacity-50', 'cursor-not-allowed');
            } else {
                cancelMigrateBtn.classList.add('opacity-50', 'cursor-not-allowed');
            }
        };

        // View items button - dynamic URL based on destination
        const viewItemsBtn = document.getElementById('viewItemsBtn');
        const destinationMenuSelect = document.querySelector('select[name="destinationMenu"]');
        
        const updateViewItemsBtn = () => {
            const destination = destinationMenuSelect.value;
            const urls = {
                'news': '/admin/news',
                'activities': '/admin/activities'
            };
            const url = urls[destination] || '/admin/news';
            viewItemsBtn.onclick = () => location.href = url;
            
            const labels = {
                'news': '📋 ดูรายการข่าว',
                'activities': '📋 ดูรายการข่าวกิจกรรม'
            };
            const label = labels[destination] || 'ดูรายการข่าว';
            viewItemsBtn.textContent = label;
        };
        
        updateViewItemsBtn();
        destinationMenuSelect?.addEventListener('change', updateViewItemsBtn);

        cancelMigrateBtn.addEventListener('click', () => {
            if (!isMigrationRunning) return;
            cancelRequested = true;
            progressTextEl.textContent = '⏹️ กำลังหยุดงาน... ระบบจะหยุดหลังจบ Batch ปัจจุบัน';
            cancelMigrateBtn.disabled = true;
            cancelMigrateBtn.classList.add('opacity-50', 'cursor-not-allowed');
        });

        retryMigrateBtn.addEventListener('click', () => {
            shouldRetryExisting = true;
            migrationForm.requestSubmit();
        });

        previewBtn.addEventListener('click', async () => {
            const formData = new FormData(migrationForm);
            const data = {
                categoryName: formData.get('categoryName'),
                destinationMenu: formData.get('destinationMenu'),
                limit: parseInt(formData.get('limit')),
                offset: parseInt(formData.get('offset')) || 0
            };

            progressContainer.classList.remove('hidden');
            previewContainer.classList.add('hidden');
            previewContainer.innerHTML = '';
            resultContainer.classList.add('hidden');
            resultContainer.innerHTML = '';
            setButtonsDisabled(true);
            updateProgressUi(0, 1, 0, 0, 'กำลังเตรียม Preview...');

            try {
                const response = await fetch(`/admin/migration/${data.destinationMenu}/preview`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(data)
                });

                const result = await response.json();
                progressContainer.classList.add('hidden');
                previewContainer.classList.remove('hidden');

                if (!result.success) {
                    previewContainer.innerHTML = `
                        <div class="bg-red-50 border-l-4 border-red-500 p-6 rounded">
                            <h5 class="font-bold text-red-800 text-lg mb-2">❌ Preview ล้มเหลว</h5>
                            <p class="text-red-700">${result.message || 'ไม่สามารถ preview ได้'}</p>
                        </div>
                    `;
                    return;
                }

                const willAddRows = result.preview.willAdd.slice(0, 5).map(item => `
                    <li class="text-sm text-green-700">[${item.articleId}] ${item.title}</li>
                `).join('');
                const willSkipRows = result.preview.willSkip.slice(0, 5).map(item => `
                    <li class="text-sm text-yellow-700">[${item.articleId}] ${item.title}</li>
                `).join('');

                previewContainer.innerHTML = `
                    <div class="bg-amber-50 border-l-4 border-amber-500 p-6 rounded">
                        <h5 class="font-bold text-amber-800 text-lg mb-3">👁️ Preview ก่อน Migration</h5>
                        <p class="text-sm text-amber-700 mb-3">
                            Source: <span class="font-semibold">${data.categoryName || 'ทั้งหมด'}</span>
                            → Destination: <span class="font-semibold">${result.statistics.destinationCategory || '-'}</span>
                        </p>
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
                            <div class="bg-white p-4 rounded shadow">
                                <p class="text-sm text-gray-600">ตรวจสอบ:</p>
                                <p class="text-2xl font-bold text-blue-600">${result.statistics.totalChecked}</p>
                            </div>
                            <div class="bg-white p-4 rounded shadow">
                                <p class="text-sm text-gray-600">จะเพิ่ม:</p>
                                <p class="text-2xl font-bold text-green-600">${result.statistics.willAddCount}</p>
                            </div>
                            <div class="bg-white p-4 rounded shadow">
                                <p class="text-sm text-gray-600">จะข้าม (ซ้ำ):</p>
                                <p class="text-2xl font-bold text-yellow-600">${result.statistics.willSkipCount}</p>
                            </div>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div class="bg-white p-4 rounded shadow">
                                <p class="font-semibold text-green-800 mb-2">ตัวอย่างรายการที่จะเพิ่ม (สูงสุด 5):</p>
                                <ul class="space-y-1">${willAddRows || '<li class="text-sm text-gray-500">ไม่มีรายการ</li>'}</ul>
                            </div>
                            <div class="bg-white p-4 rounded shadow">
                                <p class="font-semibold text-yellow-800 mb-2">ตัวอย่างรายการที่จะข้าม (สูงสุด 5):</p>
                                <ul class="space-y-1">${willSkipRows || '<li class="text-sm text-gray-500">ไม่มีรายการ</li>'}</ul>
                            </div>
                        </div>
                    </div>
                `;
            } catch (error) {
                progressContainer.classList.add('hidden');
                previewContainer.classList.remove('hidden');
                previewContainer.innerHTML = `
                    <div class="bg-red-50 border-l-4 border-red-500 p-6 rounded">
                        <h5 class="font-bold text-red-800 text-lg mb-2">❌ เกิดข้อผิดพลาด</h5>
                        <p class="text-red-700">ไม่สามารถเชื่อมต่อกับเซิร์ฟเวอร์ได้</p>
                        <p class="text-sm text-red-600 mt-2">${error.message}</p>
                    </div>
                `;
            } finally {
                setButtonsDisabled(false);
            }
        });

        migrationForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const formData = new FormData(migrationForm);
            const totalLimit = parseInt(formData.get('limit')) || 0;
            const startOffset = parseInt(formData.get('offset')) || 0;
            const baseData = {
                categoryName: formData.get('categoryName'),
                destinationMenu: formData.get('destinationMenu'),
                retryExisting: shouldRetryExisting
            };

            if (totalLimit <= 0) {
                resultContainer.classList.remove('hidden');
                resultContainer.innerHTML = `
                    <div class="bg-red-50 border-l-4 border-red-500 p-6 rounded">
                        <h5 class="font-bold text-red-800 text-lg mb-2">❌ ข้อมูลไม่ถูกต้อง</h5>
                        <p class="text-red-700">กรุณาระบุจำนวนที่ต้องการ Migrate มากกว่า 0</p>
                    </div>
                `;
                shouldRetryExisting = false;
                return;
            }

            const totalBatches = Math.ceil(totalLimit / BATCH_SIZE);
            let processedItems = 0;
            let completedBatches = 0;

            const aggregate = {
                totalProcessed: 0,
                successCount: 0,
                updatedCount: 0,
                skippedCount: 0,
                errorCount: 0,
                imagesCopied: 0,
                imageErrors: 0,
                attachmentsCopied: 0,
                attachmentErrors: 0,
                errors: [],
                destinationCategory: '-',
                imageErrorDetails: [],
                attachmentErrorDetails: []
            };

            // Show progress
            progressContainer.classList.remove('hidden');
            previewContainer.classList.add('hidden');
            previewContainer.innerHTML = '';
            resultContainer.classList.add('hidden');
            resultContainer.innerHTML = '';
            setButtonsDisabled(true);
            setCancelButtonState(true);
            cancelRequested = false;
            isMigrationRunning = true;
            updateProgressUi(0, totalLimit, 0, totalBatches, `เริ่มทำงานแบบ Batch ละ ${BATCH_SIZE} รายการ`);

            try {
                for (let batchIndex = 0; batchIndex < totalBatches; batchIndex++) {
                    if (cancelRequested) {
                        break;
                    }

                    const remaining = totalLimit - processedItems;
                    const currentBatchLimit = Math.min(BATCH_SIZE, remaining);
                    const currentOffset = startOffset + processedItems;

                    updateProgressUi(
                        processedItems,
                        totalLimit,
                        batchIndex + 1,
                        totalBatches,
                        `กำลังรัน Batch ${batchIndex + 1}/${totalBatches} (offset: ${currentOffset}, limit: ${currentBatchLimit})`
                    );

                    const response = await fetch(`/admin/migration/${baseData.destinationMenu}`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({
                            ...baseData,
                            limit: currentBatchLimit,
                            offset: currentOffset
                        })
                    });

                    const batchResult = await response.json();

                    if (!batchResult.success) {
                        throw new Error(batchResult.message || `Batch ${batchIndex + 1} failed`);
                    }

                    const stats = batchResult.statistics || {};
                    aggregate.totalProcessed += stats.totalProcessed || 0;
                    aggregate.successCount += stats.successCount || 0;
                    aggregate.updatedCount += stats.updatedCount || 0;
                    aggregate.skippedCount += stats.skippedCount || 0;
                    aggregate.errorCount += stats.errorCount || 0;
                    aggregate.imagesCopied += stats.imagesCopied || 0;
                    aggregate.imageErrors += stats.imageErrors || 0;
                    aggregate.attachmentsCopied += stats.attachmentsCopied || 0;
                    aggregate.attachmentErrors += stats.attachmentErrors || 0;
                    aggregate.destinationCategory = stats.destinationCategory || aggregate.destinationCategory;

                    if (Array.isArray(stats.errors) && stats.errors.length > 0) {
                        aggregate.errors.push(...stats.errors);
                    }

                    // เก็บรายละเอียดไฟล์ที่ผิดพลาด
                    if (batchResult.imageDetails && Array.isArray(batchResult.imageDetails.imageErrors)) {
                        aggregate.imageErrorDetails.push(...batchResult.imageDetails.imageErrors);
                    }
                    if (batchResult.attachmentDetails && Array.isArray(batchResult.attachmentDetails.attachmentErrors)) {
                        aggregate.attachmentErrorDetails.push(...batchResult.attachmentDetails.attachmentErrors);
                    }

                    processedItems += currentBatchLimit;
                    completedBatches = batchIndex + 1;
                    updateProgressUi(
                        processedItems,
                        totalLimit,
                        batchIndex + 1,
                        totalBatches,
                        `สำเร็จ Batch ${batchIndex + 1}/${totalBatches} (${processedItems}/${totalLimit} รายการ)`
                    );
                }

                // Hide progress
                progressContainer.classList.add('hidden');
                resultContainer.classList.remove('hidden');

                if (cancelRequested) {
                    resultContainer.innerHTML = `
                        <div class="bg-yellow-50 border-l-4 border-yellow-500 p-6 rounded">
                            <h5 class="font-bold text-yellow-800 text-lg mb-3">⏹️ หยุดงานแล้ว</h5>
                            <p class="text-yellow-700 mb-3">ระบบหยุดหลังจบ Batch ปัจจุบันเรียบร้อย</p>
                            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-4">
                                <div class="bg-white p-4 rounded shadow">
                                    <p class="text-sm text-gray-600">ทำแล้ว:</p>
                                    <p class="text-2xl font-bold text-blue-600">${processedItems}/${totalLimit}</p>
                                </div>
                                <div class="bg-white p-4 rounded shadow">
                                    <p class="text-sm text-gray-600">Batch:</p>
                                    <p class="text-2xl font-bold text-indigo-600">${completedBatches}/${totalBatches}</p>
                                </div>
                                <div class="bg-white p-4 rounded shadow">
                                    <p class="text-sm text-gray-600">เพิ่มใหม่:</p>
                                    <p class="text-2xl font-bold text-green-600">${aggregate.successCount}</p>
                                </div>
                                <div class="bg-white p-4 rounded shadow">
                                    <p class="text-sm text-gray-600">อัปเดต:</p>
                                    <p class="text-2xl font-bold text-indigo-600">${aggregate.updatedCount || 0}</p>
                                </div>
                            </div>
                            <p class="text-sm text-yellow-700">สามารถกดเริ่มใหม่ต่อจาก offset เดิมหรือ offset ถัดไปได้ทันที</p>
                        </div>
                    `;

                    const currentCountStopped = parseInt((currentNewsCountEl.textContent || '0').replace(/[^0-9]/g, ''), 10) || 0;
                    currentNewsCountEl.textContent = `${currentCountStopped + aggregate.successCount} รายการ`;
                    return;
                }

                resultContainer.innerHTML = `
                        <div class="bg-green-50 border-l-4 border-green-500 p-6 rounded">
                            <h5 class="font-bold text-green-800 text-lg mb-3">✅ Batch Migration สำเร็จ!</h5>
                            <div class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-4">
                                <div class="bg-white p-4 rounded shadow">
                                    <p class="text-sm text-gray-600">ประมวลผล:</p>
                                    <p class="text-2xl font-bold text-blue-600">${aggregate.totalProcessed}</p>
                                </div>
                                <div class="bg-white p-4 rounded shadow">
                                    <p class="text-sm text-gray-600">เพิ่มใหม่:</p>
                                    <p class="text-2xl font-bold text-green-600">${aggregate.successCount}</p>
                                </div>
                                <div class="bg-white p-4 rounded shadow">
                                    <p class="text-sm text-gray-600">อัปเดต:</p>
                                    <p class="text-2xl font-bold text-indigo-600">${aggregate.updatedCount || 0}</p>
                                </div>
                                <div class="bg-white p-4 rounded shadow">
                                    <p class="text-sm text-gray-600">ข้าม (ซ้ำ):</p>
                                    <p class="text-2xl font-bold text-yellow-600">${aggregate.skippedCount || 0}</p>
                                </div>
                                <div class="bg-white p-4 rounded shadow">
                                    <p class="text-sm text-gray-600">ผิดพลาด:</p>
                                    <p class="text-2xl font-bold text-red-600">${aggregate.errorCount}</p>
                                </div>
                            </div>
                            
                            <!-- 📊 สถิติไฟล์ที่คัดลอก -->
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                                <div class="bg-blue-50 border-2 border-blue-200 p-4 rounded-lg">
                                    <h6 class="font-bold text-blue-800 mb-2">🖼️ รูปภาพ</h6>
                                    <div class="flex justify-between items-center">
                                        <span class="text-sm text-blue-700">คัดลอกสำเร็จ:</span>
                                        <span class="text-xl font-bold text-green-600">${aggregate.imagesCopied || 0} ไฟล์</span>
                                    </div>
                                    <div class="flex justify-between items-center mt-1">
                                        <span class="text-sm text-blue-700">ผิดพลาด:</span>
                                        <span class="text-xl font-bold text-red-600">${aggregate.imageErrors || 0} ไฟล์</span>
                                    </div>
                                </div>
                                <div class="bg-purple-50 border-2 border-purple-200 p-4 rounded-lg">
                                    <h6 class="font-bold text-purple-800 mb-2">📎 ไฟล์แนบ (PDF/JPG)</h6>
                                    <div class="flex justify-between items-center">
                                        <span class="text-sm text-purple-700">คัดลอกสำเร็จ:</span>
                                        <span class="text-xl font-bold text-green-600">${aggregate.attachmentsCopied || 0} ไฟล์</span>
                                    </div>
                                    <div class="flex justify-between items-center mt-1">
                                        <span class="text-sm text-purple-700">ผิดพลาด:</span>
                                        <span class="text-xl font-bold text-red-600">${aggregate.attachmentErrors || 0} ไฟล์</span>
                                    </div>
                                </div>
                            </div>

                            <p class="text-sm text-green-700 mb-2">
                                Destination: <span class="font-semibold">${aggregate.destinationCategory || '-'}</span>
                            </p>
                            <p class="text-green-700">Batch migration completed: ${aggregate.successCount} created, ${aggregate.updatedCount} updated, ${aggregate.skippedCount} skipped, ${aggregate.errorCount} errors | Images: ${aggregate.imagesCopied} copied, ${aggregate.imageErrors} errors | Attachments: ${aggregate.attachmentsCopied} copied, ${aggregate.attachmentErrors} errors</p>
                            ${aggregate.errors.length > 0 ? `
                                <div class="mt-4">
                                    <p class="font-semibold text-red-700 mb-2">รายการที่มีข้อผิดพลาด:</p>
                                    <ul class="list-disc list-inside text-sm text-red-600 space-y-1">
                                        ${aggregate.errors.map(err => `
                                            <li>${err.title}: ${err.error}</li>
                                        `).join('')}
                                    </ul>
                                </div>
                            ` : ''}
                        </div>
                        
                        ${generateFileErrorsSection(aggregate)}
                    `;

                // Update current news count (เฉพาะรายการที่สร้างใหม่)
                const currentCount = parseInt((currentNewsCountEl.textContent || '0').replace(/[^0-9]/g, ''), 10) || 0;
                currentNewsCountEl.textContent = `${currentCount + aggregate.successCount} รายการ`;
            } catch (error) {
                progressContainer.classList.add('hidden');
                resultContainer.classList.remove('hidden');
                resultContainer.innerHTML = `
                    <div class="bg-red-50 border-l-4 border-red-500 p-6 rounded">
                        <h5 class="font-bold text-red-800 text-lg mb-2">❌ เกิดข้อผิดพลาด</h5>
                        <p class="text-red-700">ไม่สามารถเชื่อมต่อกับเซิร์ฟเวอร์ได้</p>
                        <p class="text-sm text-red-600 mt-2">${error.message}</p>
                    </div>
                `;
            } finally {
                isMigrationRunning = false;
                cancelRequested = false;
                setCancelButtonState(false);
                setButtonsDisabled(false);
                shouldRetryExisting = false;
            }
        });
    </script>
