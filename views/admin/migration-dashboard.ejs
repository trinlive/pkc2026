<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Sarabun', sans-serif; }
        .pulse {
            animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
        }
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: .5; }
        }
        .card-hover {
            transition: all 0.3s ease;
        }
        .card-hover:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 24px rgba(0, 0, 0, 0.15);
        }
        .badge {
            display: inline-block;
            padding: 0.35rem 0.75rem;
            border-radius: 9999px;
            font-size: 0.875rem;
            font-weight: 600;
        }
        .badge-success {
            background-color: #dcfce7;
            color: #166534;
        }
        .badge-warning {
            background-color: #fef3c7;
            color: #9a3412;
        }
        .badge-info {
            background-color: #dbeafe;
            color: #0c4a6e;
        }
    </style>
</head>
<body class="bg-gradient-to-br from-slate-50 to-blue-50 min-h-screen">
    <div class="flex min-h-screen">
        <!-- Sidebar -->
        <%- include('partials/sidebar', { currentPage: 'migration' }) %>

        <!-- Main Content -->
        <main class="flex-1 p-6 md:p-8">
            <div class="max-w-7xl mx-auto">
                <!-- Header with gradient background -->
                <div class="bg-gradient-to-r from-blue-600 via-indigo-600 to-purple-600 rounded-xl shadow-lg p-8 mb-8 text-white relative overflow-hidden">
                    <div class="absolute top-0 right-0 w-64 h-64 bg-white opacity-5 rounded-full -mr-32 -mt-32"></div>
                    <div class="relative z-10">
                        <div class="flex items-center gap-3 mb-2">
                            <span class="text-4xl">🔄</span>
                            <h2 class="text-3xl md:text-4xl font-bold">Data Migration Center</h2>
                        </div>
                        <p class="text-blue-100 text-lg ml-1 mt-2">ย้ายข้อมูลจาก Joomla Database มาที่ระบบใหม่อย่างสมบูรณ์และรวดเร็ว</p>
                    </div>
                </div>

                <!-- Database Status -->
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
                    <!-- Joomla DB Stats -->
                    <div class="bg-white rounded-xl shadow-lg p-7 card-hover border-l-4 border-orange-500">
                        <div class="flex items-center gap-3 mb-6">
                            <span class="text-3xl">📊</span>
                            <h3 class="text-2xl font-bold text-gray-800">Joomla Database</h3>
                            <span class="badge badge-warning ml-auto">เก่า</span>
                        </div>
                        <div class="space-y-3">
                            <div class="flex justify-between items-center p-4 bg-gradient-to-br from-blue-50 to-blue-100 rounded-lg border border-blue-200">
                                <span class="text-gray-700 font-medium">🔗 Connection:</span>
                                <span class="font-bold <%= joomlaStats.status === 'connected' ? 'text-green-600' : 'text-red-600' %>">
                                    <%= joomlaStats.status === 'connected' ? '✓ Connected' : '✗ Disconnected' %>
                                </span>
                            </div>
                            <div class="flex justify-between items-center p-4 bg-gray-50 rounded-lg border border-gray-200">
                                <span class="text-gray-700 font-medium">🗄️ Database:</span>
                                <span class="font-bold text-gray-800"><%= joomlaStats.database %></span>
                            </div>
                            <div class="flex justify-between items-center p-4 bg-gradient-to-br from-yellow-50 to-amber-100 rounded-lg border border-yellow-200">
                                <span class="text-gray-700 font-medium">📄 บทความ:</span>
                                <span class="font-bold text-yellow-700 text-lg"><%= joomlaStats.articles.toLocaleString() %> รายการ</span>
                            </div>
                            <div class="flex justify-between items-center p-4 bg-gradient-to-br from-purple-50 to-purple-100 rounded-lg border border-purple-200">
                                <span class="text-gray-700 font-medium">📁 หมวดหมู่:</span>
                                <span class="font-bold text-purple-700 text-lg"><%= joomlaStats.categories %> หมวด</span>
                            </div>
                            <div class="flex justify-between items-center p-4 bg-gradient-to-br from-green-50 to-emerald-100 rounded-lg border border-green-200">
                                <span class="text-gray-700 font-medium">👥 ผู้ใช้:</span>
                                <span class="font-bold text-green-700 text-lg"><%= joomlaStats.users %> คน</span>
                            </div>
                        </div>
                    </div>

                    <!-- Current System Stats -->
                    <div class="bg-white rounded-xl shadow-lg p-7 card-hover border-l-4 border-green-500">
                        <div class="flex items-center gap-3 mb-6">
                            <span class="text-3xl">🎯</span>
                            <h3 class="text-2xl font-bold text-gray-800">ระบบใหม่ (N-Pakkret)</h3>
                            <span class="badge badge-success ml-auto">ใหม่</span>
                        </div>
                        <div class="space-y-3">
                            <div class="flex justify-between items-center p-4 bg-gradient-to-br from-blue-50 to-blue-100 rounded-lg border border-blue-200">
                                <span class="text-gray-700 font-medium">🗄️ Database:</span>
                                <span class="font-bold text-gray-800">pkc_nodeweb_db</span>
                            </div>
                            <div class="flex justify-between items-center p-4 bg-gradient-to-br from-orange-50 to-orange-100 rounded-lg border border-orange-200">
                                <span class="text-gray-700 font-medium">📰 ข่าวปัจจุบัน:</span>
                                <span class="font-bold text-orange-700 text-lg" id="currentNewsCount"><%= currentNewsCount %> รายการ</span>
                            </div>
                            <div class="flex justify-between items-center p-4 bg-gradient-to-br from-green-50 to-emerald-100 rounded-lg border border-green-200">
                                <span class="text-gray-700 font-medium">🔋 สถานะระบบ:</span>
                                <span class="font-bold text-green-600 flex items-center gap-2">
                                    <span class="w-2 h-2 bg-green-600 rounded-full animate-pulse"></span>Online
                                </span>
                            </div>
                        </div>
                    </div>


                    <!-- Instructions -->
                    <div class="bg-gradient-to-br from-blue-50 to-indigo-50 border-2 border-blue-300 rounded-xl shadow-lg p-8 lg:col-span-2 card-hover">
                        <div class="flex items-center gap-3 mb-6">
                            <span class="text-3xl">📖</span>
                            <h3 class="text-2xl font-bold text-blue-900">วิธีการใช้งาน Migration</h3>
                        </div>
                        <div class="space-y-4">
                            <!-- Step 1 -->
                            <div class="bg-white rounded-lg p-5 border-l-4 border-blue-500 shadow-sm hover:shadow-md transition">
                                <div class="flex items-start gap-4">
                                    <div class="flex-shrink-0">
                                        <div class="flex items-center justify-center h-8 w-8 rounded-full bg-blue-600 text-white font-bold text-sm">1</div>
                                    </div>
                                    <div class="flex-grow">
                                        <h4 class="text-lg font-bold text-blue-900 mb-3">เลือกจำนวนรายการที่ต้องการ Migrate</h4>
                                        <div class="bg-blue-50 rounded-lg p-4 space-y-2">
                                            <div class="flex items-start gap-2">
                                                <span class="text-blue-600 font-bold">•</span>
                                                <span class="text-gray-700"><strong>ครั้งแรก:</strong> ลองเริ่มด้วย 50 หรือ 100 รายการก่อน เพื่อทดสอบว่าระบบทำงานถูกต้องหรือไม่</span>
                                            </div>
                                            <div class="flex items-start gap-2">
                                                <span class="text-blue-600 font-bold">•</span>
                                                <span class="text-gray-700"><strong>ครั้งต่อไป:</strong> ถ้า Migrate สำเร็จแล้ว ให้เลือกจำนวนที่มากขึ้น เช่น 200, 300, 500 ฯลฯ</span>
                                            </div>
                                            <div class="flex items-start gap-2">
                                                <span class="text-blue-600 font-bold">💡</span>
                                                <span class="text-gray-700">ระบบจะ<strong>ข้ามรายการที่มีอยู่แล้ว</strong>โดยอัตโนมัติ ไม่ต้องกังวล</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Step 2 -->
                            <div class="bg-white rounded-lg p-5 border-l-4 border-indigo-500 shadow-sm hover:shadow-md transition">
                                <div class="flex items-start gap-4">
                                    <div class="flex-shrink-0">
                                        <div class="flex items-center justify-center h-8 w-8 rounded-full bg-indigo-600 text-white font-bold text-sm">2</div>
                                    </div>
                                    <div class="flex-grow">
                                        <h4 class="text-lg font-bold text-indigo-900 mb-3">กด "Preview รายการ" เพื่อตรวจสอบก่อน Migrateจริง</h4>
                                        <div class="bg-indigo-50 rounded-lg p-4 space-y-2">
                                            <div class="flex items-start gap-2">
                                                <span class="text-indigo-600 font-bold">•</span>
                                                <span class="text-gray-700">ระบบจะแสดง <span class="inline-block badge badge-success">จะเพิ่ม</span> (รายการใหม่) และ <span class="inline-block badge badge-warning">จะข้าม</span> (มีอยู่แล้ว)</span>
                                            </div>
                                            <div class="flex items-start gap-2">
                                                <span class="text-indigo-600 font-bold">•</span>
                                                <span class="text-gray-700">ตรวจสอบรายการให้ชัดเจน ดูจำนวนว่าตรงกับความคาดหวังหรือไม่</span>
                                            </div>
                                            <div class="flex items-start gap-2">
                                                <span class="text-indigo-600 font-bold">💡</span>
                                                <span class="text-gray-700">หากจำนวนไม่ถูกต้อง สามารถปรับ Limit หรือ Offset แล้ว Preview ใหม่ได้</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Step 3 -->
                            <div class="bg-white rounded-lg p-5 border-l-4 border-purple-500 shadow-sm hover:shadow-md transition">
                                <div class="flex items-start gap-4">
                                    <div class="flex-shrink-0">
                                        <div class="flex items-center justify-center h-8 w-8 rounded-full bg-purple-600 text-white font-bold text-sm">3</div>
                                    </div>
                                    <div class="flex-grow">
                                        <h4 class="text-lg font-bold text-purple-900 mb-3">กด "เริ่ม Migration" เพื่อ Migrate ข้อมูลจริง</h4>
                                        <div class="bg-purple-50 rounded-lg p-4 space-y-2">
                                            <div class="flex items-start gap-2">
                                                <span class="text-purple-600 font-bold">•</span>
                                                <span class="text-gray-700">ระบบจะคัดลอกข้อมูล: <strong>ข่าว</strong>, <strong>รูปภาพ</strong>, <strong>ไฟล์แนบ (PDF/JPG)</strong></span>
                                            </div>
                                            <div class="flex items-start gap-2">
                                                <span class="text-purple-600 font-bold">•</span>
                                                <span class="text-gray-700">📎 ไฟล์แนบจะถูกใส่ในช่อง "อ่านรายละเอียด" โดยอัตโนมัติ</span>
                                            </div>
                                            <div class="flex items-start gap-2">
                                                <span class="text-purple-600 font-bold">⏳</span>
                                                <span class="text-gray-700">รอให้ migration สำเร็จ (ไม่ปิดเบราว์เซอร์) โดยถัวเฉลี่ยประมาณ 1-2 วินาทีต่อ 1 รายการ</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Migration Tools -->
                <div class="bg-white rounded-xl shadow-lg p-8 mb-8">
                    <div class="flex items-center gap-3 mb-7">
                        <span class="text-3xl">🔧</span>
                        <h3 class="text-2xl font-bold text-gray-800">เครื่องมือ Migration</h3>
                    </div>
                    
                    <!-- Universal Migration Form -->
                    <div class="border-2 border-blue-300 rounded-xl p-8 mb-6 bg-gradient-to-br from-blue-50 to-white">
                        <div class="flex items-center gap-3 mb-6">
                            <span class="text-2xl">📰</span>
                            <h4 class="text-xl font-bold text-blue-900">Migrate ข่าวประชาสัมพันธ์ / จัดการข่าวกิจกรรม</h4>
                        </div>
                        
                        <form id="migrationForm" class="space-y-6">
                            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
                                <div>
                                    <label class="block text-sm font-bold text-gray-700 mb-3">
                                        📁 หมวดหมู่จาก Joomla:
                                    </label>
                                    <select name="categoryName" class="w-full p-3 border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:outline-none bg-white hover:border-gray-400 transition">
                                        <option value="">-- ทั้งหมด --</option>
                                        <option value="ข่าวประชาสัมพันธ์ | News" selected>ข่าวประชาสัมพันธ์ | News</option>
                                        <% if (categories.length > 0) { %>
                                            <% categories.forEach(cat => { %>
                                                <% if (cat.title !== 'ข่าวประชาสัมพันธ์ | News') { %>
                                                    <option value="<%= cat.title %>"><%= cat.title %></option>
                                                <% } %>
                                            <% }) %>
                                        <% } %>
                                    </select>
                                </div>
                                <div>
                                    <label class="block text-sm font-bold text-gray-700 mb-3">
                                        🎯 ปลายทาง (Menu จัดการ):
                                    </label>
                                    <select name="destinationMenu" class="w-full p-3 border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:outline-none bg-white hover:border-gray-400 transition">
                                        <option value="news">📰 จัดการข่าวสาร → ข่าวประชาสัมพันธ์</option>
                                        <option value="activities">🎯 จัดการข่าวกิจกรรม</option>
                                        <option value="budgettransfer">💰 การโอนงบประมาณรายจ่ายประจำปี</option>
                                    </select>
                                </div>
                                <div>
                                    <label class="block text-sm font-bold text-gray-700 mb-3">
                                        📊 จำนวน Migrate:
                                    </label>
                                    <input type="number" name="limit" value="10" min="1"
                                           class="w-full p-3 border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:outline-none hover:border-gray-400 transition"
                                           placeholder="เช่น 50, 100, 200">
                                    <p class="text-xs text-gray-500 mt-2">
                                        💡 จำนวนรายการที่ดึงมาตรวจสอบ
                                    </p>
                                </div>
                                <div>
                                    <label class="block text-sm font-bold text-gray-700 mb-3">
                                        ⏭️ Offset (ข้าม):
                                    </label>
                                    <input type="number" name="offset" value="0" min="0"
                                           class="w-full p-3 border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:outline-none hover:border-gray-400 transition"
                                           placeholder="0 = เริ่มจากต้น">
                                    <p class="text-xs text-gray-500 mt-2">
                                        💡 ตั้ง 50 เพื่อเริ่มจากรายการที่ 51
                                    </p>
                                </div>
                            </div>

                            <!-- Action Buttons -->
                            <div class="flex flex-wrap gap-4 pt-4">
                                <button type="button" id="previewBtn"
                                        class="bg-amber-500 hover:bg-amber-600 text-white font-bold py-3 px-6 rounded-lg transition shadow-md hover:shadow-lg flex items-center gap-2 flex-1 md:flex-none justify-center">
                                    👁️ Preview รายการ
                                </button>
                                <button type="submit" id="migrateBtn"
                                        class="bg-green-600 hover:bg-green-700 text-white font-bold py-3 px-6 rounded-lg transition shadow-md hover:shadow-lg flex items-center gap-2 flex-1 md:flex-none justify-center">
                                    🚀 เริ่ม Migration
                                </button>
                                <button type="button" id="retryMigrateBtn"
                                        class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-6 rounded-lg transition shadow-md hover:shadow-lg flex items-center gap-2 flex-1 md:flex-none justify-center">
                                    🔁 Re-Migrate Existing
                                </button>
                                <button type="button" id="cancelMigrateBtn"
                                        class="bg-red-600 hover:bg-red-700 text-white font-bold py-3 px-6 rounded-lg transition shadow-md hover:shadow-lg flex items-center gap-2 flex-1 md:flex-none justify-center opacity-50 cursor-not-allowed"
                                        disabled>
                                    ⛔ หยุดงาน
                                </button>
                                <button type="button" id="viewItemsBtn"
                                        class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3 px-6 rounded-lg transition shadow-md hover:shadow-lg flex items-center gap-2 flex-1 md:flex-none justify-center">
                                    📋 ดูรายการข่าว
                                </button>
                            </div>
                        </form>

                        <!-- Progress Display -->
                        <div id="progressContainer" class="hidden mt-8 bg-gradient-to-br from-blue-50 to-indigo-50 border-2 border-blue-300 rounded-xl p-8 shadow-lg">
                            <div class="flex items-center gap-3 mb-4">
                                <svg class="animate-spin h-6 w-6 text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                                </svg>
                                <p class="text-blue-800 font-bold text-lg">กำลัง Migrate ข้อมูล...</p>
                            </div>
                            <p id="progressText" class="text-sm text-gray-700 mb-4 font-medium"></p>
                            <div class="mb-4">
                                <div class="bg-white/80 rounded-full h-4 overflow-hidden border-2 border-blue-300 shadow-inner">
                                    <div id="progressBar" class="h-full bg-gradient-to-r from-blue-500 to-indigo-500 transition-all duration-300" style="width: 0%"></div>
                                </div>
                            </div>
                            <div class="flex justify-between items-center text-sm font-semibold text-gray-700">
                                <span id="progressBatchText" class="bg-white px-3 py-1 rounded-full">Batch 0/0</span>
                                <span id="progressPercent" class="bg-white px-3 py-1 rounded-full text-blue-600">0%</span>
                            </div>
                        </div>

                        <!-- Result Display -->
                        <div id="previewContainer" class="hidden mt-8"></div>
                        <div id="resultContainer" class="hidden mt-8"></div>
                    </div>
                </div>

                <!-- Help Section -->
                <div class="bg-gradient-to-br from-amber-50 to-orange-50 border-l-4 border-amber-500 p-8 rounded-xl mt-8 shadow-md">
                    <div class="flex items-center gap-3 mb-4">
                        <span class="text-2xl">💡</span>
                        <h4 class="font-bold text-amber-900 text-lg">ตัวอย่างการใช้งาน (Quick Guide)</h4>
                    </div>
                    <ol class="list-decimal list-inside space-y-3 text-amber-900 font-medium">
                        <li class="flex items-start gap-3">
                            <span>1.</span>
                            <span>เลือกหมวดหมู่ที่ต้องการ migrate (แนะนำ: ข่าวประชาสัมพันธ์ | News)</span>
                        </li>
                        <li class="flex items-start gap-3">
                            <span>2.</span>
                            <span>ระบุจำนวนข่าวที่ต้องการ migrate เช่น 50, 100, 200 รายการ</span>
                        </li>
                        <li class="flex items-start gap-3">
                            <span>3.</span>
                            <span>กดปุ่ม "Preview รายการ" เพื่อตรวจสอบรายการก่อน (ไม่บังคับ แต่แนะนำ)</span>
                        </li>
                        <li class="flex items-start gap-3">
                            <span>4.</span>
                            <span>กดปุ่ม "เริ่ม Migration" เพื่อเริ่มต้นการ migrate จริง</span>
                        </li>
                        <li class="flex items-start gap-3">
                            <span>5.</span>
                            <span>รอระบบประมวลผล (ใช้เวลาประมาณ 1-2 วินาที/รายการ ไม่ปิดเบราว์เซอร์)</span>
                        </li>
                        <li class="flex items-start gap-3">
                            <span>6.</span>
                            <span>เมื่อเสร็จแล้วสามารถกด "ดูรายการข่าว" เพื่อตรวจสอบผลลัพธ์และทำการ Migrate ต่อได้</span>
                        </li>
                    </ol>
                </div>
            </div>
        </main>
    </div>

    <script>
        const migrationForm = document.getElementById('migrationForm');
        const progressContainer = document.getElementById('progressContainer');
        const previewContainer = document.getElementById('previewContainer');
        const resultContainer = document.getElementById('resultContainer');
        const previewBtn = document.getElementById('previewBtn');
        const migrateBtn = document.getElementById('migrateBtn');
        const retryMigrateBtn = document.getElementById('retryMigrateBtn');
        const cancelMigrateBtn = document.getElementById('cancelMigrateBtn');
        const currentNewsCountEl = document.getElementById('currentNewsCount');
        const progressTextEl = document.getElementById('progressText');
        const progressBarEl = document.getElementById('progressBar');
        const progressBatchTextEl = document.getElementById('progressBatchText');
        const progressPercentEl = document.getElementById('progressPercent');
        let shouldRetryExisting = false;
        let cancelRequested = false;
        let isMigrationRunning = false;
        const BATCH_SIZE = 10;

        /**
         * สร้างส่วนแสดงรายละเอียดไฟล์ที่ผิดพลาด
         * @param {Object} aggregate - ข้อมูลรวมจาก migration
         * @returns {string} HTML string
         */
        const generateFileErrorsSection = (aggregate) => {
            const hasImageErrors = aggregate.imageErrorDetails && aggregate.imageErrorDetails.length > 0;
            const hasAttachmentErrors = aggregate.attachmentErrorDetails && aggregate.attachmentErrorDetails.length > 0;
            
            if (!hasImageErrors && !hasAttachmentErrors) {
                return ''; // ไม่มีข้อผิดพลาด ไม่ต้องแสดงอะไร
            }

            // รวมรายการ Article IDs ที่มีปัญหา (สำหรับปุ่ม Retry)
            const failedArticleIds = new Set();
            if (hasImageErrors) {
                aggregate.imageErrorDetails.forEach(item => failedArticleIds.add(item.articleId));
            }
            if (hasAttachmentErrors) {
                aggregate.attachmentErrorDetails.forEach(item => failedArticleIds.add(item.articleId));
            }

            // สร้างรายการรูปภาพที่ผิดพลาด
            const imageErrorRows = hasImageErrors ? aggregate.imageErrorDetails.flatMap(item => 
                item.errors.map(err => `
                    <tr class="hover:bg-blue-50">
                        <td class="py-2 px-3 border-b text-sm">${item.articleId}</td>
                        <td class="py-2 px-3 border-b text-sm">${item.articleTitle}</td>
                        <td class="py-2 px-3 border-b text-xs text-gray-600 font-mono">${err.path}</td>
                        <td class="py-2 px-3 border-b text-xs text-red-600">${err.error}</td>
                    </tr>
                `)
            ).join('') : '';

            // สร้างรายการไฟล์แนบที่ผิดพลาด
            const attachmentErrorRows = hasAttachmentErrors ? aggregate.attachmentErrorDetails.flatMap(item => 
                item.errors.map(err => `
                    <tr class="hover:bg-purple-50">
                        <td class="py-2 px-3 border-b text-sm">${item.articleId}</td>
                        <td class="py-2 px-3 border-b text-sm">${item.articleTitle}</td>
                        <td class="py-2 px-3 border-b text-xs text-gray-600 font-mono">${err.path}</td>
                        <td class="py-2 px-3 border-b text-xs text-red-600">${err.error}</td>
                    </tr>
                `)
            ).join('') : '';

            return `
                <div class="bg-red-50 border-l-4 border-red-500 p-6 rounded mt-6">
                    <h5 class="font-bold text-red-800 text-lg mb-3">⚠️ รายละเอียดไฟล์ที่ผิดพลาด</h5>
                    
                    <!-- ปุ่มควบคุม -->
                    <div class="flex gap-3 mb-4">
                        <button onclick="downloadErrorsAsCsv()" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded text-sm font-semibold flex items-center gap-2">
                            📥 ดาวน์โหลดรายการเป็น CSV
                        </button>
                        <button onclick="retryFailedArticles([${Array.from(failedArticleIds).join(',')}])" class="bg-orange-600 hover:bg-orange-700 text-white px-4 py-2 rounded text-sm font-semibold flex items-center gap-2">
                            🔄 Retry เฉพาะบทความที่มีปัญหา (${failedArticleIds.size} รายการ)
                        </button>
                    </div>

                    ${hasImageErrors ? `
                        <div class="mb-6">
                            <h6 class="font-bold text-blue-800 mb-2">🖼️ รูปภาพที่ผิดพลาด (${aggregate.imageErrors} ไฟล์)</h6>
                            <div class="bg-white rounded-lg overflow-hidden border border-blue-200 max-h-96 overflow-y-auto">
                                <table class="w-full text-left">
                                    <thead class="bg-blue-100 sticky top-0">
                                        <tr>
                                            <th class="py-2 px-3 font-semibold text-blue-900 text-sm">Article ID</th>
                                            <th class="py-2 px-3 font-semibold text-blue-900 text-sm">ชื่อบทความ</th>
                                            <th class="py-2 px-3 font-semibold text-blue-900 text-sm">Path ไฟล์</th>
                                            <th class="py-2 px-3 font-semibold text-blue-900 text-sm">สาเหตุ</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        ${imageErrorRows}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    ` : ''}

                    ${hasAttachmentErrors ? `
                        <div>
                            <h6 class="font-bold text-purple-800 mb-2">📎 ไฟล์แนบที่ผิดพลาด (${aggregate.attachmentErrors} ไฟล์)</h6>
                            <div class="bg-white rounded-lg overflow-hidden border border-purple-200 max-h-96 overflow-y-auto">
                                <table class="w-full text-left">
                                    <thead class="bg-purple-100 sticky top-0">
                                        <tr>
                                            <th class="py-2 px-3 font-semibold text-purple-900 text-sm">Article ID</th>
                                            <th class="py-2 px-3 font-semibold text-purple-900 text-sm">ชื่อบทความ</th>
                                            <th class="py-2 px-3 font-semibold text-purple-900 text-sm">Path ไฟล์</th>
                                            <th class="py-2 px-3 font-semibold text-purple-900 text-sm">สาเหตุ</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        ${attachmentErrorRows}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    ` : ''}

                    <div class="mt-4 p-3 bg-yellow-50 border border-yellow-200 rounded">
                        <p class="text-sm text-yellow-800">
                            <strong>💡 แนะนำ:</strong> ตรวจสอบว่าไฟล์เหล่านี้มีอยู่ในเซิร์ฟเวอร์ Joomla เดิมหรือไม่ หากไม่มีอาจต้องหาไฟล์สำรองหรือติดต่อผู้ดูแลระบบเดิม
                        </p>
                    </div>

                    <div id="csvDownloadData" data-image-errors='${JSON.stringify(aggregate.imageErrorDetails || [])}' data-attachment-errors='${JSON.stringify(aggregate.attachmentErrorDetails || [])}' class="hidden"></div>
                </div>
            `;
        };

        /**
         * ดาวน์โหลดรายการไฟล์ที่ผิดพลาดเป็น CSV
         */
        const downloadErrorsAsCsv = () => {
            const dataEl = document.getElementById('csvDownloadData');
            if (!dataEl) return;

            const imageErrors = JSON.parse(dataEl.getAttribute('data-image-errors') || '[]');
            const attachmentErrors = JSON.parse(dataEl.getAttribute('data-attachment-errors') || '[]');

            // สร้าง CSV content
            const csvRows = [];
            csvRows.push('Type,Article ID,Article Title,File Path,Error,Details');

            // เพิ่มข้อมูลรูปภาพ
            imageErrors.forEach(item => {
                item.errors.forEach(err => {
                    csvRows.push(`"Image","${item.articleId}","${item.articleTitle.replace(/"/g, '""')}","${err.path}","${err.error}","${err.details || ''}"`);
                });
            });

            // เพิ่มข้อมูลไฟล์แนบ
            attachmentErrors.forEach(item => {
                item.errors.forEach(err => {
                    csvRows.push(`"Attachment","${item.articleId}","${item.articleTitle.replace(/"/g, '""')}","${err.path}","${err.error}","${err.details || ''}"`);
                });
            });

            // สร้าง Blob และดาวน์โหลด
            const csvContent = csvRows.join('\\n');
            const blob = new Blob(['\uFEFF' + csvContent], { type: 'text/csv;charset=utf-8;' });
            const link = document.createElement('a');
            const url = URL.createObjectURL(blob);
            const timestamp = new Date().toISOString().replace(/[:.]/g, '-').substring(0, 19);
            
            link.setAttribute('href', url);
            link.setAttribute('download', `migration_errors_${timestamp}.csv`);
            link.style.visibility = 'hidden';
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        };

        /**
         * Retry เฉพาะบทความที่มีไฟล์ผิดพลาด
         * @param {Array<number>} articleIds - รายการ Article IDs
         */
        const retryFailedArticles = async (articleIds) => {
            if (!articleIds || articleIds.length === 0) {
                alert('ไม่มี Article IDs ที่ต้อง retry');
                return;
            }

            if (!confirm(`ต้องการ Retry ${articleIds.length} รายการที่มีไฟล์ผิดพลาดหรือไม่?`)) {
                return;
            }

            const categoryName = document.getElementById('categoryName').value;
            const destinationMenu = document.getElementById('destinationMenu').value;

            progressContainer.classList.remove('hidden');
            previewContainer.classList.add('hidden');
            resultContainer.classList.add('hidden');
            setButtonsDisabled(true);
            updateProgressUi(0, articleIds.length, 1, 1, 'กำลัง Retry บทความที่มีไฟล์ผิดพลาด...');

            try {
                const response = await fetch('/admin/migration/news', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        categoryName,
                        destinationMenu,
                        retryExisting: true,
                        articleIds: articleIds,
                        limit: articleIds.length,
                        offset: 0
                    })
                });

                const result = await response.json();
                progressContainer.classList.add('hidden');
                resultContainer.classList.remove('hidden');

                if (!result.success) {
                    resultContainer.innerHTML = `
                        <div class="bg-gradient-to-br from-red-50 to-orange-50 border-2 border-red-400 rounded-xl p-8 shadow-lg">
                            <div class="flex items-center gap-3 mb-4">
                                <span class="text-3xl">❌</span>
                                <h5 class="font-bold text-red-900 text-xl">Retry ล้มเหลว</h5>
                            </div>
                            <p class="text-red-700 font-medium">${result.message || 'ไม่สามารถ retry ได้'}</p>
                        </div>
                    `;
                    return;
                }

                const stats = result.statistics || {};
                const hasNewImageErrors = result.imageDetails && result.imageDetails.imageErrors && result.imageDetails.imageErrors.length > 0;
                const hasNewAttachmentErrors = result.attachmentDetails && result.attachmentDetails.attachmentErrors && result.attachmentDetails.attachmentErrors.length > 0;

                resultContainer.innerHTML = `
                    <div class="bg-gradient-to-br from-green-50 to-emerald-50 border-2 border-green-400 rounded-xl p-8 shadow-lg">
                        <div class="flex items-center gap-3 mb-6">
                            <span class="text-3xl animate-bounce">✅</span>
                            <h5 class="font-bold text-green-900 text-xl">Retry สำเร็จ!</h5>
                        </div>
                        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
                            <div class="bg-white rounded-lg p-5 border-2 border-blue-200 shadow-md text-center">
                                <p class="text-xs text-gray-600 font-semibold">📊 ประมวลผล</p>
                                <p class="text-2xl font-bold text-blue-600 mt-2">${stats.totalProcessed || 0}</p>
                            </div>
                            <div class="bg-white rounded-lg p-5 border-2 border-purple-200 shadow-md text-center">
                                <p class="text-xs text-gray-600 font-semibold">🔄 อัปเดต</p>
                                <p class="text-2xl font-bold text-purple-600 mt-2">${stats.updatedCount || 0}</p>
                            </div>
                            <div class="bg-white rounded-lg p-5 border-2 border-green-200 shadow-md text-center">
                                <p class="text-xs text-gray-600 font-semibold">🖼️ รูปภาพ</p>
                                <p class="text-lg font-bold ${stats.imageErrors > 0 ? 'text-red-600' : 'text-green-600'} mt-2">
                                    ${stats.imagesCopied || 0} ✓ / ${stats.imageErrors || 0} ✗
                                </p>
                            </div>
                            <div class="bg-white rounded-lg p-5 border-2 border-purple-200 shadow-md text-center">
                                <p class="text-xs text-gray-600 font-semibold">📎 ไฟล์แนบ</p>
                                <p class="text-lg font-bold ${stats.attachmentErrors > 0 ? 'text-red-600' : 'text-green-600'} mt-2">
                                    ${stats.attachmentsCopied || 0} ✓ / ${stats.attachmentErrors || 0} ✗
                                </p>
                            </div>
                        </div>
                        <div class="bg-white rounded-lg p-6 border-l-4 border-green-500">
                            <p class="text-sm text-gray-700 font-medium">
                                ${stats.imageErrors > 0 || stats.attachmentErrors > 0 ? 
                                    '⚠️ ยังคงมีไฟล์ที่คัดลอกไม่สำเร็จ อาจเป็นเพราะไฟล์ไม่มีอยู่จริงในระบบ Joomla เดิม' : 
                                    '🎉 คัดลอกไฟล์ทั้งหมดสำเร็จแล้ว!'}
                            </p>
                        </div>
                    </div>

                    ${hasNewImageErrors || hasNewAttachmentErrors ? generateFileErrorsSection({
                        imageErrors: stats.imageErrors || 0,
                        imageErrorDetails: result.imageDetails.imageErrors || [],
                        attachmentErrors: stats.attachmentErrors || 0,
                        attachmentErrorDetails: result.attachmentDetails.attachmentErrors || []
                    }) : ''}
                `;

            } catch (error) {
                progressContainer.classList.add('hidden');
                resultContainer.classList.remove('hidden');
                resultContainer.innerHTML = `
                    <div class="bg-gradient-to-br from-red-50 to-orange-50 border-2 border-red-400 rounded-xl p-8 shadow-lg">
                        <div class="flex items-center gap-3 mb-4">
                            <span class="text-3xl">⚠️</span>
                            <h5 class="font-bold text-red-900 text-xl">เกิดข้อผิดพลาด</h5>
                        </div>
                        <p class="text-red-700 font-medium mb-2">ไม่สามารถเชื่อมต่อกับเซิร์ฟเวอร์ได้</p>
                        <p class="text-sm text-red-600 bg-white rounded p-3 mt-3 border border-red-200 font-mono">${error.message}</p>
                    </div>
                `;
            } finally {
                setButtonsDisabled(false);
            }
        };

        const setButtonsDisabled = (disabled) => {
            previewBtn.disabled = disabled;
            migrateBtn.disabled = disabled;
            retryMigrateBtn.disabled = disabled;

            const method = disabled ? 'add' : 'remove';
            previewBtn.classList[method]('opacity-50', 'cursor-not-allowed');
            migrateBtn.classList[method]('opacity-50', 'cursor-not-allowed');
            retryMigrateBtn.classList[method]('opacity-50', 'cursor-not-allowed');
        };

        const updateProgressUi = (processedItems, totalItems, batchIndex, totalBatches, message = '') => {
            const safeTotal = Math.max(totalItems, 1);
            const percent = Math.min(100, Math.round((processedItems / safeTotal) * 100));
            progressBarEl.style.width = `${percent}%`;
            progressPercentEl.textContent = `${percent}%`;
            progressBatchTextEl.textContent = `Batch ${batchIndex}/${totalBatches}`;
            progressTextEl.textContent = message || `กำลังประมวลผล ${processedItems}/${totalItems} รายการ`;
        };

        const setCancelButtonState = (enabled) => {
            cancelMigrateBtn.disabled = !enabled;
            if (enabled) {
                cancelMigrateBtn.classList.remove('opacity-50', 'cursor-not-allowed');
            } else {
                cancelMigrateBtn.classList.add('opacity-50', 'cursor-not-allowed');
            }
        };

        // View items button - dynamic URL based on destination
        const viewItemsBtn = document.getElementById('viewItemsBtn');
        const destinationMenuSelect = document.querySelector('select[name="destinationMenu"]');
        
        const updateViewItemsBtn = () => {
            const destination = destinationMenuSelect.value;
            const urls = {
                'news': '/admin/news',
                'activities': '/admin/activities'
            };
            const url = urls[destination] || '/admin/news';
            viewItemsBtn.onclick = () => location.href = url;
            
            const labels = {
                'news': '📋 ดูรายการข่าว',
                'activities': '📋 ดูรายการข่าวกิจกรรม'
            };
            const label = labels[destination] || 'ดูรายการข่าว';
            viewItemsBtn.textContent = label;
        };
        
        updateViewItemsBtn();
        destinationMenuSelect?.addEventListener('change', updateViewItemsBtn);

        cancelMigrateBtn.addEventListener('click', () => {
            if (!isMigrationRunning) return;
            cancelRequested = true;
            progressTextEl.textContent = '⏹️ กำลังหยุดงาน... ระบบจะหยุดหลังจบ Batch ปัจจุบัน';
            cancelMigrateBtn.disabled = true;
            cancelMigrateBtn.classList.add('opacity-50', 'cursor-not-allowed');
        });

        retryMigrateBtn.addEventListener('click', () => {
            shouldRetryExisting = true;
            migrationForm.requestSubmit();
        });

        previewBtn.addEventListener('click', async () => {
            const formData = new FormData(migrationForm);
            const data = {
                categoryName: formData.get('categoryName'),
                destinationMenu: formData.get('destinationMenu'),
                limit: parseInt(formData.get('limit')),
                offset: parseInt(formData.get('offset')) || 0
            };

            progressContainer.classList.remove('hidden');
            previewContainer.classList.add('hidden');
            previewContainer.innerHTML = '';
            resultContainer.classList.add('hidden');
            resultContainer.innerHTML = '';
            setButtonsDisabled(true);
            updateProgressUi(0, 1, 0, 0, 'กำลังเตรียม Preview...');

            try {
                const response = await fetch(`/admin/migration/${data.destinationMenu}/preview`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(data)
                });

                const result = await response.json();
                progressContainer.classList.add('hidden');
                previewContainer.classList.remove('hidden');

                if (!result.success) {
                    previewContainer.innerHTML = `
                        <div class="bg-gradient-to-br from-red-50 to-orange-50 border-2 border-red-400 rounded-xl p-8 shadow-lg">
                            <div class="flex items-center gap-3 mb-4">
                                <span class="text-3xl">❌</span>
                                <h5 class="font-bold text-red-900 text-xl">Preview ล้มเหลว</h5>
                            </div>
                            <p class="text-red-700 font-medium">${result.message || 'ไม่สามารถ preview ได้'}</p>
                        </div>
                    `;
                    return;
                }

                const willAddRows = result.preview.willAdd.slice(0, 5).map(item => `
                    <li class="text-sm text-green-700">[${item.articleId}] ${item.title}</li>
                `).join('');
                const willSkipRows = result.preview.willSkip.slice(0, 5).map(item => `
                    <li class="text-sm text-yellow-700">[${item.articleId}] ${item.title}</li>
                `).join('');

                previewContainer.innerHTML = `
                    <div class="bg-gradient-to-br from-amber-50 to-orange-50 border-2 border-amber-400 rounded-xl p-8 shadow-lg">
                        <div class="flex items-center gap-3 mb-6">
                            <span class="text-3xl">👁️</span>
                            <h5 class="font-bold text-amber-900 text-xl">Preview ก่อน Migration</h5>
                        </div>
                        <div class="mb-6 p-4 bg-white rounded-lg border-l-4 border-amber-500">
                            <p class="text-sm text-gray-700">
                                📁 Source: <span class="font-bold text-blue-700">${data.categoryName || 'ทั้งหมด'}</span>
                                <span class="mx-2">→</span>
                                🎯 Destination: <span class="font-bold text-green-700">${result.statistics.destinationCategory || '-'}</span>
                            </p>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
                            <div class="bg-white rounded-lg p-5 border-2 border-blue-200 shadow-md">
                                <p class="text-sm text-gray-600 font-medium">📊 ตรวจสอบทั้งหมด:</p>
                                <p class="text-3xl font-bold text-blue-600 mt-2">${result.statistics.totalChecked}</p>
                            </div>
                            <div class="bg-white rounded-lg p-5 border-2 border-green-200 shadow-md">
                                <p class="text-sm text-gray-600 font-medium">✅ จะเพิ่มใหม่:</p>
                                <p class="text-3xl font-bold text-green-600 mt-2">${result.statistics.willAddCount}</p>
                            </div>
                            <div class="bg-white rounded-lg p-5 border-2 border-yellow-200 shadow-md">
                                <p class="text-sm text-gray-600 font-medium">⏭️ จะข้าม (ซ้ำ):</p>
                                <p class="text-3xl font-bold text-yellow-600 mt-2">${result.statistics.willSkipCount}</p>
                            </div>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="bg-gradient-to-br from-green-50 to-emerald-50 p-6 rounded-lg border-2 border-green-200 shadow-md">
                                <p class="font-bold text-green-900 mb-4 flex items-center gap-2">
                                    <span class="text-xl">✅</span>
                                    <span>รายการที่จะเพิ่ม</span>
                                    <span class="ml-auto bg-green-200 px-3 py-1 rounded-full text-sm font-bold text-green-700">${result.statistics.willAddCount}</span>
                                </p>
                                <ul class="space-y-2">${willAddRows || '<li class="text-sm text-gray-500 italic">ไม่มีรายการที่จะเพิ่ม</li>'}</ul>
                            </div>
                            <div class="bg-gradient-to-br from-yellow-50 to-orange-50 p-6 rounded-lg border-2 border-yellow-200 shadow-md">
                                <p class="font-bold text-yellow-900 mb-4 flex items-center gap-2">
                                    <span class="text-xl">⏭️</span>
                                    <span>รายการที่จะข้าม (ซ้ำ)</span>
                                    <span class="ml-auto bg-yellow-200 px-3 py-1 rounded-full text-sm font-bold text-yellow-700">${result.statistics.willSkipCount}</span>
                                </p>
                                <ul class="space-y-2">${willSkipRows || '<li class="text-sm text-gray-500 italic">ไม่มีรายการที่ซ้ำ</li>'}</ul>
                            </div>
                        </div>
                    </div>
                `;
            } catch (error) {
                progressContainer.classList.add('hidden');
                previewContainer.classList.remove('hidden');
                previewContainer.innerHTML = `
                    <div class="bg-gradient-to-br from-red-50 to-orange-50 border-2 border-red-400 rounded-xl p-8 shadow-lg">
                        <div class="flex items-center gap-3 mb-4">
                            <span class="text-3xl">⚠️</span>
                            <h5 class="font-bold text-red-900 text-xl">เกิดข้อผิดพลาด</h5>
                        </div>
                        <p class="text-red-700 font-medium mb-2">ไม่สามารถเชื่อมต่อกับเซิร์ฟเวอร์ได้</p>
                        <p class="text-sm text-red-600 bg-white rounded p-3 mt-3 border border-red-200 font-mono">${error.message}</p>
                    </div>
                `;
            } finally {
                setButtonsDisabled(false);
            }
        });

        migrationForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const formData = new FormData(migrationForm);
            const totalLimit = parseInt(formData.get('limit')) || 0;
            const startOffset = parseInt(formData.get('offset')) || 0;
            const baseData = {
                categoryName: formData.get('categoryName'),
                destinationMenu: formData.get('destinationMenu'),
                retryExisting: shouldRetryExisting
            };

            if (totalLimit <= 0) {
                resultContainer.classList.remove('hidden');
                resultContainer.innerHTML = `
                    <div class="bg-gradient-to-br from-red-50 to-orange-50 border-2 border-red-400 rounded-xl p-8 shadow-lg">
                        <div class="flex items-center gap-3 mb-4">
                            <span class="text-3xl">⚠️</span>
                            <h5 class="font-bold text-red-900 text-xl">ข้อมูลไม่ถูกต้อง</h5>
                        </div>
                        <p class="text-red-700 font-medium">กรุณาระบุจำนวนที่ต้องการ Migrate มากกว่า 0</p>
                    </div>
                `;
                shouldRetryExisting = false;
                return;
            }

            const totalBatches = Math.ceil(totalLimit / BATCH_SIZE);
            let processedItems = 0;
            let completedBatches = 0;

            const aggregate = {
                totalProcessed: 0,
                successCount: 0,
                updatedCount: 0,
                skippedCount: 0,
                errorCount: 0,
                imagesCopied: 0,
                imageErrors: 0,
                attachmentsCopied: 0,
                attachmentErrors: 0,
                errors: [],
                destinationCategory: '-',
                imageErrorDetails: [],
                attachmentErrorDetails: []
            };

            // Show progress
            progressContainer.classList.remove('hidden');
            previewContainer.classList.add('hidden');
            previewContainer.innerHTML = '';
            resultContainer.classList.add('hidden');
            resultContainer.innerHTML = '';
            setButtonsDisabled(true);
            setCancelButtonState(true);
            cancelRequested = false;
            isMigrationRunning = true;
            updateProgressUi(0, totalLimit, 0, totalBatches, `เริ่มทำงานแบบ Batch ละ ${BATCH_SIZE} รายการ`);

            try {
                for (let batchIndex = 0; batchIndex < totalBatches; batchIndex++) {
                    if (cancelRequested) {
                        break;
                    }

                    const remaining = totalLimit - processedItems;
                    const currentBatchLimit = Math.min(BATCH_SIZE, remaining);
                    const currentOffset = startOffset + processedItems;

                    updateProgressUi(
                        processedItems,
                        totalLimit,
                        batchIndex + 1,
                        totalBatches,
                        `กำลังรัน Batch ${batchIndex + 1}/${totalBatches} (offset: ${currentOffset}, limit: ${currentBatchLimit})`
                    );

                    const response = await fetch(`/admin/migration/${baseData.destinationMenu}`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({
                            ...baseData,
                            limit: currentBatchLimit,
                            offset: currentOffset
                        })
                    });

                    const batchResult = await response.json();

                    if (!batchResult.success) {
                        throw new Error(batchResult.message || `Batch ${batchIndex + 1} failed`);
                    }

                    const stats = batchResult.statistics || {};
                    aggregate.totalProcessed += stats.totalProcessed || 0;
                    aggregate.successCount += stats.successCount || 0;
                    aggregate.updatedCount += stats.updatedCount || 0;
                    aggregate.skippedCount += stats.skippedCount || 0;
                    aggregate.errorCount += stats.errorCount || 0;
                    aggregate.imagesCopied += stats.imagesCopied || 0;
                    aggregate.imageErrors += stats.imageErrors || 0;
                    aggregate.attachmentsCopied += stats.attachmentsCopied || 0;
                    aggregate.attachmentErrors += stats.attachmentErrors || 0;
                    aggregate.destinationCategory = stats.destinationCategory || aggregate.destinationCategory;

                    if (Array.isArray(stats.errors) && stats.errors.length > 0) {
                        aggregate.errors.push(...stats.errors);
                    }

                    // เก็บรายละเอียดไฟล์ที่ผิดพลาด
                    if (batchResult.imageDetails && Array.isArray(batchResult.imageDetails.imageErrors)) {
                        aggregate.imageErrorDetails.push(...batchResult.imageDetails.imageErrors);
                    }
                    if (batchResult.attachmentDetails && Array.isArray(batchResult.attachmentDetails.attachmentErrors)) {
                        aggregate.attachmentErrorDetails.push(...batchResult.attachmentDetails.attachmentErrors);
                    }

                    processedItems += currentBatchLimit;
                    completedBatches = batchIndex + 1;
                    updateProgressUi(
                        processedItems,
                        totalLimit,
                        batchIndex + 1,
                        totalBatches,
                        `สำเร็จ Batch ${batchIndex + 1}/${totalBatches} (${processedItems}/${totalLimit} รายการ)`
                    );
                }

                // Hide progress
                progressContainer.classList.add('hidden');
                resultContainer.classList.remove('hidden');

                if (cancelRequested) {
                    resultContainer.innerHTML = `
                        <div class="bg-gradient-to-br from-yellow-50 to-orange-50 border-2 border-yellow-400 rounded-xl p-8 shadow-lg">
                            <div class="flex items-center gap-3 mb-4">
                                <span class="text-3xl">⏹️</span>
                                <h5 class="font-bold text-yellow-900 text-xl">หยุดงานแล้ว</h5>
                            </div>
                            <p class="text-yellow-700 mb-6 font-medium">ระบบหยุดหลังจบ Batch ปัจจุบันเรียบร้อยแล้ว</p>
                            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
                                <div class="bg-white rounded-lg p-5 border-2 border-blue-200 shadow-md text-center">
                                    <p class="text-sm text-gray-600 font-medium">ประมวลแล้ว</p>
                                    <p class="text-2xl font-bold text-blue-600 mt-2">${processedItems}/${totalLimit}</p>
                                </div>
                                <div class="bg-white rounded-lg p-5 border-2 border-indigo-200 shadow-md text-center">
                                    <p class="text-sm text-gray-600 font-medium">Batch</p>
                                    <p class="text-2xl font-bold text-indigo-600 mt-2">${completedBatches}/${totalBatches}</p>
                                </div>
                                <div class="bg-white rounded-lg p-5 border-2 border-green-200 shadow-md text-center">
                                    <p class="text-sm text-gray-600 font-medium">เพิ่มใหม่</p>
                                    <p class="text-2xl font-bold text-green-600 mt-2">${aggregate.successCount}</p>
                                </div>
                                <div class="bg-white rounded-lg p-5 border-2 border-purple-200 shadow-md text-center">
                                    <p class="text-sm text-gray-600 font-medium">อัปเดต</p>
                                    <p class="text-2xl font-bold text-purple-600 mt-2">${aggregate.updatedCount || 0}</p>
                                </div>
                            </div>
                            <div class="bg-white rounded-lg p-6 border-l-4 border-yellow-500">
                                <p class="text-sm text-gray-700 font-medium">
                                    💡 คุณสามารถใช้ Offset เดิมเพื่อเดินต่อจากที่หยุด หรือเปลี่ยน Offset เพื่อ Migrate รายการอื่นที่ยังไม่ได้ migrate ได้ทันที
                                </p>
                            </div>
                        </div>
                    `;

                    const currentCountStopped = parseInt((currentNewsCountEl.textContent || '0').replace(/[^0-9]/g, ''), 10) || 0;
                    currentNewsCountEl.textContent = `${currentCountStopped + aggregate.successCount} รายการ`;
                    return;
                }

                resultContainer.innerHTML = `
                        <div class="bg-gradient-to-br from-green-50 to-emerald-50 border-2 border-green-400 rounded-xl p-8 shadow-lg">
                            <div class="flex items-center gap-3 mb-6">
                                <span class="text-3xl animate-bounce">✅</span>
                                <h5 class="font-bold text-green-900 text-xl">Batch Migration สำเร็จ!</h5>
                            </div>
                            <div class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-8">
                                <div class="bg-white rounded-lg p-5 border-2 border-blue-200 shadow-md text-center">
                                    <p class="text-xs text-gray-600 font-semibold">📊 ประมวลผล</p>
                                    <p class="text-2xl font-bold text-blue-600 mt-2">${aggregate.totalProcessed}</p>
                                </div>
                                <div class="bg-white rounded-lg p-5 border-2 border-green-200 shadow-md text-center">
                                    <p class="text-xs text-gray-600 font-semibold">✨ เพิ่มใหม่</p>
                                    <p class="text-2xl font-bold text-green-600 mt-2">${aggregate.successCount}</p>
                                </div>
                                <div class="bg-white rounded-lg p-5 border-2 border-purple-200 shadow-md text-center">
                                    <p class="text-xs text-gray-600 font-semibold">🔄 อัปเดต</p>
                                    <p class="text-2xl font-bold text-purple-600 mt-2">${aggregate.updatedCount || 0}</p>
                                </div>
                                <div class="bg-white rounded-lg p-5 border-2 border-yellow-200 shadow-md text-center">
                                    <p class="text-xs text-gray-600 font-semibold">⏭️ ข้าม (ซ้ำ)</p>
                                    <p class="text-2xl font-bold text-yellow-600 mt-2">${aggregate.skippedCount || 0}</p>
                                </div>
                                <div class="bg-white rounded-lg p-5 border-2 border-red-200 shadow-md text-center">
                                    <p class="text-xs text-gray-600 font-semibold">⚠️ ผิดพลาด</p>
                                    <p class="text-2xl font-bold text-red-600 mt-2">${aggregate.errorCount}</p>
                                </div>
                            </div>
                            
                            <!-- 📊 สถิติไฟล์ที่คัดลอก -->
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                                <div class="bg-blue-50 border-2 border-blue-300 p-6 rounded-lg">
                                    <h6 class="font-bold text-blue-900 mb-4 flex items-center gap-2">
                                        <span class="text-xl">🖼️</span>
                                        <span>รูปภาพ</span>
                                    </h6>
                                    <div class="space-y-3">
                                        <div class="flex justify-between items-center p-3 bg-white rounded-lg border border-blue-200">
                                            <span class="text-sm text-blue-800 font-medium">คัดลอกสำเร็จ:</span>
                                            <span class="text-lg font-bold text-green-600">${aggregate.imagesCopied || 0} ไฟล์</span>
                                        </div>
                                        <div class="flex justify-between items-center p-3 bg-white rounded-lg border border-red-200">
                                            <span class="text-sm text-red-800 font-medium">ผิดพลาด:</span>
                                            <span class="text-lg font-bold text-red-600">${aggregate.imageErrors || 0} ไฟล์</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="bg-purple-50 border-2 border-purple-300 p-6 rounded-lg">
                                    <h6 class="font-bold text-purple-900 mb-4 flex items-center gap-2">
                                        <span class="text-xl">📎</span>
                                        <span>ไฟล์แนบ (PDF/JPG)</span>
                                    </h6>
                                    <div class="space-y-3">
                                        <div class="flex justify-between items-center p-3 bg-white rounded-lg border border-green-200">
                                            <span class="text-sm text-purple-800 font-medium">คัดลอกสำเร็จ:</span>
                                            <span class="text-lg font-bold text-green-600">${aggregate.attachmentsCopied || 0} ไฟล์</span>
                                        </div>
                                        <div class="flex justify-between items-center p-3 bg-white rounded-lg border border-red-200">
                                            <span class="text-sm text-red-800 font-medium">ผิดพลาด:</span>
                                            <span class="text-lg font-bold text-red-600">${aggregate.attachmentErrors || 0} ไฟล์</span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="bg-white rounded-lg p-6 border-l-4 border-green-500">
                                <p class="text-sm text-gray-700 mb-2">
                                    🎯 <strong>Destination:</strong> <span class="font-semibold text-green-700">${aggregate.destinationCategory || '-'}</span>
                                </p>
                                <p class="text-sm text-gray-600 font-medium">
                                    Batch migration completed: <span class="text-green-600">${aggregate.successCount} created</span>, <span class="text-purple-600">${aggregate.updatedCount} updated</span>, <span class="text-yellow-600">${aggregate.skippedCount} skipped</span>, <span class="text-red-600">${aggregate.errorCount} errors</span>
                                </p>
                            </div>
                            ${aggregate.errors.length > 0 ? `
                                <div class="mt-6 bg-red-50 border-2 border-red-200 rounded-lg p-6">
                                    <h6 class="font-bold text-red-900 mb-4 flex items-center gap-2">
                                        <span class="text-xl">⚠️</span>
                                        <span>รายการที่มีข้อผิดพลาด</span>
                                    </h6>
                                    <ul class="list-disc list-inside text-sm text-red-700 space-y-1 max-h-48 overflow-y-auto">
                                        ${aggregate.errors.map(err => `
                                            <li class="font-medium">${err.title}: <span class="text-red-600">${err.error}</span></li>
                                        `).join('')}
                                    </ul>
                                </div>
                            ` : ''}
                        </div>
                        
                        ${generateFileErrorsSection(aggregate)}
                    `;

                // Update current news count (เฉพาะรายการที่สร้างใหม่)
                const currentCount = parseInt((currentNewsCountEl.textContent || '0').replace(/[^0-9]/g, ''), 10) || 0;
                currentNewsCountEl.textContent = `${currentCount + aggregate.successCount} รายการ`;
            } catch (error) {
                progressContainer.classList.add('hidden');
                resultContainer.classList.remove('hidden');
                resultContainer.innerHTML = `
                    <div class="bg-gradient-to-br from-red-50 to-orange-50 border-2 border-red-400 rounded-xl p-8 shadow-lg">
                        <div class="flex items-center gap-3 mb-4">
                            <span class="text-3xl">⚠️</span>
                            <h5 class="font-bold text-red-900 text-xl">เกิดข้อผิดพลาด</h5>
                        </div>
                        <p class="text-red-700 font-medium mb-2">ไม่สามารถเชื่อมต่อกับเซิร์ฟเวอร์ได้</p>
                        <p class="text-sm text-red-600 bg-white rounded p-3 mt-3 border border-red-200 font-mono">${error.message}</p>
                    </div>
                `;
            } finally {
                isMigrationRunning = false;
                cancelRequested = false;
                setCancelButtonState(false);
                setButtonsDisabled(false);
                shouldRetryExisting = false;
            }
        });
    </script>
</body>
</html>
