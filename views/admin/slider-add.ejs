<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Sarabun', sans-serif; }
    </style>
</head>
<body class="bg-gray-100">
    <div class="flex min-h-screen">
        <!-- Sidebar -->
        <%- include('admin-panel', { currentPage }) %>

        <!-- Main Content -->
        <main class="flex-1 p-8">
            <div class="max-w-4xl mx-auto">
                <div class="bg-white rounded-lg shadow-md p-6 mb-6">
                    <h2 class="text-3xl font-bold text-gray-800">เพิ่ม Slider ใหม่</h2>
                    <p class="text-gray-600 mt-2">กรอกข้อมูล Slider สำหรับหน้าแรก</p>
                </div>

                <form action="/admin/sliders/add" method="POST" enctype="multipart/form-data" class="bg-white rounded-lg shadow-md p-6">
                    <div class="space-y-6">
                        <% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
                        <div class="bg-red-50 border-l-4 border-red-500 p-4 rounded">
                            <p class="text-red-700 font-semibold"><%= errorMessage %></p>
                        </div>
                        <% } %>

                        <!-- หัวข้อหลัก -->
                        <div>
                            <label class="block text-sm font-bold text-gray-700 mb-2">หัวข้อหลัก *</label>
                            <input type="text" name="title" required value="<%= formData.title || '' %>"
                                   class="w-full p-3 border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:outline-none"
                                   placeholder="เช่น เทศบาลนครปากเกร็ด คว้ารางวัลเมืองน่าอยู่">
                        </div>

                        <!-- หัวข้อรอง -->
                        <div>
                            <label class="block text-sm font-bold text-gray-700 mb-2">หัวข้อรอง</label>
                            <input type="text" name="subtitle" value="<%= formData.subtitle || '' %>"
                                   class="w-full p-3 border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:outline-none"
                                   placeholder="เช่น มุ่งมั่นพัฒนาคุณภาพชีวิตประชาชน">
                        </div>

                        <!-- อัปโหลดรูปภาพ -->
                        <div>
                            <label class="block text-sm font-bold text-gray-700 mb-2">อัปโหลดรูปภาพ</label>
                            <div class="bg-blue-50 border-l-4 border-blue-500 p-3 mb-3 rounded">
                                <p class="text-sm text-blue-800 font-semibold">📐 ขนาดรูปภาพมาตรฐาน: 1920 x 1080 พิกเซล</p>
                                <p class="text-xs text-blue-700 mt-1">✨ ระบบจะปรับขนาดรูปภาพให้อัตโนมัติเป็น 1920x1080 หลังจาก upload</p>
                            </div>
                            <input type="file" name="image_file" accept=".jpg,.jpeg,.png,.webp,.gif,image/*"
                                   class="w-full p-3 border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:outline-none bg-white">
                            <p class="text-xs text-gray-500 mt-1">อนุญาตเฉพาะ .jpg, .jpeg, .png, .webp, .gif (สูงสุด 10MB)</p>
                        </div>

                        <!-- URL รูปภาพ -->
                        <div>
                            <label class="block text-sm font-bold text-gray-700 mb-2">หรือใส่ URL รูปภาพ</label>
                            <input type="url" name="image_url" value="<%= formData.image_url || '' %>"
                                   class="w-full p-3 border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:outline-none"
                                   placeholder="https://example.com/image.jpg">
                            <p class="text-xs text-gray-500 mt-1">กรอก URL หรืออัปโหลดไฟล์ อย่างน้อย 1 วิธี</p>
                        </div>

                        <!-- URL ลิงก์ -->
                        <div>
                            <label class="block text-sm font-bold text-gray-700 mb-2">URL ลิงก์</label>
                            <input type="url" name="link_url" value="<%= formData.link_url || '' %>"
                                   class="w-full p-3 border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:outline-none"
                                   placeholder="https://example.com/page">
                            <p class="text-xs text-gray-500 mt-1">URL ที่จะเปิดเมื่อคลิก Slider (ถ้ามี)</p>
                        </div>

                        <!-- Badge -->
                        <div>
                            <label class="block text-sm font-bold text-gray-700 mb-2">ข้อความ Badge</label>
                            <input type="text" name="badge_text" value="<%= formData.badge_text || '' %>"
                                   class="w-full p-3 border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:outline-none"
                                   placeholder="เช่น ข่าวเด่น, ข่าวใหม่">
                            <p class="text-xs text-gray-500 mt-1">แสดงเป็นป้ายด้านบนหัวข้อ</p>
                        </div>

                        <!-- ลำดับการแสดง -->
                        <div>
                            <label class="block text-sm font-bold text-gray-700 mb-2">ลำดับการแสดง *</label>
                            <input type="number" name="display_order" required value="<%= formData.display_order || 0 %>" min="0"
                                   class="w-full p-3 border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:outline-none">
                            <p class="text-xs text-gray-500 mt-1">เรียงจากน้อยไปมาก (0, 1, 2, ...)</p>
                        </div>

                        <!-- ตัวอย่างแสดงผล -->
                        <div class="bg-blue-50 border-l-4 border-blue-500 p-4">
                            <h3 class="font-bold text-blue-800 mb-2">💡 ตัวอย่างแสดงผล:</h3>
                            <div class="bg-white rounded-lg p-4 shadow">
                                <span class="bg-blue-600 text-white px-2 py-1 rounded-full text-xs">Badge ที่นี่</span>
                                <h4 class="text-xl font-bold text-gray-800 mt-2">หัวข้อหลักที่นี่</h4>
                                <p class="text-gray-600 text-sm">หัวข้อรองที่นี่</p>
                            </div>
                        </div>

                        <!-- ปุ่ม -->
                        <div class="pt-4 flex gap-4">
                            <button type="submit" class="bg-green-600 hover:bg-green-700 text-white font-bold py-3 px-8 rounded-lg transition shadow-md">
                                💾 บันทึก Slider
                            </button>
                            <a href="/admin/sliders" class="bg-gray-600 hover:bg-gray-700 text-white font-bold py-3 px-8 rounded-lg transition inline-block">
                                ← ยกเลิก
                            </a>
                        </div>
                    </div>
                </form>
            </div>
        </main>
    </div>
</body>
</html>
