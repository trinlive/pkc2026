<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;700&display=swap" rel="stylesheet">
    
    <style>
        body { font-family: 'Sarabun', sans-serif; }
        .status-badge { display: inline-block; padding: 0.25rem 0.75rem; border-radius: 9999px; font-size: 0.875rem; }
        .status-published { background-color: #d1fae5; color: #065f46; }
        .status-draft { background-color: #fef3c7; color: #78350f; }
    </style>
</head>
<body class="bg-gray-100">
    <div class="flex min-h-screen">
        <!-- Sidebar -->
            <%- include('./partials/sidebar', { currentPage }) %>

        <!-- Main Content -->
        <main class="flex-1 p-8">
            <div class="max-w-7xl mx-auto">
                <!-- Header -->
                <div class="bg-white rounded-lg shadow-md p-6 mb-6">
                    <div class="flex justify-between items-center">
                        <div>
                            <h2 class="text-3xl font-bold text-gray-800">🎯 จัดการข่าวกิจกรรม</h2>
                            <p class="text-gray-600 mt-2">รายการข่าวกิจกรรมที่ Migrate มาจากระบบ Joomla เก่า</p>
                        </div>
                    </div>
                </div>

                <!-- Statistics -->
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
                    <div class="bg-white rounded-lg shadow-md p-4">
                        <div class="text-3xl font-bold text-gray-800"><%= totalItems %></div>
                        <div class="text-gray-600">ข่าวกิจกรรมทั้งหมด</div>
                    </div>
                    <div class="bg-white rounded-lg shadow-md p-4">
                        <div class="text-3xl font-bold text-green-600"><%= publishedCount %></div>
                        <div class="text-gray-600">✅ เผยแพร่แล้ว</div>
                    </div>
                    <div class="bg-white rounded-lg shadow-md p-4">
                        <div class="text-3xl font-bold text-blue-600"><%= migratedCount %></div>
                        <div class="text-gray-600">📦 Migrate จาก Joomla</div>
                    </div>
                </div>

                <!-- Table -->
                <div class="bg-white rounded-lg shadow-md overflow-hidden">
                    <% if (activities && activities.length > 0) { %>
                        <div class="overflow-x-auto">
                            <table class="w-full border-collapse">
                                <thead>
                                    <tr class="bg-blue-900 text-white">
                                        <th class="px-6 py-4 text-left text-sm font-semibold">ID</th>
                                        <th class="px-6 py-4 text-left text-sm font-semibold">ชื่อข่าว</th>
                                        <th class="px-6 py-4 text-left text-sm font-semibold">สถานะ</th>
                                        <th class="px-6 py-4 text-left text-sm font-semibold">วันที่เผยแพร่</th>
                                        <th class="px-6 py-4 text-left text-sm font-semibold">ผู้เขียน</th>
                                        <th class="px-6 py-4 text-left text-sm font-semibold">การจัดการ</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% activities.forEach((activity, index) => { %>
                                        <tr class="border-b hover:bg-gray-50 transition">
                                            <td class="px-6 py-4 text-sm"><%= activity.id %></td>
                                            <td class="px-6 py-4">
                                                <div class="text-sm font-semibold text-gray-800"><%= activity.title %></div>
                                                <% if (activity.image_url) { %>
                                                    <img src="<%= activity.image_url %>" alt="<%= activity.title %>" class="mt-2 h-16 w-auto rounded" onerror="this.src='/images/placeholder.png'">
                                                <% } %>
                                            </td>
                                            <td class="px-6 py-4">
                                                <span class="status-badge <%= activity.is_published === 1 ? 'status-published' : 'status-draft' %>">
                                                    <%= activity.is_published === 1 ? '✅ เผยแพร่' : '⏸️ ร่าง' %>
                                                </span>
                                            </td>
                                            <td class="px-6 py-4 text-sm text-gray-600">
                                                <% 
                                                    const date = new Date(activity.date_posted);
                                                    const formattedDate = date.toLocaleDateString('th-TH', { 
                                                        year: 'numeric', 
                                                        month: 'short', 
                                                        day: 'numeric',
                                                        hour: '2-digit',
                                                        minute: '2-digit'
                                                    });
                                                %>
                                                <%= formattedDate %>
                                            </td>
                                            <td class="px-6 py-4 text-sm text-gray-600">
                                                <% if (activity.created_by && activity.created_by.startsWith('joomla:')) { %>
                                                    <span class="text-xs bg-blue-100 text-blue-800 px-2 py-1 rounded">📦 <%= activity.created_by %></span>
                                                <% } else { %>
                                                    <%= activity.created_by || 'N/A' %>
                                                <% } %>
                                            </td>
                                            <td class="px-6 py-4 text-sm">
                                                <a href="/admin/activities/<%= activity.id %>" class="text-blue-600 hover:text-blue-800 font-semibold transition">
                                                    👁️ ดู
                                                </a>
                                            </td>
                                        </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                    <% } else { %>
                        <div class="p-8 text-center text-gray-500">
                            <p class="text-lg">ไม่พบข่าวกิจกรรมในระบบ</p>
                        </div>
                    <% } %>
                </div>

                <!-- Footer Info -->
                <div class="mt-6 bg-blue-50 border border-blue-200 rounded-lg p-4">
                    <p class="text-sm text-blue-800">
                        💡 <strong>ข้อมูล:</strong> ข่าวกิจกรรมนี้ถูก Migrate มาจากฐานข้อมูล Joomla เก่า (pkc_joomla_db) 
                        และเก็บในตาราง news_activity แยกต่างหาก
                        รายการที่แสดงคือข้อมูลที่ผ่านการ Migration แล้วเท่านั้น
                    </p>
                </div>
            </div>
        </main>
    </div>
</body>
</html>
