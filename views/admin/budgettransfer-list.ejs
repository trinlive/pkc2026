<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Sarabun', sans-serif; }
        .status-badge { 
            display: inline-block; 
            padding: 0.375rem 0.75rem; 
            border-radius: 9999px; 
            font-size: 0.75rem; 
            font-weight: 600;
        }
        .status-published { background-color: #d1fae5; color: #065f46; }
        .status-draft { background-color: #fef3c7; color: #78350f; }
        .status-featured { background-color: #dbeafe; color: #0c2d6b; }
    </style>
</head>
<body class="bg-gray-100">
    <div class="flex min-h-screen">
        <!-- Sidebar -->
        <%- include('./partials/sidebar', { currentPage: 'budgettransfer' }) %>

        <!-- Main Content -->
        <main class="flex-1 p-8">
            <div class="max-w-7xl mx-auto">
                <!-- Header -->
                <div class="bg-white rounded-lg shadow-md p-6 mb-6">
                    <div class="flex justify-between items-center">
                        <div>
                            <h2 class="text-3xl font-bold text-gray-800">💰 จัดการการโอนงบประมาณรายจ่าย</h2>
                            <p class="text-gray-600 mt-2">รวมทั้งหมด: <span class="font-semibold text-orange-600"><%= statistics.total %></span> รายการ</p>
                        </div>
                        <a href="/admin/budgettransfer/add" class="bg-orange-600 hover:bg-orange-700 text-white font-bold py-3 px-6 rounded-lg transition shadow-md">
                            ➕ เพิ่มรายการใหม่
                        </a>
                    </div>
                </div>

                <!-- Statistics Cards -->
                <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
                    <div class="bg-white rounded-lg shadow-md p-4">
                        <div class="flex items-center">
                            <div class="text-3xl">📊</div>
                            <div class="ml-4">
                                <p class="text-gray-500 text-sm">ทั้งหมด</p>
                                <p class="text-2xl font-bold text-gray-800"><%= statistics.total %></p>
                            </div>
                        </div>
                    </div>
                    <div class="bg-white rounded-lg shadow-md p-4">
                        <div class="flex items-center">
                            <div class="text-3xl">✓</div>
                            <div class="ml-4">
                                <p class="text-gray-500 text-sm">เผยแพร่แล้ว</p>
                                <p class="text-2xl font-bold text-green-600"><%= statistics.published %></p>
                            </div>
                        </div>
                    </div>
                    <div class="bg-white rounded-lg shadow-md p-4">
                        <div class="flex items-center">
                            <div class="text-3xl">◐</div>
                            <div class="ml-4">
                                <p class="text-gray-500 text-sm">ร่างอยู่</p>
                                <p class="text-2xl font-bold text-yellow-600"><%= statistics.draft %></p>
                            </div>
                        </div>
                    </div>
                    <div class="bg-white rounded-lg shadow-md p-4">
                        <div class="flex items-center">
                            <div class="text-3xl">★</div>
                            <div class="ml-4">
                                <p class="text-gray-500 text-sm">ปักหมุด</p>
                                <p class="text-2xl font-bold text-blue-600"><%= statistics.featured %></p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Search and Filter -->
                <div class="bg-white rounded-lg shadow-md p-4 mb-6">
                    <form action="/admin/budgettransfer" method="GET" class="mb-4">
                        <div class="flex gap-3 flex-wrap">
                            <input type="hidden" name="limit" value="<%= currentLimit %>">
                            <input
                                type="text"
                                name="q"
                                value="<%= searchQuery || '' %>"
                                placeholder="ค้นหาหัวข้อ หรือ อ้างอิง..."
                                class="flex-1 min-w-[260px] p-2.5 border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:outline-none"
                            >
                            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-medium px-5 py-2.5 rounded-lg transition">
                                🔍 ค้นหา
                            </button>
                            <% if (searchQuery) { %>
                                <a href="/admin/budgettransfer?limit=<%= currentLimit %>" class="bg-gray-200 hover:bg-gray-300 text-gray-700 font-medium px-5 py-2.5 rounded-lg transition">
                                    ล้างคำค้น
                                </a>
                            <% } %>
                        </div>
                    </form>

                    <div class="flex items-center justify-between flex-wrap gap-4">
                        <div class="flex items-center gap-2">
                            <span class="text-sm font-medium text-gray-700">แสดงรายการ:</span>
                            <div class="flex gap-2">
                                <a href="/admin/budgettransfer?limit=30<%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>" class="<%= currentLimit === 30 ? 'bg-orange-600 text-white' : 'bg-gray-200 text-gray-700 hover:bg-gray-300' %> px-4 py-2 rounded-lg font-medium transition text-sm">30</a>
                                <a href="/admin/budgettransfer?limit=50<%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>" class="<%= currentLimit === 50 ? 'bg-orange-600 text-white' : 'bg-gray-200 text-gray-700 hover:bg-gray-300' %> px-4 py-2 rounded-lg font-medium transition text-sm">50</a>
                                <a href="/admin/budgettransfer?limit=100<%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>" class="<%= currentLimit === 100 ? 'bg-orange-600 text-white' : 'bg-gray-200 text-gray-700 hover:bg-gray-300' %> px-4 py-2 rounded-lg font-medium transition text-sm">100</a>
                                <a href="/admin/budgettransfer?limit=all<%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>" class="<%= currentLimit === 'all' ? 'bg-orange-600 text-white' : 'bg-gray-200 text-gray-700 hover:bg-gray-300' %> px-4 py-2 rounded-lg font-medium transition text-sm">ทั้งหมด</a>
                            </div>
                        </div>
                        <div class="text-sm text-gray-600">
                            แสดง <span class="font-semibold"><%= budgetTransferList.length %></span> จาก <span class="font-semibold"><%= searchQuery ? statistics.filteredTotal : statistics.total %></span> รายการ
                        </div>
                    </div>
                </div>

                <!-- Budget Transfer Table -->
                <div class="bg-white rounded-lg shadow-md overflow-hidden">
                    <% if (budgetTransferList.length > 0) { %>
                        <!-- Bulk Action Bar -->
                        <div class="bg-orange-50 border-b border-orange-200 px-4 py-3 hidden" id="bulkActionBar">
                            <div class="flex items-center justify-between">
                                <div class="flex items-center gap-4">
                                    <span class="text-sm font-medium text-gray-700">
                                        เลือกแล้ว: <span id="selectedCount">0</span> รายการ
                                    </span>
                                    <button type="button" id="deleteSelectedBtn" 
                                            class="bg-red-600 hover:bg-red-700 text-white font-medium px-5 py-2 rounded-lg transition text-sm">
                                        🗑️ ลบที่เลือก
                                    </button>
                                </div>
                                <button type="button" id="cancelSelectBtn"
                                        class="bg-gray-400 hover:bg-gray-500 text-white font-medium px-4 py-2 rounded-lg transition text-sm">
                                    ยกเลิก
                                </button>
                            </div>
                        </div>

                        <div class="overflow-x-auto">
                            <table class="w-full">
                                <thead class="bg-gray-50 border-b">
                                    <tr>
                                        <th class="px-4 py-3 text-center text-sm font-semibold text-gray-700 w-12">
                                            <input type="checkbox" id="selectAllCheckbox" class="w-5 h-5 cursor-pointer rounded">
                                        </th>
                                        <th class="px-4 py-3 text-center text-sm font-semibold text-gray-700">ID</th>
                                        <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700">หัวข้อ/อ้างอิง</th>
                                        <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700">หมวดหมู่</th>
                                        <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700">วันที่สร้าง</th>
                                        <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700">สถานะ</th>
                                        <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700">ไฟล์แนบ</th>
                                        <th class="px-6 py-3 text-center text-sm font-semibold text-gray-700">ดำเนินการ</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% budgetTransferList.forEach((item, index) => { %>
                                        <tr class="border-b hover:bg-gray-50" data-transfer-id="<%= item.id %>">
                                            <td class="px-4 py-4 text-center">
                                                <input type="checkbox" class="transferCheckbox w-5 h-5 cursor-pointer rounded" value="<%= item.id %>">
                                            </td>
                                            <td class="px-4 py-4 text-center">
                                                <span class="inline-flex items-center justify-center min-w-10 h-10 px-2 bg-gray-100 text-gray-700 font-semibold rounded-lg">
                                                    <%= item.id %>
                                                </span>
                                            </td>
                                            <td class="px-6 py-4">
                                                <div>
                                                    <div class="font-medium text-gray-900">
                                                        <% if (item.title.length > 50) { %>
                                                            <%= item.title.substring(0, 50) %>...
                                                        <% } else { %>
                                                            <%= item.title %>
                                                        <% } %>
                                                    </div>
                                                    <% if (item.reference_number) { %>
                                                        <div class="text-xs text-gray-500 mt-1">อ้างอิง: <%= item.reference_number %></div>
                                                    <% } %>
                                                </div>
                                            </td>
                                            <td class="px-6 py-4 text-sm">
                                                <span class="inline-block px-2 py-1 bg-purple-100 text-purple-800 text-xs rounded-full font-medium">
                                                    <%= item.category || 'ไม่ระบุ' %>
                                                </span>
                                            </td>
                                            <td class="px-6 py-4 text-sm text-gray-600">
                                                <% 
                                                    const date = new Date(item.date_posted);
                                                    const dateStr = date.toLocaleDateString('th-TH', { 
                                                        year: 'numeric', 
                                                        month: 'short', 
                                                        day: 'numeric'
                                                    });
                                                %>
                                                <%= dateStr %>
                                            </td>
                                            <td class="px-6 py-4 text-sm">
                                                <div class="flex gap-2 flex-wrap">
                                                    <span class="status-badge <%= item.is_published ? 'status-published' : 'status-draft' %>">
                                                        <%= item.is_published ? '✓ เผยแพร่' : '◐ ร่าง' %>
                                                    </span>
                                                    <% if (item.is_featured) { %>
                                                        <span class="status-badge status-featured">★ ปักหมุด</span>
                                                    <% } %>
                                                </div>
                                            </td>
                                            <td class="px-6 py-4 text-sm">
                                                <% if (item.attachment_url) { %>
                                                    <a href="<%= item.attachment_url %>" target="_blank" class="text-green-600 hover:text-green-800 font-medium">
                                                        📎 ดาวน์โหลด
                                                    </a>
                                                <% } else { %>
                                                    <span class="text-gray-400">ไม่มี</span>
                                                <% } %>
                                            </td>
                                            <td class="px-6 py-4 text-center">
                                                <div class="flex justify-center gap-2">
                                                    <a href="/admin/budgettransfer/edit/<%= item.id %>" class="text-blue-600 hover:text-blue-800 font-medium text-sm">
                                                        ✏️ แก้ไข
                                                    </a>
                                                    <form action="/admin/budgettransfer/delete/<%= item.id %>" method="POST" style="display:inline;" onsubmit="return confirm('ยืนยันการลบรายการนี้?');">
                                                        <button type="submit" class="text-red-600 hover:text-red-800 font-medium text-sm">
                                                            🗑️ ลบ
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                    <% } else { %>
                        <div class="p-8 text-center">
                            <div class="text-4xl mb-4">📭</div>
                            <p class="text-gray-600 text-lg">ยังไม่มีรายการโอนงบประมาณรายจ่าย</p>
                            <a href="/admin/budgettransfer/add" class="mt-4 inline-block bg-orange-600 hover:bg-orange-700 text-white font-bold py-2 px-6 rounded-lg transition">
                                เพิ่มรายการใหม่
                            </a>
                        </div>
                    <% } %>
                </div>
            </div>
        </main>
    </div>

    <script>
        // Checkbox management
        const selectAllCheckbox = document.getElementById('selectAllCheckbox');
        const transferCheckboxes = document.querySelectorAll('.transferCheckbox');
        const bulkActionBar = document.getElementById('bulkActionBar');
        const selectedCount = document.getElementById('selectedCount');
        const deleteSelectedBtn = document.getElementById('deleteSelectedBtn');
        const cancelSelectBtn = document.getElementById('cancelSelectBtn');

        selectAllCheckbox.addEventListener('change', (e) => {
            transferCheckboxes.forEach(checkbox => {
                checkbox.checked = e.target.checked;
            });
            updateBulkActionBar();
        });

        transferCheckboxes.forEach(checkbox => {
            checkbox.addEventListener('change', () => {
                const allChecked = Array.from(transferCheckboxes).every(cb => cb.checked);
                const someChecked = Array.from(transferCheckboxes).some(cb => cb.checked);
                
                selectAllCheckbox.checked = allChecked;
                selectAllCheckbox.indeterminate = someChecked && !allChecked;
                
                updateBulkActionBar();
            });
        });

        function updateBulkActionBar() {
            const checkedCount = Array.from(transferCheckboxes).filter(cb => cb.checked).length;
            selectedCount.textContent = checkedCount;
            
            if (checkedCount > 0) {
                bulkActionBar.classList.remove('hidden');
            } else {
                bulkActionBar.classList.add('hidden');
            }
        }

        cancelSelectBtn.addEventListener('click', () => {
            selectAllCheckbox.checked = false;
            transferCheckboxes.forEach(checkbox => checkbox.checked = false);
            updateBulkActionBar();
        });

        deleteSelectedBtn.addEventListener('click', async () => {
            const selectedIds = Array.from(transferCheckboxes)
                .filter(checkbox => checkbox.checked)
                .map(checkbox => parseInt(checkbox.value));

            if (selectedIds.length === 0) {
                alert('กรุณาเลือกรายการที่ต้องการลบ');
                return;
            }

            if (!confirm(`ยืนยันการลบ ${selectedIds.length} รายการ?\n\nการกระทำนี้ไม่สามารถเรียกคืนได้`)) {
                return;
            }

            deleteSelectedBtn.disabled = true;
            deleteSelectedBtn.textContent = '⏳ กำลังลบ...';

            try {
                const response = await fetch('/admin/budgettransfer/delete-multiple', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ ids: selectedIds })
                });

                const result = await response.json();

                if (result.success) {
                    alert(`ลบสำเร็จ ${result.deletedCount} รายการ`);
                    location.reload();
                } else {
                    alert(`เกิดข้อผิดพลาด: ${result.message}`);
                    deleteSelectedBtn.disabled = false;
                    deleteSelectedBtn.textContent = '🗑️ ลบที่เลือก';
                }
            } catch (error) {
                console.error('Error:', error);
                alert('เกิดข้อผิดพลาดในการลบข้อมูล');
                deleteSelectedBtn.disabled = false;
                deleteSelectedBtn.textContent = '🗑️ ลบที่เลือก';
            }
        });
    </script>
</body>
</html>
