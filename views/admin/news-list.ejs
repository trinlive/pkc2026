<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;700&display=swap" rel="stylesheet">
    
    <style>
        body { font-family: 'Sarabun', sans-serif; }
        .status-badge { display: inline-block; padding: 0.25rem 0.75rem; border-radius: 9999px; font-size: 0.875rem; }
        .status-published { background-color: #d1fae5; color: #065f46; }
        .status-draft { background-color: #fef3c7; color: #78350f; }
        .status-featured { background-color: #dbeafe; color: #0c2d6b; }
    </style>
</head>
<body class="bg-gray-100">
    <div class="flex min-h-screen">
        <!-- Sidebar -->
            <%- include('./partials/sidebar', { currentPage }) %>

        <!-- Main Content -->
        <main class="flex-1 p-8">
            <div class="max-w-7xl mx-auto">
                <!-- Header -->
                <div class="bg-white rounded-lg shadow-md p-6 mb-6">
                    <div class="flex justify-between items-center">
                        <div>
                            <h2 class="text-3xl font-bold text-gray-800">📰 จัดการข่าวประชาสัมพันธ์</h2>
                            <p class="text-gray-600 mt-2">สร้าง แก้ไข และจัดการข่าวประชาสัมพันธ์ของเทศบาล</p>
                        </div>
                        <a href="/admin/news/add" class="bg-orange-600 hover:bg-orange-700 text-white font-bold py-3 px-6 rounded-lg transition shadow-md">
                            ➕ เพิ่มข่าวใหม่
                        </a>
                    </div>
                </div>

                <!-- Statistics -->
                <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
                    <div class="bg-white rounded-lg shadow-md p-4">
                        <div class="text-3xl font-bold text-gray-800"><%= statistics.total %></div>
                        <div class="text-gray-600">ข่าวทั้งหมด</div>
                    </div>
                    <div class="bg-white rounded-lg shadow-md p-4">
                        <div class="text-3xl font-bold text-green-600"><%= statistics.published %></div>
                        <div class="text-gray-600">เผยแพร่แล้ว</div>
                    </div>
                    <div class="bg-white rounded-lg shadow-md p-4">
                        <div class="text-3xl font-bold text-yellow-600"><%= statistics.draft %></div>
                        <div class="text-gray-600">ร่าง</div>
                    </div>
                    <div class="bg-white rounded-lg shadow-md p-4">
                        <div class="text-3xl font-bold text-blue-600"><%= statistics.featured %></div>
                        <div class="text-gray-600">ปักหมุด</div>
                    </div>
                </div>

                <!-- Homepage News Preview -->
                <% if (homepageNews && homepageNews.length > 0) { %>
                <div class="bg-gradient-to-r from-blue-50 to-indigo-50 border-2 border-blue-200 rounded-lg shadow-md p-5 mb-6">
                    <div class="flex items-center mb-4">
                        <span class="text-2xl mr-2">🏠</span>
                        <h3 class="text-xl font-bold text-blue-800">ข่าวที่แสดงในหน้าแรก Home (5 รายการแรก)</h3>
                    </div>
                    <div class="bg-white rounded-lg overflow-hidden border border-blue-200">
                        <table class="min-w-full divide-y divide-gray-200">
                            <thead class="bg-blue-600">
                                <tr>
                                    <th class="px-4 py-3 text-left text-xs font-bold text-white uppercase tracking-wider w-12">#</th>
                                    <th class="px-4 py-3 text-left text-xs font-bold text-white uppercase tracking-wider">หัวข้อข่าว</th>
                                    <th class="px-4 py-3 text-left text-xs font-bold text-white uppercase tracking-wider w-32">หมวดหมู่</th>
                                    <th class="px-4 py-3 text-left text-xs font-bold text-white uppercase tracking-wider w-32">วันที่</th>
                                    <th class="px-4 py-3 text-center text-xs font-bold text-white uppercase tracking-wider w-24">สถานะ</th>
                                </tr>
                            </thead>
                            <tbody class="bg-white divide-y divide-gray-200">
                                <% homepageNews.forEach((news, index) => { %>
                                <tr class="hover:bg-blue-50 transition">
                                    <td class="px-4 py-3 whitespace-nowrap">
                                        <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-blue-600 text-white font-bold text-sm">
                                            <%= index + 1 %>
                                        </span>
                                    </td>
                                    <td class="px-4 py-3">
                                        <div class="text-sm font-medium text-gray-900"><%= news.title %></div>
                                        <% if (news.is_featured) { %>
                                            <span class="inline-block mt-1 px-2 py-0.5 bg-yellow-100 text-yellow-800 text-xs rounded-full">⭐ ปักหมุด</span>
                                        <% } %>
                                    </td>
                                    <td class="px-4 py-3 whitespace-nowrap">
                                        <span class="text-sm text-gray-600"><%= news.news_category || '-' %></span>
                                    </td>
                                    <td class="px-4 py-3 whitespace-nowrap">
                                        <span class="text-sm text-gray-600"><%= new Date(news.date_posted).toLocaleDateString('th-TH') %></span>
                                    </td>
                                    <td class="px-4 py-3 whitespace-nowrap text-center">
                                        <% if (news.is_published) { %>
                                            <span class="status-badge status-published">✅ เผยแพร่</span>
                                        <% } else { %>
                                            <span class="status-badge status-draft">📝 ร่าง</span>
                                        <% } %>
                                    </td>
                                </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                    <p class="text-xs text-gray-600 mt-3 italic">💡 ข่าวเหล่านี้แสดงบนหน้าแรกของเว็บไซต์ โดยเรียงตาม: ข่าวปักหมุด → ข่าวล่าสุด (is_featured DESC, date_posted DESC)</p>
                </div>
                <% } %>

                <!-- Pagination Controls -->
                <div class="bg-white rounded-lg shadow-md p-4 mb-6">
                    <form action="/admin/news" method="GET" class="mb-4">
                        <div class="flex gap-3 flex-wrap">
                            <input type="hidden" name="limit" value="<%= currentLimit %>">
                            <input
                                type="text"
                                name="q"
                                value="<%= searchQuery || '' %>"
                                placeholder="ค้นหาหัวข้อข่าว..."
                                class="flex-1 min-w-[260px] p-2.5 border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:outline-none"
                            >
                            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-medium px-5 py-2.5 rounded-lg transition">
                                🔍 ค้นหา
                            </button>
                            <% if (searchQuery) { %>
                                <a href="/admin/news?limit=<%= currentLimit %>" class="bg-gray-200 hover:bg-gray-300 text-gray-700 font-medium px-5 py-2.5 rounded-lg transition">
                                    ล้างคำค้น
                                </a>
                            <% } %>
                        </div>
                    </form>

                    <div class="flex items-center justify-between flex-wrap gap-4">
                        <div class="flex items-center gap-2">
                            <span class="text-sm font-medium text-gray-700">แสดงรายการ:</span>
                            <div class="flex gap-2">
                                <a href="/admin/news?limit=30<%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>" class="<%= currentLimit === 30 ? 'bg-orange-600 text-white' : 'bg-gray-200 text-gray-700 hover:bg-gray-300' %> px-4 py-2 rounded-lg font-medium transition text-sm">30</a>
                                <a href="/admin/news?limit=50<%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>" class="<%= currentLimit === 50 ? 'bg-orange-600 text-white' : 'bg-gray-200 text-gray-700 hover:bg-gray-300' %> px-4 py-2 rounded-lg font-medium transition text-sm">50</a>
                                <a href="/admin/news?limit=100<%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>" class="<%= currentLimit === 100 ? 'bg-orange-600 text-white' : 'bg-gray-200 text-gray-700 hover:bg-gray-300' %> px-4 py-2 rounded-lg font-medium transition text-sm">100</a>
                                <a href="/admin/news?limit=all<%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>" class="<%= currentLimit === 'all' ? 'bg-orange-600 text-white' : 'bg-gray-200 text-gray-700 hover:bg-gray-300' %> px-4 py-2 rounded-lg font-medium transition text-sm">ทั้งหมด</a>
                            </div>
                        </div>
                        <div class="text-sm text-gray-600">
                            แสดง <span class="font-semibold"><%= newsList.length %></span> จาก <span class="font-semibold"><%= searchQuery ? statistics.filteredTotal : statistics.total %></span> รายการ
                        </div>
                    </div>
                </div>

                <!-- News Table -->
                <div class="bg-white rounded-lg shadow-md overflow-hidden">
                    <% if (newsList.length > 0) { %>
                        <!-- Bulk Action Bar -->
                        <div class="bg-orange-50 border-b border-orange-200 px-4 py-3 hidden" id="bulkActionBar">
                            <div class="flex items-center justify-between">
                                <div class="flex items-center gap-4">
                                    <span class="text-sm font-medium text-gray-700">
                                        เลือกแล้ว: <span id="selectedCount">0</span> รายการ
                                    </span>
                                    <button type="button" id="deleteSelectedBtn" 
                                            class="bg-red-600 hover:bg-red-700 text-white font-medium px-5 py-2 rounded-lg transition text-sm">
                                        🗑️ ลบที่เลือก
                                    </button>
                                </div>
                                <button type="button" id="cancelSelectBtn"
                                        class="bg-gray-400 hover:bg-gray-500 text-white font-medium px-4 py-2 rounded-lg transition text-sm">
                                    ยกเลิก
                                </button>
                            </div>
                        </div>

                        <div class="overflow-x-auto">
                            <table class="w-full">
                                <thead class="bg-gray-50 border-b">
                                    <tr>
                                        <th class="px-4 py-3 text-center text-sm font-semibold text-gray-700 w-12">
                                            <input type="checkbox" id="selectAllCheckbox" class="w-5 h-5 cursor-pointer rounded">
                                        </th>
                                        <th class="px-4 py-3 text-center text-sm font-semibold text-gray-700">ID</th>
                                        <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700">หัวข้อข่าว</th>
                                        <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700">หมวดหมู่</th>
                                        <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700">วันที่ลง</th>
                                        <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700">สถานะ</th>
                                        <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700">ดูแล้ว</th>
                                        <th class="px-6 py-3 text-center text-sm font-semibold text-gray-700">ดำเนินการ</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% newsList.forEach((news, index) => { %>
                                        <% 
                                            let previewImageUrl = '';
                                            const sourceImageUrl = news.image_preview_url || news.image_url;
                                            if (sourceImageUrl) {
                                                try {
                                                    const cleanImagePath = decodeURIComponent(String(sourceImageUrl).split('#')[0].trim());
                                                    if (cleanImagePath) {
                                                        if (/^https?:\/\//i.test(cleanImagePath) || cleanImagePath.startsWith('/')) {
                                                            previewImageUrl = cleanImagePath;
                                                        } else {
                                                            previewImageUrl = `/${cleanImagePath}`;
                                                        }
                                                    }
                                                } catch (e) {
                                                    const fallbackPath = String(sourceImageUrl).split('#')[0].trim();
                                                    if (fallbackPath) {
                                                        previewImageUrl = fallbackPath.startsWith('/') ? fallbackPath : `/${fallbackPath}`;
                                                    }
                                                }
                                            }
                                        %>
                                        <tr class="border-b hover:bg-gray-50" data-news-id="<%= news.id %>">
                                            <td class="px-4 py-4 text-center">
                                                <input type="checkbox" class="newsCheckbox w-5 h-5 cursor-pointer rounded" value="<%= news.id %>">
                                            </td>
                                            <td class="px-4 py-4 text-center">
                                                <span class="inline-flex items-center justify-center min-w-10 h-10 px-2 bg-gray-100 text-gray-700 font-semibold rounded-lg">
                                                    <%= news.id %>
                                                </span>
                                            </td>
                                            <td class="px-6 py-4">
                                                <div class="flex items-center gap-3">
                                                    <% if (previewImageUrl) { %>
                                                        <img src="<%= previewImageUrl %>" alt="<%= news.title %>" class="w-12 h-12 object-cover rounded">
                                                    <% } else { %>
                                                        <div class="w-12 h-12 bg-gray-300 rounded flex items-center justify-center text-gray-600">
                                                            <span>ไม่มี</span>
                                                        </div>
                                                    <% } %>
                                                    <div>
                                                        <div class="font-medium text-gray-900">
                                                            <% if (news.title.length > 50) { %>
                                                                <%= news.title.substring(0, 50) %>...
                                                            <% } else { %>
                                                                <%= news.title %>
                                                            <% } %>
                                                        </div>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="px-6 py-4 text-sm text-gray-600">
                                                <% if (news.news_category) { %>
                                                    <span class="bg-blue-100 text-blue-800 px-3 py-1 rounded-full text-xs font-medium">
                                                        <%= news.news_category %>
                                                    </span>
                                                <% } else { %>
                                                    <span class="text-gray-400">-</span>
                                                <% } %>
                                            </td>
                                            <td class="px-6 py-4 text-sm text-gray-600">
                                                <% 
                                                    const date = new Date(news.date_posted);
                                                    const dateStr = date.toLocaleDateString('th-TH', { 
                                                        year: 'numeric', 
                                                        month: 'short', 
                                                        day: 'numeric',
                                                        hour: '2-digit',
                                                        minute: '2-digit'
                                                    });
                                                %>
                                                <%= dateStr %>
                                            </td>
                                            <td class="px-6 py-4 text-sm">
                                                <div class="flex gap-2">
                                                    <span class="status-badge <%= news.is_published ? 'status-published' : 'status-draft' %>">
                                                        <%= news.is_published ? '✓ เผยแพร่' : '◐ ร่าง' %>
                                                    </span>
                                                    <% if (news.is_featured) { %>
                                                        <span class="status-badge status-featured">★ ปักหมุด</span>
                                                    <% } %>
                                                </div>
                                            </td>
                                            <td class="px-6 py-4 text-sm text-gray-600">
                                                <span class="font-medium"><%= news.view_count || 0 %></span>
                                            </td>
                                            <td class="px-6 py-4 text-center">
                                                <div class="flex justify-center gap-2">
                                                    <a href="/admin/news/edit/<%= news.id %>" class="text-blue-600 hover:text-blue-800 font-medium text-sm">
                                                        ✏️ แก้ไข
                                                    </a>
                                                    <form action="/admin/news/delete/<%= news.id %>" method="POST" style="display:inline;" onsubmit="return confirm('ยืนยันการลบข่าวนี้?');">
                                                        <button type="submit" class="text-red-600 hover:text-red-800 font-medium text-sm">
                                                            🗑️ ลบ
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                    <% } else { %>
                        <div class="p-8 text-center">
                            <div class="text-4xl mb-4">📭</div>
                            <p class="text-gray-600 text-lg">ยังไม่มีข่าวประชาสัมพันธ์</p>
                            <a href="/admin/news/add" class="mt-4 inline-block bg-orange-600 hover:bg-orange-700 text-white font-bold py-2 px-6 rounded-lg transition">
                                เพิ่มข่าวใหม่
                            </a>
                        </div>
                    <% } %>
                </div>
            </div>
        </main>
    </div>

    <script>
        // จัดการ Checkbox
        const selectAllCheckbox = document.getElementById('selectAllCheckbox');
        const newsCheckboxes = document.querySelectorAll('.newsCheckbox');
        const bulkActionBar = document.getElementById('bulkActionBar');
        const selectedCount = document.getElementById('selectedCount');
        const deleteSelectedBtn = document.getElementById('deleteSelectedBtn');
        const cancelSelectBtn = document.getElementById('cancelSelectBtn');

        // Update Select All checkbox เมื่อเลือก/ยกเลิก checkbox ทั้งหมด
        selectAllCheckbox.addEventListener('change', (e) => {
            newsCheckboxes.forEach(checkbox => {
                checkbox.checked = e.target.checked;
            });
            updateBulkActionBar();
        });

        // Update เมื่อเลือกรายการแต่ละอัน
        newsCheckboxes.forEach(checkbox => {
            checkbox.addEventListener('change', () => {
                const allChecked = Array.from(newsCheckboxes).every(cb => cb.checked);
                const someChecked = Array.from(newsCheckboxes).some(cb => cb.checked);
                
                selectAllCheckbox.checked = allChecked;
                selectAllCheckbox.indeterminate = someChecked && !allChecked;
                
                updateBulkActionBar();
            });
        });

        // แสดง/ซ่อน Bulk Action Bar
        function updateBulkActionBar() {
            const checkedCount = Array.from(newsCheckboxes).filter(cb => cb.checked).length;
            selectedCount.textContent = checkedCount;
            
            if (checkedCount > 0) {
                bulkActionBar.classList.remove('hidden');
            } else {
                bulkActionBar.classList.add('hidden');
            }
        }

        // ยกเลิกการเลือก
        cancelSelectBtn.addEventListener('click', () => {
            selectAllCheckbox.checked = false;
            newsCheckboxes.forEach(checkbox => checkbox.checked = false);
            updateBulkActionBar();
        });

        // ลบรายการที่เลือก
        deleteSelectedBtn.addEventListener('click', async () => {
            const selectedIds = Array.from(newsCheckboxes)
                .filter(checkbox => checkbox.checked)
                .map(checkbox => parseInt(checkbox.value));

            if (selectedIds.length === 0) {
                alert('กรุณาเลือกรายการที่ต้องการลบ');
                return;
            }

            if (!confirm(`ยืนยันการลบ ${selectedIds.length} รายการ?\n\nการกระทำนี้ไม่สามารถเรียกคืนได้`)) {
                return;
            }

            deleteSelectedBtn.disabled = true;
            deleteSelectedBtn.textContent = '⏳ กำลังลบ...';

            try {
                const response = await fetch('/admin/news/delete-multiple', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ ids: selectedIds })
                });

                const result = await response.json();

                if (result.success) {
                    alert(`ลบสำเร็จ ${result.deletedCount} รายการ`);
                    location.reload();
                } else {
                    alert(`เกิดข้อผิดพลาด: ${result.message}`);
                    deleteSelectedBtn.disabled = false;
                    deleteSelectedBtn.textContent = '🗑️ ลบที่เลือก';
                }
            } catch (error) {
                console.error('Error:', error);
                alert('เกิดข้อผิดพลาดในการลบข้อมูล');
                deleteSelectedBtn.disabled = false;
                deleteSelectedBtn.textContent = '🗑️ ลบที่เลือก';
            }
        });
    </script>
</body>
</html>
