<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;700&display=swap" rel="stylesheet">
    
    <!-- Flatpickr -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/themes/material_orange.css">
    
    <style>
        body { font-family: 'Sarabun', sans-serif; }
        .file-input-label {
            display: inline-block;
            cursor: pointer;
            padding: 0.75rem 1.5rem;
            background-color: #f3f4f6;
            border: 2px dashed #d1d5db;
            border-radius: 0.5rem;
            text-align: center;
            transition: all 0.3s ease;
        }
        .file-input-label:hover {
            border-color: #ea580c;
            background-color: #fef3c7;
        }
        .file-input {
            display: none;
        }
        .image-preview {
            position: relative;
            width: 100%;
            max-width: 400px;
        }
        .image-preview img {
            width: 100%;
            height: auto;
            border-radius: 0.5rem;
            border: 2px solid #e5e7eb;
        }
        .remove-image {
            position: absolute;
            top: 10px;
            right: 10px;
            background-color: #ef4444;
            color: white;
            border: none;
            border-radius: 50%;
            width: 36px;
            height: 36px;
            cursor: pointer;
            font-size: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .remove-image:hover {
            background-color: #dc2626;
        }
        .status-badge { 
            display: inline-block; 
            padding: 0.5rem 1rem; 
            border-radius: 9999px; 
            font-size: 0.875rem; 
            font-weight: 500;
        }
        .status-published { background-color: #d1fae5; color: #065f46; }
        .status-draft { background-color: #fef3c7; color: #78350f; }
        .status-featured { background-color: #dbeafe; color: #0c2d6b; }
    </style>
</head>
<body class="bg-gray-100">
    <div class="flex min-h-screen">
        <!-- Sidebar -->
            <%- include('./partials/sidebar', { currentPage }) %>

        <!-- Main Content -->
        <main class="flex-1 p-8">
            <div class="max-w-4xl mx-auto">
                <div class="bg-white rounded-lg shadow-md p-6 mb-6">
                    <div class="flex justify-between items-start">
                        <div>
                            <h2 class="text-3xl font-bold text-gray-800">📝 แก้ไขข่าวประชาสัมพันธ์</h2>
                            <p class="text-gray-600 mt-2">ID: <%= news.id %> | ลงข่าว: <%= new Date(news.date_posted).toLocaleDateString('th-TH', {year: 'numeric', month: 'long', day: 'numeric'}) %></p>
                        </div>
                        <div class="flex gap-2">
                            <span class="status-badge <%= news.is_published ? 'status-published' : 'status-draft' %>">
                                <%= news.is_published ? '✓ เผยแพร่' : '◐ ร่าง' %>
                            </span>
                            <% if (news.is_featured) { %>
                                <span class="status-badge status-featured">★ ปักหมุด</span>
                            <% } %>
                        </div>
                    </div>
                </div>

                <% if (errorMessage) { %>
                    <div class="bg-red-100 border-l-4 border-red-600 text-red-700 p-4 mb-6 rounded">
                        <p class="font-medium">❌ เกิดข้อผิดพลาด</p>
                        <p><%= errorMessage %></p>
                    </div>
                <% } %>

                <form action="/admin/news/edit/<%= news.id %>" method="POST" enctype="multipart/form-data" class="bg-white rounded-lg shadow-md p-6">
                    <div class="space-y-6">
                        <!-- หัวข้อข่าว -->
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">
                                <span class="text-red-600">*</span> หัวข้อข่าว
                            </label>
                            <input type="text" name="title" required 
                                   value="<%= news.title %>"
                                   class="w-full p-3 border-2 border-gray-300 rounded-lg focus:border-orange-500 focus:outline-none"
                                   placeholder="กรอกหัวข้อข่าว...">
                        </div>

                        <!-- รายละเอียด -->
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">รายละเอียดข่าว</label>
                            <textarea name="description" rows="6"
                                      class="w-full p-3 border-2 border-gray-300 rounded-lg focus:border-orange-500 focus:outline-none"
                                      placeholder="กรอกรายละเอียดข่าวสาร..."><%= news.description || '' %></textarea>
                        </div>

                        <!-- หมวดหมู่ -->
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">หมวดหมู่ข่าว</label>
                            <select name="news_category" class="w-full p-3 border-2 border-gray-300 rounded-lg focus:border-orange-500 focus:outline-none">
                                <option value="">-- เลือกหมวดหมู่ --</option>
                                <option value="ข่าวประชาสัมพันธ์" <% if (news.news_category === 'ข่าวประชาสัมพันธ์') { %>selected<% } %>>ข่าวประชาสัมพันธ์</option>
                                <option value="ติดตามการบริหาร" <% if (news.news_category === 'ติดตามการบริหาร') { %>selected<% } %>>ติดตามการบริหาร</option>
                                <option value="บริการประชาชน" <% if (news.news_category === 'บริการประชาชน') { %>selected<% } %>>บริการประชาชน</option>
                                <option value="โครงการพิเศษ" <% if (news.news_category === 'โครงการพิเศษ') { %>selected<% } %>>โครงการพิเศษ</option>
                                <option value="ประกาศ" <% if (news.news_category === 'ประกาศ') { %>selected<% } %>>ประกาศ</option>
                                <% categories.forEach(cat => { %>
                                    <% if (cat.news_category && !['ข่าวประชาสัมพันธ์', 'ติดตามการบริหาร', 'บริการประชาชน', 'โครงการพิเศษ', 'ประกาศ'].includes(cat.news_category)) { %>
                                        <option value="<%= cat.news_category %>" <% if (news.news_category === cat.news_category) { %>selected<% } %>><%= cat.news_category %></option>
                                    <% } %>
                                <% }); %>
                            </select>
                        </div>

                        <!-- วันที่ลงข่าว -->
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">วันที่ลงข่าว</label>
                            <% 
                                const postedDate = news.date_posted ? new Date(news.date_posted) : new Date();
                                const yyyy = postedDate.getFullYear();
                                const mm = String(postedDate.getMonth() + 1).padStart(2, '0');
                                const dd = String(postedDate.getDate()).padStart(2, '0');
                                const postedDateValue = `${yyyy}-${mm}-${dd}`;
                            %>
                            <input type="text" id="datepicker" name="date_posted" required readonly 
                                   value="<%= postedDateValue %>"
                                   class="w-full p-3 border-2 border-gray-300 rounded-lg focus:border-orange-500 focus:outline-none cursor-pointer bg-white"
                                   placeholder="เลือกวันที่...">
                        </div>

                        <!-- รูปภาพหัวข้อข่าว -->
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">🖼️ รูปภาพหัวข้อข่าว</label>
                            <% const previewImageUrl = news.image_preview_url || ''; %>
                            
                            <% if (previewImageUrl) { %>
                                <div class="mb-4">
                                    <p class="text-sm text-gray-600 mb-2">รูปภาพปัจจุบัน:</p>
                                    <div class="image-preview">
                                        <img src="<%= previewImageUrl %>" alt="<%= news.title %>">
                                        <button type="button" class="remove-image" onclick="removeCurrentImage()">×</button>
                                    </div>
                                </div>
                            <% } %>

                            <label class="file-input-label">
                                <input type="file" name="image" class="file-input" id="imageInput" accept="image/*">
                                <div class="text-sm text-gray-600">
                                    <div class="mb-1">📤 คลิกเพื่อเลือกไฟล์ หรือ ลากไฟล์มาวางที่นี่</div>
                                    <div class="text-xs text-gray-500">รูปแนะนำ: 1200x630 px | สูงสุด 10MB</div>
                                </div>
                            </label>
                            <div id="imagePreview" class="mt-4"></div>
                        </div>

                        <!-- สถานะการเผยแพร่ -->
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="flex items-center gap-2">
                                    <input type="checkbox" name="is_published" value="1" <% if (news.is_published) { %>checked<% } %> 
                                           class="w-5 h-5 text-orange-600 border-gray-300 rounded focus:ring-orange-500">
                                    <span class="text-sm font-medium text-gray-700">เผยแพร่ข่าวนี้</span>
                                </label>
                                <p class="text-xs text-gray-500 mt-1">ถ้าไม่ติก จะเก็บเป็นร่าง</p>
                            </div>

                            <div>
                                <label class="flex items-center gap-2">
                                    <input type="checkbox" name="is_featured" value="1" <% if (news.is_featured) { %>checked<% } %> 
                                           class="w-5 h-5 text-blue-600 border-gray-300 rounded focus:ring-blue-500">
                                    <span class="text-sm font-medium text-gray-700">ปักหมุด</span>
                                </label>
                                <p class="text-xs text-gray-500 mt-1">แสดงในหน้าแรก</p>
                            </div>
                        </div>

                        <!-- สถิติวิว -->
                        <div class="bg-gray-50 p-4 rounded-lg">
                            <p class="text-sm text-gray-600">
                                <span class="font-medium">👁️ ดูแล้ว:</span> <%= news.view_count || 0 %> ครั้ง
                            </p>
                            <p class="text-sm text-gray-600 mt-1">
                                <span class="font-medium">🕐 สร้างข่าว:</span> <%= new Date(news.created_at).toLocaleDateString('th-TH', {year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit'}) %>
                            </p>
                            <p class="text-sm text-gray-600 mt-1">
                                <span class="font-medium">✏️ แก้ไขล่าสุด:</span> <%= new Date(news.updated_at).toLocaleDateString('th-TH', {year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit'}) %>
                            </p>
                        </div>

                        <!-- ปุ่มบันทึก -->
                        <div class="pt-4 flex gap-4">
                            <button type="submit" class="bg-orange-600 hover:bg-orange-700 text-white font-bold py-3 px-6 rounded-lg transition shadow-md">
                                💾 บันทึกการแก้ไข
                            </button>
                            <a href="/admin/news" class="bg-gray-600 hover:bg-gray-700 text-white font-bold py-3 px-6 rounded-lg transition inline-block">
                                ← ยกเลิก
                            </a>
                        </div>
                    </div>
                </form>
            </div>
        </main>
    </div>
    
    <!-- Flatpickr JS -->
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/th.js"></script>
    
    <script>
        // Flatpickr Date Picker
        const datepickerInput = document.getElementById('datepicker');
        flatpickr(datepickerInput, {
            locale: 'th',
            dateFormat: 'Y-m-d',
            altInput: true,
            altFormat: 'j M Y',
            allowInput: false,
            defaultDate: datepickerInput.value || new Date()
        });

        // Image Preview
        const imageInput = document.getElementById('imageInput');
        const imagePreview = document.getElementById('imagePreview');

        imageInput.addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(event) {
                    imagePreview.innerHTML = `
                        <div class="image-preview">
                            <img src="${event.target.result}" alt="Preview">
                            <button type="button" class="remove-image" onclick="clearImage()">×</button>
                        </div>
                    `;
                };
                reader.readAsDataURL(file);
            }
        });

        // Drag and Drop
        const fileInputLabel = document.querySelector('.file-input-label');
        
        fileInputLabel.addEventListener('dragover', (e) => {
            e.preventDefault();
            fileInputLabel.style.borderColor = '#ea580c';
            fileInputLabel.style.backgroundColor = '#fef3c7';
        });

        fileInputLabel.addEventListener('dragleave', () => {
            fileInputLabel.style.borderColor = '#d1d5db';
            fileInputLabel.style.backgroundColor = '#f3f4f6';
        });

        fileInputLabel.addEventListener('drop', (e) => {
            e.preventDefault();
            fileInputLabel.style.borderColor = '#d1d5db';
            fileInputLabel.style.backgroundColor = '#f3f4f6';
            
            const files = e.dataTransfer.files;
            if (files.length > 0) {
                imageInput.files = files;
                const event = new Event('change', { bubbles: true });
                imageInput.dispatchEvent(event);
            }
        });

        function clearImage() {
            imageInput.value = '';
            imagePreview.innerHTML = '';
        }

        function removeCurrentImage() {
            // This just removes the image preview, but keeps the current image in the database
        }
    </script>
</body>
</html>
