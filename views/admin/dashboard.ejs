<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Sarabun', sans-serif; }
    </style>
</head>
<body class="bg-gray-100">
    <div class="flex min-h-screen">
        <!-- Sidebar -->
        <%- include('admin-panel', { currentPage }) %>

        <!-- Main Content -->
        <main class="flex-1 p-8">
            <div class="max-w-7xl mx-auto">
                <!-- Header -->
                <div class="bg-white rounded-lg shadow-md p-6 mb-6">
                    <h2 class="text-3xl font-bold text-gray-800">ระบบจัดการหลังบ้าน</h2>
                    <p class="text-gray-600 mt-2">เทศบาลนครปากเกร็ด จังหวัดนนทบุรี</p>
                </div>

                <!-- Cards -->
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                    <!-- Partials Card -->
                    <div class="bg-white rounded-lg shadow-md p-6 hover:shadow-xl transition">
                        <div class="text-4xl mb-4">🧩</div>
                        <h3 class="text-xl font-bold text-gray-800 mb-2">จัดการ Partials</h3>
                        <p class="text-gray-600 mb-4">แก้ไขส่วนประกอบต่างๆ ของเว็บไซต์</p>
                        <a href="/admin/partials" class="inline-block bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700">
                            เข้าจัดการ →
                        </a>
                    </div>

                    <!-- Models Card -->
                    <div class="bg-white rounded-lg shadow-md p-6 hover:shadow-xl transition">
                        <div class="text-4xl mb-4">🗄️</div>
                        <h3 class="text-xl font-bold text-gray-800 mb-2">จัดการ Models</h3>
                        <p class="text-gray-600 mb-4">แก้ไขโครงสร้างฐานข้อมูล</p>
                        <a href="/admin/models" class="inline-block bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700">
                            เข้าจัดการ →
                        </a>
                    </div>

                    <!-- News Card -->
                    <div class="bg-white rounded-lg shadow-md p-6 hover:shadow-xl transition">
                        <div class="text-4xl mb-4">📰</div>
                        <h3 class="text-xl font-bold text-gray-800 mb-2">จัดการข่าวสาร</h3>
                        <p class="text-gray-600 mb-4">เพิ่ม แก้ไข ลบข่าวสาร</p>
                        <a href="/admin/news" class="inline-block bg-orange-600 text-white px-4 py-2 rounded hover:bg-orange-700">
                            เข้าจัดการ →
                        </a>
                    </div>

                    <!-- Sliders Card -->
                    <div class="bg-white rounded-lg shadow-md p-6 hover:shadow-xl transition">
                        <div class="text-4xl mb-4">🎬</div>
                        <h3 class="text-xl font-bold text-gray-800 mb-2">จัดการ Slider</h3>
                        <p class="text-gray-600 mb-4">จัดการภาพสไลด์หน้าแรก</p>
                        <a href="/admin/sliders" class="inline-block bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700">
                            เข้าจัดการ →
                        </a>
                    </div>
                </div>

                <!-- Quick Stats -->
                <div class="bg-white rounded-lg shadow-md p-6 mt-6">
                    <h3 class="text-xl font-bold text-gray-800 mb-4">สถิติระบบ</h3>
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                        <div class="text-center">
                            <div class="text-3xl font-bold text-blue-600">18</div>
                            <div class="text-sm text-gray-600">Partials</div>
                        </div>
                        <div class="text-center">
                            <div class="text-3xl font-bold text-green-600">2</div>
                            <div class="text-sm text-gray-600">Models</div>
                        </div>
                        <div class="text-center">
                            <div class="text-3xl font-bold text-orange-600">-</div>
                            <div class="text-sm text-gray-600">ข่าวสาร</div>
                        </div>
                        <div class="text-center">
                            <div class="text-3xl font-bold text-purple-600">✓</div>
                            <div class="text-sm text-gray-600">ระบบพร้อมใช้งาน</div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</body>
</html>
