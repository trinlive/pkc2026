<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;700&display=swap" rel="stylesheet">
    
    <!-- Flatpickr -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/themes/material_orange.css">
    
    <style>
        body { font-family: 'Sarabun', sans-serif; }
        .file-input-label {
            display: inline-block;
            cursor: pointer;
            padding: 0.75rem 1.5rem;
            background-color: #f3f4f6;
            border: 2px dashed #d1d5db;
            border-radius: 0.5rem;
            text-align: center;
            transition: all 0.3s ease;
        }
        .file-input-label:hover {
            border-color: #ea580c;
            background-color: #fef3c7;
        }
        .file-input {
            display: none;
        }
        .image-preview {
            position: relative;
            width: 100%;
            max-width: 400px;
        }
        .image-preview img {
            width: 100%;
            height: auto;
            border-radius: 0.5rem;
            border: 2px solid #e5e7eb;
        }
        .remove-image {
            position: absolute;
            top: 10px;
            right: 10px;
            background-color: #ef4444;
            color: white;
            border: none;
            border-radius: 50%;
            width: 36px;
            height: 36px;
            cursor: pointer;
            font-size: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .remove-image:hover {
            background-color: #dc2626;
        }
        .progress-container {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.7);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 9999;
        }
        .progress-box {
            background: white;
            padding: 2rem;
            border-radius: 1rem;
            box-shadow: 0 10px 40px rgba(0,0,0,0.3);
            min-width: 400px;
        }
        .progress-bar-wrapper {
            width: 100%;
            height: 24px;
            background: #e5e7eb;
            border-radius: 12px;
            overflow: hidden;
            margin: 1rem 0;
        }
        .progress-bar {
            height: 100%;
            background: linear-gradient(90deg, #ea580c, #f97316);
            transition: width 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 12px;
            font-weight: bold;
        }
    </style>
</head>
<body class="bg-gray-100">
    <div class="flex min-h-screen">
        <!-- Sidebar -->
        <%- include('./partials/sidebar', { currentPage: 'budgettransfer' }) %>

        <!-- Main Content -->
        <main class="flex-1 p-8">
            <div class="max-w-4xl mx-auto">
                <div class="bg-white rounded-lg shadow-md p-6 mb-6">
                    <h2 class="text-3xl font-bold text-gray-800">💰 เพิ่มการโอนงบประมาณรายจ่ายใหม่</h2>
                    <p class="text-gray-600 mt-2">กรอกรายละเอียดข้อมูลการโอนงบประมาณรายจ่ายประจำปี</p>
                </div>

                <% if (errorMessage) { %>
                    <div class="bg-red-100 border-l-4 border-red-600 text-red-700 p-4 mb-6 rounded">
                        <p class="font-medium">❌ เกิดข้อผิดพลาด</p>
                        <p><%= errorMessage %></p>
                    </div>
                <% } %>

                <!-- Progress Upload Modal -->
                <div id="uploadProgress" class="progress-container">
                    <div class="progress-box">
                        <h3 class="text-xl font-bold text-gray-800 mb-2" id="progressTitle">กำลังอัปโหลด...</h3>
                        <div class="progress-bar-wrapper">
                            <div class="progress-bar" id="progressBar" style="width: 0%">0%</div>
                        </div>
                        <p class="text-sm text-gray-600 text-center" id="progressStatus">กำลังเตรียมข้อมูล...</p>
                    </div>
                </div>

                <form id="budgetForm" action="/admin/budgettransfer/add" method="POST" enctype="multipart/form-data" class="bg-white rounded-lg shadow-md p-6">
                    <div class="space-y-6">
                        <!-- หัวข้อ/ชื่อรายการ -->
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">
                                <span class="text-red-600">*</span> หัวข้อ/ชื่อรายการ
                            </label>
                            <input type="text" name="title" required 
                                   value="<%= formData.title || '' %>"
                                   class="w-full p-3 border-2 border-gray-300 rounded-lg focus:border-orange-500 focus:outline-none"
                                   placeholder="กรอกหัวข้อการโอนงบประมาณ...">
                        </div>

                        <!-- เลขอ้างอิง -->
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">เลขอ้างอิง</label>
                            <input type="text" name="reference_number"
                                   value="<%= formData.reference_number || '' %>"
                                   class="w-full p-3 border-2 border-gray-300 rounded-lg focus:border-orange-500 focus:outline-none"
                                   placeholder="เช่น BT-2024-001">
                        </div>

                        <!-- หมวดหมู่ -->
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">หมวดหมู่</label>
                            <input type="text" name="category"
                                   value="<%= formData.category || '' %>"
                                   class="w-full p-3 border-2 border-gray-300 rounded-lg focus:border-orange-500 focus:outline-none"
                                   placeholder="เช่น งบประมาณหมวดอื่น, งบประมาณพัฒนา">
                        </div>

                        <!-- รายละเอียด -->
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">รายละเอียด</label>
                            <textarea name="description" rows="6"
                                      class="w-full p-3 border-2 border-gray-300 rounded-lg focus:border-orange-500 focus:outline-none"
                                      placeholder="กรอกรายละเอียดการโอนงบประมาณ..."><%= formData.description || '' %></textarea>
                        </div>

                        <!-- วันที่สร้าง -->
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">วันที่สร้าง</label>
                            <input type="text" id="datepicker" name="date_posted" required readonly 
                                   value="<%= formData.date_posted || '' %>"
                                   class="w-full p-3 border-2 border-gray-300 rounded-lg focus:border-orange-500 focus:outline-none cursor-pointer bg-white"
                                   placeholder="เลือกวันที่...">
                        </div>

                        <!-- รูปภาพหัวข้อ -->
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">🖼️ รูปภาพหัวข้อข้อมูล</label>
                            <label class="file-input-label">
                                <input type="file" name="image" class="file-input" id="imageInput" accept="image/*">
                                <div class="text-sm text-gray-600">
                                    <div class="mb-1">📤 คลิกเพื่อเลือกไฟล์ หรือ ลากไฟล์มาวางที่นี่</div>
                                    <div class="text-xs text-gray-500">รูปแนะนำ: 1200x630 px | สูงสุด 10MB</div>
                                </div>
                            </label>
                            <div id="imagePreview" class="mt-4"></div>
                        </div>

                        <!-- ไฟล์แนบ PDF -->
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">📎 ไฟล์แนบ (PDF/JPG)</label>
                            <label class="file-input-label w-full">
                                <input type="file" name="attachment" class="file-input" id="attachmentInput" accept=".pdf,.jpg,.jpeg,.png,application/pdf,image/jpeg,image/png">
                                <div class="text-sm text-gray-600">
                                    <div class="mb-1">📄 คลิกเพื่อเลือกไฟล์แนบหรือเอกสารประกอบ</div>
                                    <div class="text-xs text-gray-500">รองรับ: PDF, JPG, JPEG, PNG | สูงสุด 10MB</div>
                                </div>
                            </label>
                            <p id="attachmentName" class="mt-2 text-sm text-gray-600"></p>
                        </div>

                        <!-- สถานะการเผยแพร่ -->
                        <div>
                            <label class="flex items-center gap-2">
                                <input type="checkbox" name="is_published" value="1" <% if (formData.is_published || !formData.is_published) { %>checked<% } %> 
                                       class="w-5 h-5 text-orange-600 border-gray-300 rounded focus:ring-orange-500">
                                <span class="text-sm font-medium text-gray-700">เผยแพร่ข้อมูลนี้ทันที</span>
                            </label>
                            <p class="text-xs text-gray-500 mt-1">ถ้าไม่ติก จะเก็บเป็นร่าง</p>
                        </div>

                        <!-- ปักหมุด -->
                        <div>
                            <label class="flex items-center gap-2">
                                <input type="checkbox" name="is_featured" value="1"
                                       class="w-5 h-5 text-blue-600 border-gray-300 rounded focus:ring-blue-500">
                                <span class="text-sm font-medium text-gray-700">★ ปักหมุดไว้หน้าแรก</span>
                            </label>
                            <p class="text-xs text-gray-500 mt-1">ข้อมูลแนวหน้าจะแสดงไว้ด้านบนสุด</p>
                        </div>

                        <!-- ปุ่มบันทึก -->
                        <div class="pt-4 flex gap-4">
                            <button type="submit" class="bg-orange-600 hover:bg-orange-700 text-white font-bold py-3 px-6 rounded-lg transition shadow-md">
                                💾 บันทึกข้อมูล
                            </button>
                            <a href="/admin/budgettransfer" class="bg-gray-600 hover:bg-gray-700 text-white font-bold py-3 px-6 rounded-lg transition inline-block">
                                ← ยกเลิก
                            </a>
                        </div>
                    </div>
                </form>
            </div>
        </main>
    </div>
    
    <!-- Flatpickr JS -->
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/th.js"></script>
    
    <script>
        const resizeImageFile = (file, { maxWidth = 1920, quality = 0.82 } = {}) => {
            return new Promise((resolve, reject) => {
                const reader = new FileReader();
                reader.onload = () => {
                    const img = new Image();
                    img.onload = () => {
                        const ratio = Math.min(1, maxWidth / img.width);
                        const canvas = document.createElement('canvas');
                        canvas.width = Math.max(1, Math.round(img.width * ratio));
                        canvas.height = Math.max(1, Math.round(img.height * ratio));

                        const ctx = canvas.getContext('2d');
                        ctx.drawImage(img, 0, 0, canvas.width, canvas.height);

                        const outputType = 'image/jpeg';
                        canvas.toBlob((blob) => {
                            if (!blob) {
                                return reject(new Error('ไม่สามารถย่อขนาดรูปภาพได้'));
                            }
                            const resizedFile = new File(
                                [blob],
                                file.name.replace(/\.[^/.]+$/, '.jpg'),
                                { type: outputType, lastModified: Date.now() }
                            );
                            resolve(resizedFile);
                        }, outputType, quality);
                    };
                    img.onerror = () => reject(new Error('ไม่สามารถอ่านไฟล์รูปภาพได้'));
                    img.src = reader.result;
                };
                reader.onerror = () => reject(new Error('ไม่สามารถโหลดไฟล์สำหรับย่อขนาดได้'));
                reader.readAsDataURL(file);
            });
        };

        const setInputFile = (input, file) => {
            const dt = new DataTransfer();
            dt.items.add(file);
            input.files = dt.files;
        };

        // Flatpickr Date Picker
        flatpickr("#datepicker", {
            locale: "th",
            dateFormat: "Y-m-d",
            defaultDate: new Date(),
            onChange: function(selectedDates, dateStr, instance) {
                const date = selectedDates[0];
                const thaiMonths = ['ม.ค.', 'ก.พ.', 'มี.ค.', 'เม.ย.', 'พ.ค.', 'มิ.ย.', 
                                   'ก.ค.', 'ส.ค.', 'ก.ย.', 'ต.ค.', 'พ.ย.', 'ธ.ค.'];
                
                if (date) {
                    const day = date.getDate();
                    const month = thaiMonths[date.getMonth()];
                    const year = date.getFullYear() + 543;
                    const displayDate = `${day} ${month} ${year}`;
                    
                    instance.input.value = dateStr;
                    instance.input.placeholder = displayDate;
                }
            }
        });

        // Image Preview
        const imageInput = document.getElementById('imageInput');
        const imagePreview = document.getElementById('imagePreview');

        imageInput.addEventListener('change', async function(e) {
            const file = e.target.files[0];
            if (file) {
                let previewFile = file;
                if (file.type.startsWith('image/')) {
                    try {
                        const resizedFile = await resizeImageFile(file, { maxWidth: 1920, quality: 0.82 });
                        setInputFile(imageInput, resizedFile);
                        previewFile = resizedFile;
                    } catch (error) {
                        console.warn('Resize image failed, using original file:', error);
                    }
                }

                const reader = new FileReader();
                reader.onload = function(event) {
                    imagePreview.innerHTML = `
                        <div class="image-preview">
                            <img src="${event.target.result}" alt="Preview">
                            <button type="button" class="remove-image" onclick="clearImage()">×</button>
                        </div>
                    `;
                };
                reader.readAsDataURL(previewFile);
            }
        });

        function clearImage() {
            imageInput.value = '';
            imagePreview.innerHTML = '';
        }

        const attachmentInput = document.getElementById('attachmentInput');
        const attachmentName = document.getElementById('attachmentName');
        if (attachmentInput) {
            attachmentInput.addEventListener('change', async function(e) {
                const file = e.target.files[0];
                if (!file) {
                    attachmentName.textContent = '';
                    return;
                }

                let selectedFile = file;
                if (file.type.startsWith('image/')) {
                    try {
                        const resizedFile = await resizeImageFile(file, { maxWidth: 2200, quality: 0.85 });
                        setInputFile(attachmentInput, resizedFile);
                        selectedFile = resizedFile;
                    } catch (error) {
                        console.warn('Resize attachment image failed, using original file:', error);
                    }
                }

                const mb = (selectedFile.size / (1024 * 1024)).toFixed(2);
                attachmentName.textContent = `ไฟล์ที่เลือก: ${selectedFile.name} (${mb} MB)`;
            });
        }

        // Handle form submission with progress tracking
        const budgetForm = document.getElementById('budgetForm');
        const uploadProgress = document.getElementById('uploadProgress');
        const progressBar = document.getElementById('progressBar');
        const progressTitle = document.getElementById('progressTitle');
        const progressStatus = document.getElementById('progressStatus');

        budgetForm.addEventListener('submit', async function(e) {
            e.preventDefault();

            const formData = new FormData(budgetForm);
            
            uploadProgress.style.display = 'flex';
            progressBar.style.width = '0%';
            progressBar.textContent = '0%';
            progressTitle.textContent = 'กำลังอัปโหลด...';
            progressStatus.textContent = 'กำลังเตรียมข้อมูล...';

            try {
                const xhr = new XMLHttpRequest();

                xhr.upload.addEventListener('progress', (e) => {
                    if (e.lengthComputable) {
                        const percentComplete = Math.round((e.loaded / e.total) * 100);
                        progressBar.style.width = percentComplete + '%';
                        progressBar.textContent = percentComplete + '%';
                        progressStatus.textContent = `กำลังอัปโหลดไฟล์... (${(e.loaded / (1024*1024)).toFixed(1)} MB / ${(e.total / (1024*1024)).toFixed(1)} MB)`;
                    }
                });

                xhr.addEventListener('load', () => {
                    if (xhr.status === 200) {
                        progressBar.style.width = '100%';
                        progressBar.textContent = '100%';
                        progressTitle.textContent = '✓ สำเร็จ!';
                        progressStatus.textContent = 'บันทึกข้อมูลเรียบร้อย กำลังโหลดหน้าใหม่...';
                        setTimeout(() => {
                            window.location.href = '/admin/budgettransfer';
                        }, 1000);
                    } else {
                        throw new Error('Upload failed');
                    }
                });

                xhr.addEventListener('error', () => {
                    progressTitle.textContent = '✗ เกิดข้อผิดพลาด';
                    progressStatus.textContent = 'ไม่สามารถอัปโหลดได้ กรุณาลองใหม่อีกครั้ง';
                    setTimeout(() => {
                        uploadProgress.style.display = 'none';
                    }, 3000);
                });

                xhr.addEventListener('loadend', () => {
                    if (xhr.status !== 200) {
                        progressTitle.textContent = '⚠ เกิดข้อผิดพลาด';
                        progressStatus.textContent = 'กรุณาตรวจสอบข้อมูลและลองใหม่อีกครั้ง';
                        setTimeout(() => {
                            uploadProgress.style.display = 'none';
                        }, 3000);
                    }
                });

                xhr.upload.addEventListener('load', () => {
                    progressTitle.textContent = 'กำลังประมวลผล...';
                    progressStatus.textContent = 'กำลังบีบอัดและประมวลผลไฟล์...';
                });

                xhr.open('POST', '/admin/budgettransfer/add');
                xhr.send(formData);

            } catch (error) {
                console.error('Upload error:', error);
                progressTitle.textContent = '✗ เกิดข้อผิดพลาด';
                progressStatus.textContent = error.message || 'เกิดข้อผิดพลาดในการอัปโหลด';
                setTimeout(() => {
                    uploadProgress.style.display = 'none';
                }, 3000);
            }
        });
    </script>
</body>
</html>
