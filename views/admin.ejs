<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-gray-100 font-sans">
    <div class="min-h-screen flex items-center justify-center p-6">
        <div class="bg-white shadow-xl rounded-2xl p-8 max-w-md w-full">
            <h1 class="text-2xl font-bold text-gray-800 mb-6 text-center">เพิ่มข่าวใหม่</h1>
            
            <form action="/admin/add" method="POST" class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">หัวข้อข่าว</label>
                    <input type="text" name="title" required class="w-full p-3 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">วันที่แสดง (เช่น 26 ก.พ. 2569)</label>
                    <input type="text" name="date_posted" required class="w-full p-3 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">
                </div>
                <div class="pt-4">
                    <button type="submit" class="w-full bg-green-600 hover:bg-green-700 text-white font-bold py-3 rounded-lg transition shadow-md">
                        บันทึกข้อมูลลงฐานข้อมูล
                    </button>
                    <a href="/" class="block text-center mt-4 text-gray-500 hover:underline text-sm">ยกเลิกและกลับหน้าแรก</a>
                </div>
            </form>
        </div>
    </div>
</body>
</html>