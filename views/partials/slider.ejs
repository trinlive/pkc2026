<script>
    var swiper = new Swiper(".hero-swiper", {
        spaceBetween: 0,
        effect: "fade", // ใช้ fade ทำให้ภาพเปลี่ยนแบบนุ่มนวลสมูทมาก
        loop: true,
        autoplay: {
            delay: 5000, // เปลี่ยนสไลด์ทุก 5 วินาที
            disableOnInteraction: false, // เอาเมาส์จิ้มแล้วยังเลื่อนอัตโนมัติอยู่
        },
        pagination: {
            el: ".swiper-pagination",
            clickable: true,
            dynamicBullets: true, // จุดไข่ปลาแบบยืดหยุ่น (ฮิตมากในแอพสมัยใหม่)
        },
        navigation: {
            nextEl: ".swiper-button-next",
            prevEl: ".swiper-button-prev",
        },
    });
</script>