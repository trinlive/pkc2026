<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<style>
    /* ปรับแต่ง Slider ให้เต็มจอและดู Modern - รองรับทุก Resolution */
    .hero-swiper { 
        width: 100%; 
        height: 50vh; /* ความสูงเริ่มต้นสำหรับมือถือ */
        min-height: 400px; /* ความสูงขั้นต่ำสำหรับจอเล็ก */
        max-height: 900px; /* ความสูงสูงสุดสำหรับจอใหญ่มาก */
    }
    
    @media (min-width: 768px) {
        .hero-swiper { 
            height: 60vh; 
            min-height: 500px;
        }
    }
    
    @media (min-width: 1280px) {
        .hero-swiper { 
            height: 70vh; 
            min-height: 600px;
        }
    }
    
    /* สำหรับจอ Ultra-wide (21:9) */
    @media (min-aspect-ratio: 21/9) {
        .hero-swiper { 
            height: 80vh;
            max-height: 1000px;
        }
    }
    
    /* สำหรับจอแนวตั้ง (Portrait) */
    @media (max-aspect-ratio: 9/16) {
        .hero-swiper { 
            height: 40vh;
            min-height: 350px;
        }
    }
    
    .swiper-slide {
        display: flex; 
        align-items: flex-end; /* ให้ข้อความอยู่ด้านล่าง */
        background-size: cover; /* ปกคลุมเต็มพื้นที่ */
        background-position: center center; /* จัดกลางทั้ง 2 แกน */
        background-repeat: no-repeat; /* ไม่ซ้ำภาพ */
    }
    
    /* ไล่สีพื้นหลังข้อความให้ดูลึก (Cinematic Gradient) */
    .slider-overlay {
        position: absolute; 
        inset: 0; 
        background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.4) 50%, rgba(0,0,0,0) 100%);
    }

    /* ตกแต่งจุดไข่ปลา (Pagination) */
    .swiper-pagination-bullet { background: #ffffff; opacity: 0.5; transition: all 0.3s ease; }
    .swiper-pagination-bullet-active { opacity: 1; background: #fbbf24; width: 24px; border-radius: 8px; }
    
    /* ตกแต่งปุ่มเลื่อนซ้าย-ขวา */
    .swiper-button-next::after, .swiper-button-prev::after { font-size: 1.5rem !important; font-weight: bold; }
    .swiper-button-next, .swiper-button-prev { color: rgba(255,255,255,0.7); transition: color 0.3s; }
    .swiper-button-next:hover, .swiper-button-prev:hover { color: #ffffff; }
</style>

<div class="w-full relative z-0 mb-8 border-b-4 border-yellow-500">
    <div class="swiper hero-swiper">
        <div class="swiper-wrapper">
            
            <% if (typeof sliders !== 'undefined' && sliders && sliders.length > 0) { %>
                <% sliders.forEach(function(slider) { %>
                    <div class="swiper-slide" style="background-image: url('<%= slider.image_url %>');">
                        <div class="slider-overlay"></div>
                        <div class="absolute bottom-8 md:bottom-12 left-0 w-full px-4 sm:px-8 md:px-16 lg:px-24 z-10 max-w-7xl mx-auto">
                            <% if (slider.badge_text) { %>
                                <span class="bg-blue-600 px-2.5 py-1 md:px-3 md:py-1.5 rounded-full text-[10px] md:text-xs font-bold mb-2 md:mb-3 inline-block text-white shadow-lg"><%= slider.badge_text %></span>
                            <% } %>
                            <% if (slider.link_url) { %>
                                <a href="<%= slider.link_url %>" class="block">
                                    <h2 class="text-2xl sm:text-3xl md:text-5xl font-bold text-white mb-2 leading-tight drop-shadow-lg line-clamp-2 md:line-clamp-none hover:text-yellow-400 transition-colors"><%= slider.title %></h2>
                                </a>
                            <% } else { %>
                                <h2 class="text-2xl sm:text-3xl md:text-5xl font-bold text-white mb-2 leading-tight drop-shadow-lg line-clamp-2 md:line-clamp-none"><%= slider.title %></h2>
                            <% } %>
                            <% if (slider.subtitle) { %>
                                <p class="text-sm sm:text-base md:text-xl text-gray-200 drop-shadow-md line-clamp-2"><%= slider.subtitle %></p>
                            <% } %>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <!-- Fallback content กรณีไม่มีข้อมูล slider -->
                <div class="swiper-slide" style="background-image: url('https://picsum.photos/1920/1080?random=1');">
                    <div class="slider-overlay"></div>
                    <div class="absolute bottom-8 md:bottom-12 left-0 w-full px-4 sm:px-8 md:px-16 lg:px-24 z-10 max-w-7xl mx-auto">
                        <span class="bg-blue-600 px-2.5 py-1 md:px-3 md:py-1.5 rounded-full text-[10px] md:text-xs font-bold mb-2 md:mb-3 inline-block text-white shadow-lg">ข่าวเด่น</span>
                        <h2 class="text-2xl sm:text-3xl md:text-5xl font-bold text-white mb-2 leading-tight drop-shadow-lg line-clamp-2 md:line-clamp-none">ยินดีต้อนรับสู่เทศบาลนครปากเกร็ด</h2>
                        <p class="text-sm sm:text-base md:text-xl text-gray-200 drop-shadow-md line-clamp-2">มุ่งมั่นพัฒนาคุณภาพชีวิตประชาชนอย่างยั่งยืน สู่เมืองแห่งอนาคต</p>
                    </div>
                </div>
            <% } %>

        </div>
        <div class="swiper-button-next"></div>
        <div class="swiper-button-prev"></div>
        <div class="swiper-pagination mb-2"></div>
    </div>
</div>

<script>
    var swiper = new Swiper(".hero-swiper", {
        spaceBetween: 0,
        effect: "fade", // ใช้ fade ทำให้ภาพเปลี่ยนแบบนุ่มนวลสมูทมาก
        loop: true,
        autoplay: {
            delay: 5000, // เปลี่ยนสไลด์ทุก 5 วินาที
            disableOnInteraction: false, // เอาเมาส์จิ้มแล้วยังเลื่อนอัตโนมัติอยู่
        },
        pagination: {
            el: ".swiper-pagination",
            clickable: true,
            dynamicBullets: true, // จุดไข่ปลาแบบยืดหยุ่น (ฮิตมากในแอพสมัยใหม่)
        },
        navigation: {
            nextEl: ".swiper-button-next",
            prevEl: ".swiper-button-prev",
        },
    });
</script>