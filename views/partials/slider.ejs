        height: 50vh; /* ความสูงเริ่มต้นสำหรับมือถือ */
    }
    @media (min-width: 768px) {
        .hero-swiper { height: 60vh; } /* แท็บเล็ต */
    }
    @media (min-width: 1280px) {
        .hero-swiper { height: 70vh; } /* จอคอมพิวเตอร์ขนาดใหญ่ */
    }
    
    .swiper-slide {
        display: flex; 
        align-items: flex-end; /* ให้ข้อความอยู่ด้านล่าง */
        background-size: cover; 
        background-position: center;
    }
    
    /* ไล่สีพื้นหลังข้อความให้ดูลึก (Cinematic Gradient) */
    .slider-overlay {
        position: absolute; 
        inset: 0; 
        background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.4) 50%, rgba(0,0,0,0) 100%);
    }

    /* ตกแต่งจุดไข่ปลา (Pagination) */
    .swiper-pagination-bullet { background: #ffffff; opacity: 0.5; transition: all 0.3s ease; }
    .swiper-pagination-bullet-active { opacity: 1; background: #fbbf24; width: 24px; border-radius: 8px; }
    
    /* ตกแต่งปุ่มเลื่อนซ้าย-ขวา */
    .swiper-button-next::after, .swiper-button-prev::after { font-size: 1.5rem !important; font-weight: bold; }
    .swiper-button-next, .swiper-button-prev { color: rgba(255,255,255,0.7); transition: color 0.3s; }
    .swiper-button-next:hover, .swiper-button-prev:hover { color: #ffffff; }
</style>

